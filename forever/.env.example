# ============================================================
# Qwen Cloud / Alibaba Model Studio (ALL LLM + TTS + ASR + embeddings)
# OpenAI-compatible endpoint. Singapore (intl): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# ============================================================
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model routing — one model per job, never one model for everything
MODEL_PLANNER=qwen3-max            # Dean, Teacher, Arbiter (thinking)
MODEL_SCENE=qwen-plus              # Board Director, Voice Writer, Quiz Master, Researcher
MODEL_FAST=qwen-flash              # Domain Router, Librarian labeling, validators, memory distill
MODEL_VISION=qwen3-vl-plus         # page-image vision (regions, diagrams, transcription)
MODEL_CODER=qwen3-coder-plus       # Code Runner generation
MODEL_EMBEDDING=text-embedding-v4  # Archivist (pgvector)

# TTS (CosyVoice via DashScope) + word alignment (Paraformer ASR)
TTS_MODEL=cosyvoice-v2
TTS_VOICE_ID=
ASR_ALIGN_MODEL=paraformer-v2

# ============================================================
# Alibaba Cloud infrastructure (deployment proof)
# ============================================================
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION=ap-southeast-1

# OSS — audio, page images, manifests, notebook PDFs
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=

# ApsaraDB RDS PostgreSQL (+ pgvector extension enabled)
DATABASE_URL=postgresql://forever:forever@127.0.0.1:5432/forever

# Tair (Redis) — BullMQ queues + SSE progress events
REDIS_URL=redis://127.0.0.1:6379/0

# ============================================================
# External ingestion APIs (non-LLM; all LLM work stays on Qwen)
# ============================================================
# Topic-name input: Researcher web search (either provider)
TAVILY_API_KEY=
SERPER_API_KEY=

# URL/article ingestion: Jina Reader works keyless (rate-limited); key raises limits.
# Firecrawl optional alternative for hard pages.
JINA_API_KEY=
FIRECRAWL_API_KEY=

# Code Runner sandbox: local Docker runner on ECS by default; Judge0 as fallback
CODE_SANDBOX=docker
JUDGE0_API_KEY=

# ============================================================
# App
# ============================================================
FOREVER_ENV=development
FOREVER_WEB_PORT=3000
FOREVER_PUBLIC_URL=http://localhost:3000

# Generation guardrails
MAX_TOKENS_PER_SCENE=60000
MAX_REPAIR_ROUNDS=2
MAX_DEBATE_ROUNDS=2
