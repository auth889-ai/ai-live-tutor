# ============================================================
# Qwen Cloud / Alibaba Model Studio (ALL LLM + TTS + ASR + embeddings)
# OpenAI-compatible endpoint. Singapore (intl): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# ============================================================
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model routing — one model per job, never one model for everything.
# Qwen3.7 generation (verify exact IDs in your Model Studio console — names are authoritative there).
MODEL_PLANNER=qwen3.7-max          # Dean, Teacher, Arbiter — agent-first, long-horizon tool use
MODEL_SCENE=qwen3.7-plus           # Board Director, Voice Writer, Quiz Master, Researcher — multimodal, 1M ctx
MODEL_FAST=qwen3.6-flash           # Domain Router, Librarian labeling, validators, memory distill
MODEL_VISION=qwen3.7-plus          # page-image vision (regions, diagrams, transcription) — same model as SCENE
MODEL_CODER=qwen3-coder-plus       # Code Runner generation (no 3.7 coder variant shipped yet)
MODEL_EMBEDDING=text-embedding-v4  # Archivist (pgvector)

# TTS (CosyVoice via DashScope) + word alignment (Paraformer ASR)
TTS_MODEL=cosyvoice-v2
TTS_VOICE_ID=
ASR_ALIGN_MODEL=paraformer-v2

# ============================================================
# Alibaba Cloud infrastructure (deployment proof)
# ============================================================
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION=ap-southeast-1

# OSS — audio, page images, manifests, notebook PDFs
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=

# MongoDB — records (users, lessons). SET -> database backend (production); UNSET -> filesystem
# .data/ (local dev/tests only). Atlas works in dev; the deployment points the SAME driver at
# Alibaba ApsaraDB for MongoDB. Indexes are created automatically on first boot.
MONGODB_URI=
MONGODB_DB=forever

# Tair (Redis) — BullMQ queues + SSE progress events
REDIS_URL=redis://127.0.0.1:6379/0

# ============================================================
# External ingestion APIs (non-LLM; all LLM work stays on Qwen)
# ============================================================
# Topic-name + URL ingestion: PRIMARY path is Qwen's built-in web_search/web_extractor
# tools (Responses API — same DASHSCOPE_API_KEY, no extra key). The keys below are
# optional fallbacks only.
TAVILY_API_KEY=
SERPER_API_KEY=
JINA_API_KEY=
FIRECRAWL_API_KEY=

# Code Runner sandbox: local Docker runner on ECS by default; Judge0 as fallback
CODE_SANDBOX=docker
JUDGE0_API_KEY=

# ============================================================
# App
# ============================================================
FOREVER_ENV=development
FOREVER_WEB_PORT=3000
FOREVER_PUBLIC_URL=http://localhost:3000

# Generation guardrails
MAX_TOKENS_PER_SCENE=60000
MAX_REPAIR_ROUNDS=2
MAX_DEBATE_ROUNDS=2

# ElevenLabs TTS (natural voice + built-in word timestamps; supporting service)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=


# Active TTS provider: "elevenlabs" (word timestamps) or empty for Qwen TTS via DashScope.
# NOTE: TTS models are regional — if your workspace serves no TTS model, set a dedicated
# TTS workspace via ALIBABA_TTS_API_KEY + ALIBABA_TTS_BASE_URL (see below), or use elevenlabs.
TTS_PROVIDER=
