{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forever.dev/schemas/timeline-manifest.schema.json",
  "title": "TimelineManifest",
  "type": "object",
  "required": ["version", "sceneId", "durationMs", "layout", "objects", "actions", "voiceLines", "subtitles", "sourceEvidence"],
  "properties": {
    "version": { "type": "string" },
    "sceneId": { "type": "string" },
    "learningUnitId": { "type": "string" },
    "teachingIntent": { "type": "string" },
    "durationMs": { "type": "integer", "minimum": 1 },
    "layout": {
      "type": "object",
      "required": ["regions"],
      "properties": {
        "regions": {
          "type": "array",
          "items": { "$ref": "#/$defs/layoutRegion" }
        }
      }
    },
    "objects": {
      "type": "array",
      "items": { "$ref": "#/$defs/timelineObject" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/boardAction" }
    },
    "voiceLines": {
      "type": "array",
      "items": { "$ref": "#/$defs/voiceLine" }
    },
    "subtitles": {
      "type": "array",
      "items": { "$ref": "#/$defs/subtitleWord" }
    },
    "interactions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "sourceEvidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceEvidence" }
    }
  },
  "$defs": {
    "layoutRegion": {
      "type": "object",
      "required": ["regionId", "capability", "x", "y", "w", "h"],
      "properties": {
        "regionId": { "type": "string" },
        "capability": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number" },
        "h": { "type": "number" }
      }
    },
    "timelineObject": {
      "type": "object",
      "required": ["objectId", "type", "regionId", "content"],
      "properties": {
        "objectId": { "type": "string" },
        "type": { "type": "string" },
        "regionId": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number" },
        "h": { "type": "number" },
        "content": { "type": "object" },
        "style": { "type": "object" }
      }
    },
    "boardAction": {
      "type": "object",
      "required": ["actionId", "type", "startMs", "endMs"],
      "properties": {
        "actionId": { "type": "string" },
        "type": { "type": "string" },
        "objectId": { "type": "string" },
        "targetObjectId": { "type": "string" },
        "targetRegion": { "type": "string" },
        "startMs": { "type": "integer", "minimum": 0 },
        "endMs": { "type": "integer", "minimum": 0 },
        "payload": { "type": "object" }
      }
    },
    "voiceLine": {
      "type": "object",
      "required": ["voiceLineId", "beatId", "text", "startMs", "endMs"],
      "properties": {
        "voiceLineId": { "type": "string" },
        "beatId": { "type": "string" },
        "text": { "type": "string" },
        "startMs": { "type": "integer", "minimum": 0 },
        "endMs": { "type": "integer", "minimum": 0 }
      }
    },
    "subtitleWord": {
      "type": "object",
      "required": ["word", "startMs", "endMs", "beatId"],
      "properties": {
        "word": { "type": "string" },
        "startMs": { "type": "integer", "minimum": 0 },
        "endMs": { "type": "integer", "minimum": 0 },
        "beatId": { "type": "string" }
      }
    },
    "sourceEvidence": {
      "type": "object",
      "required": ["sourceId", "sourceRef", "quote"],
      "properties": {
        "sourceId": { "type": "string" },
        "sourceRef": { "type": "string" },
        "quote": { "type": "string" }
      }
    }
  }
}

