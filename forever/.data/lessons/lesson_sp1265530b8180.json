{"lessonTitle":"Properties of Binary Trees: From Concrete Examples to Powerful Formulas","sourcePackId":"sp_1265530b8180","skippedScenes":6,"scenes":[{"sceneId":"sc_01","title":"Counting Nodes on a Tiny Tree — The Hook","pedagogicalRole":"motivate","layout":"teacher_notebook_code","objects":[{"id":"title","objectType":"scene_title","renderHint":"text","region":"notebook_area","lineNumber":1,"content":"🌳 Binary Tree: Counting Nodes Level by Level","sourceRef":{"chunkId":"chunk_0001"}},{"id":"tree_diagram","objectType":"binary_tree_visual","renderHint":"diagram","region":"notebook_area","lineNumber":2,"content":{"diagramType":"graph","nodes":[{"id":"A","label":"A"},{"id":"B","label":"B"},{"id":"C","label":"C"},{"id":"D","label":"D"},{"id":"E","label":"E"},{"id":"F","label":"F"},{"id":"G","label":"G"}],"edges":[{"from":"A","to":"B"},{"from":"A","to":"C"},{"from":"B","to":"D"},{"from":"B","to":"E"},{"from":"C","to":"F"},{"from":"C","to":"G"}],"directed":true},"sourceRef":{"chunkId":"chunk_0001"}},{"id":"counting_trace","objectType":"level_counting","renderHint":"list","region":"notebook_area","lineNumber":3,"content":{"items":["Level 0 (root): 1 node → A","Level 1: 2 nodes → B, C","Level 2: 4 nodes → D, E, F, G","Total nodes so far: 1 + 2 + 4 = 7"]},"sourceRef":{"chunkId":"chunk_0001"}},{"id":"checkpoint_question","objectType":"motivation_question","renderHint":"quiz","region":"notebook_area","lineNumber":4,"content":{"question":"If I add one more level (level 3), what's the MAXIMUM nodes I could have at level 3? And in the whole tree?","choices":["Level 3: 6 nodes, Total: 13","Level 3: 8 nodes, Total: 15","Level 3: 16 nodes, Total: 31","Level 3: 4 nodes, Total: 11"],"answerIndex":1,"explanation":"Each level can double: Level 3 max = 2³ = 8 nodes. Total = 1 + 2 + 4 + 8 = 15 = 2⁴ - 1. This is the pattern we'll prove!"},"sourceRef":{"chunkId":"chunk_0001"}}],"voiceLines":[{"id":"1","text":"Let's look at this binary tree and count the nodes level by level. Notice that the root A sits alone at level zero.","targetObjectId":"tree_diagram"},{"id":"2","text":"Then at level one we have B and C, and at level two we have D, E, F, and G. See how each level can have up to twice as many nodes as the one above it?","targetObjectId":"tree_diagram"},{"id":"3","text":"A common mistake is to count edges instead of nodes, or to forget that the root is level zero, not level one.","targetObjectId":"tree_diagram"},{"id":"4","text":"Now let's record these counts in our trace. Level zero has one node, level one has two, and level two has four.","targetObjectId":"counting_trace","focusRef":0},{"id":"5","text":"Adding them up gives us seven total nodes. Here's the key insight: each level doubles, so the totals grow like powers of two.","targetObjectId":"counting_trace","focusRef":3},{"id":"6","text":"Now here's a checkpoint question to test your intuition. If we add a level three, what's the maximum number of nodes we could have at that level?","targetObjectId":"checkpoint_question"},{"id":"7","text":"Think about the doubling pattern: level zero had one, level one had two, level two had four, so level three can have at most eight nodes.","targetObjectId":"checkpoint_question","focusRef":1},{"id":"8","text":"That means the total tree would have fifteen nodes, which is two to the fourth power minus one. This is the pattern we'll prove next!","targetObjectId":"checkpoint_question","focusRef":2}],"timeline":{"sceneId":"sc_01","timingSource":"provisional","actions":[{"id":"act_point_title","kind":"point","startMs":0,"durationMs":600,"targetObjectId":"title"},{"id":"act_point_tree_diagram","kind":"point","startMs":900,"durationMs":600,"targetObjectId":"tree_diagram"},{"id":"act_speak_tree_diagram_0","kind":"speech","startMs":1100,"durationMs":8740,"voiceLineId":"1"},{"id":"act_write_tree_diagram","kind":"write","startMs":1200,"durationMs":28044,"targetObjectId":"tree_diagram"},{"id":"act_speak_tree_diagram_1","kind":"speech","startMs":9840,"durationMs":14060,"voiceLineId":"2"},{"id":"act_speak_tree_diagram_2","kind":"speech","startMs":23900,"durationMs":8360,"voiceLineId":"3"},{"id":"act_point_counting_trace","kind":"point","startMs":32560,"durationMs":600,"targetObjectId":"counting_trace"},{"id":"act_speak_counting_trace_0","kind":"speech","startMs":32760,"durationMs":8360,"voiceLineId":"4"},{"id":"act_write_counting_trace","kind":"write","startMs":32860,"durationMs":15390,"targetObjectId":"counting_trace"},{"id":"act_speak_counting_trace_1","kind":"speech","startMs":41120,"durationMs":8740,"voiceLineId":"5"},{"id":"act_point_checkpoint_question","kind":"point","startMs":50160,"durationMs":600,"targetObjectId":"checkpoint_question"},{"id":"act_speak_checkpoint_question_0","kind":"speech","startMs":50360,"durationMs":10260,"voiceLineId":"6"},{"id":"act_write_checkpoint_question","kind":"write","startMs":50460,"durationMs":26676,"targetObjectId":"checkpoint_question"},{"id":"act_speak_checkpoint_question_1","kind":"speech","startMs":60620,"durationMs":9880,"voiceLineId":"7"},{"id":"act_speak_checkpoint_question_2","kind":"speech","startMs":70500,"durationMs":9500,"voiceLineId":"8"}]},"durationMs":80300,"reviewRounds":0},{"sceneId":"sc_02","title":"Building the Level & Height Formulas from Scratch","pedagogicalRole":"intuition","layout":"teacher_notebook_code","objects":[{"id":"title_max_nodes","objectType":"section_title","renderHint":"text","region":"notebook_area","lineNumber":1,"content":"🌳 Max Nodes in a Binary Tree: Level-by-Level & by Height","sourceRef":{"chunkId":"chunk_0001"}},{"id":"tree_diagram","objectType":"binary_tree_visual","renderHint":"diagram","region":"notebook_area","lineNumber":2,"content":{"diagramType":"graph","nodes":[{"id":"r","label":"L0: 1 node"},{"id":"a","label":"L1"},{"id":"b","label":"L1"},{"id":"c","label":"L2"},{"id":"d","label":"L2"},{"id":"e","label":"L2"},{"id":"f","label":"L2"}],"edges":[{"from":"r","to":"a"},{"from":"r","to":"b"},{"from":"a","to":"c"},{"from":"a","to":"d"},{"from":"b","to":"e"},{"from":"b","to":"f"}],"directed":true,"trace":[{"note":"Level 0 (root): 2⁰ = 1 node","current":"r","visited":[],"pointers":{}},{"note":"Level 1: each node has ≤2 children → 2×1 = 2¹ = 2 nodes","current":"a","visited":["r"],"pointers":{}},{"note":"Level 2: each of the 2 nodes has ≤2 children → 2×2 = 2² = 4 nodes","current":"c","visited":["r","a","b"],"pointers":{}}]},"sourceRef":{"chunkId":"chunk_0001"}},{"id":"induction_proof","objectType":"math_derivation","renderHint":"math","region":"notebook_area","lineNumber":3,"content":{"steps":[{"latex":"\\text{Level } l \\text{ has at most } 2^l \\text{ nodes}","note":"Claim (prove by induction)"},{"latex":"l = 0 \\Rightarrow 2^0 = 1 \\text{ node (root)}","note":"Base case ✓"},{"latex":"\\text{If level } l \\text{ has } 2^l \\text{ nodes, then level } l{+}1 \\text{ has at most } 2 \\times 2^l = 2^{l+1}","note":"Inductive step: each node → ≤2 children"},{"latex":"\\therefore \\text{max nodes at level } l = 2^l","note":"By induction ✓"}]},"sourceRef":{"chunkId":"chunk_0001"}},{"id":"concrete_summation","objectType":"geometric_series","renderHint":"math","region":"notebook_area","lineNumber":4,"content":{"steps":[{"latex":"\\text{Height } h = 2 \\text{ (root at level 0)} \\Rightarrow \\text{levels } 0, 1, 2","note":"Concrete example: tree of height 2"},{"latex":"\\text{Total max nodes} = 2^0 + 2^1 + 2^2 = 1 + 2 + 4 = 7","note":"Sum each level's max: 1+2+4=7"},{"latex":"= 2^{2+1} - 1 = 2^3 - 1 = 8 - 1 = 7 \\checkmark","note":"Pattern: 1+2+4 = 2³−1 = 7"},{"latex":"\\text{Generalize: } \\sum_{k=0}^{h} 2^k = \\frac{2^{h+1} - 1}{2 - 1} = 2^{h+1} - 1","note":"Geometric series formula"},{"latex":"\\boxed{\\text{Max nodes in tree of height } h = 2^{h+1} - 1}","note":"Final formula (root height = 0)"}]},"sourceRef":{"chunkId":"chunk_0002"}},{"id":"convention_callout","objectType":"convention_warning","renderHint":"callout","region":"notebook_area","lineNumber":5,"content":{"variant":"mistake","body":["⚠️ Height convention matters!","• Root height = 0, empty tree = −1 → max nodes = 2^(h+1) − 1","• Root height = 1, empty tree = 0 → max nodes = 2^h − 1","Always check which convention your textbook uses!"]},"sourceRef":{"chunkId":"chunk_0002"}}],"voiceLines":[{"id":"v1","text":"Let's start with the title: we're figuring out the maximum number of nodes a binary tree can hold, both level-by-level and overall by height.","targetObjectId":"title_max_nodes"},{"id":"v2","text":"Picture this tree here — notice that level 0, the root, has just 1 node; level 1 has 2 nodes; and level 2 has 4 nodes.","targetObjectId":"tree_diagram"},{"id":"v3","text":"The key insight is that each node can have at most 2 children, so the count doubles every level — that's why level l has at most 2 to the power l nodes.","targetObjectId":"tree_diagram","focusRef":"r"},{"id":"v4","text":"A common mistake is forgetting that the root is level 0, not level 1 — this off-by-one error will mess up every formula downstream.","targetObjectId":"tree_diagram","focusRef":"f"},{"id":"v5","text":"Now let's prove this with induction — the claim is simple: level l has at most 2 to the l nodes.","targetObjectId":"induction_proof","focusRef":1},{"id":"v6","text":"The base case is trivial: at level 0, 2 to the 0 is 1, which is just the root — that checks out.","targetObjectId":"induction_proof","focusRef":2},{"id":"v7","text":"For the inductive step, if level l has 2 to the l nodes, then each one spawns at most 2 children, giving us 2 times 2 to the l, which is 2 to the l plus 1.","targetObjectId":"induction_proof","focusRef":3},{"id":"v8","text":"That completes the induction — now we know the per-level bound is rock solid.","targetObjectId":"induction_proof","focusRef":4},{"id":"v9","text":"To get the total max nodes, we sum across all levels — let's use a concrete example: a tree of height 2 has levels 0, 1, and 2.","targetObjectId":"concrete_summation","focusRef":1},{"id":"v10","text":"Adding them up: 1 plus 2 plus 4 equals 7 — that's the maximum number of nodes you can pack into a height-2 tree.","targetObjectId":"concrete_summation","focusRef":2},{"id":"v11","text":"Notice the pattern: 1 plus 2 plus 4 is also 2 cubed minus 1 — this is a geometric series with ratio 2.","targetObjectId":"concrete_summation","focusRef":3},{"id":"v12","text":"Applying the geometric series formula, the sum from k equals 0 to h of 2 to the k simplifies to 2 to the h plus 1, minus 1.","targetObjectId":"concrete_summation","focusRef":4},{"id":"v13","text":"So our final boxed formula: a binary tree of height h has at most 2 to the h plus 1, minus 1 nodes.","targetObjectId":"concrete_summation","focusRef":5},{"id":"v14","text":"Here's a critical warning — height conventions vary between textbooks, and this trips up students constantly.","targetObjectId":"convention_callout"},{"id":"v15","text":"If the root is height 0 and an empty tree is height negative 1, the formula is 2 to the h plus 1, minus 1 — that's what we just derived.","targetObjectId":"convention_callout"},{"id":"v16","text":"But some books say the root is height 1 and an empty tree is height 0 — then the formula becomes 2 to the h, minus 1 instead.","targetObjectId":"convention_callout"},{"id":"v17","text":"Always check which convention your textbook or interviewer uses before you plug numbers in — the math is the same, but the variable h shifts.","targetObjectId":"convention_callout"}],"timeline":{"sceneId":"sc_02","timingSource":"provisional","actions":[{"id":"act_point_title_max_nodes","kind":"point","startMs":0,"durationMs":600,"targetObjectId":"title_max_nodes"},{"id":"act_speak_title_max_nodes_0","kind":"speech","startMs":200,"durationMs":9120,"voiceLineId":"v1"},{"id":"act_write_title_max_nodes","kind":"write","startMs":300,"durationMs":8208,"targetObjectId":"title_max_nodes"},{"id":"act_point_tree_diagram","kind":"point","startMs":9620,"durationMs":600,"targetObjectId":"tree_diagram"},{"id":"act_speak_tree_diagram_0","kind":"speech","startMs":9820,"durationMs":9880,"voiceLineId":"v2"},{"id":"act_write_tree_diagram","kind":"write","startMs":9920,"durationMs":28386,"targetObjectId":"tree_diagram"},{"id":"act_speak_tree_diagram_1","kind":"speech","startMs":19700,"durationMs":12540,"voiceLineId":"v3"},{"id":"act_speak_tree_diagram_2","kind":"speech","startMs":32240,"durationMs":9120,"voiceLineId":"v4"},{"id":"act_point_induction_proof","kind":"point","startMs":41660,"durationMs":600,"targetObjectId":"induction_proof"},{"id":"act_speak_induction_proof_0","kind":"speech","startMs":41860,"durationMs":7980,"voiceLineId":"v5"},{"id":"act_write_induction_proof","kind":"write","startMs":41960,"durationMs":32490,"targetObjectId":"induction_proof"},{"id":"act_speak_induction_proof_1","kind":"speech","startMs":49840,"durationMs":8740,"voiceLineId":"v6"},{"id":"act_speak_induction_proof_2","kind":"speech","startMs":58580,"durationMs":14060,"voiceLineId":"v7"},{"id":"act_speak_induction_proof_3","kind":"speech","startMs":72640,"durationMs":5320,"voiceLineId":"v8"},{"id":"act_point_concrete_summation","kind":"point","startMs":78260,"durationMs":600,"targetObjectId":"concrete_summation"},{"id":"act_speak_concrete_summation_0","kind":"speech","startMs":78460,"durationMs":10640,"voiceLineId":"v9"},{"id":"act_write_concrete_summation","kind":"write","startMs":78560,"durationMs":43092,"targetObjectId":"concrete_summation"},{"id":"act_speak_concrete_summation_1","kind":"speech","startMs":89100,"durationMs":9120,"voiceLineId":"v10"},{"id":"act_speak_concrete_summation_2","kind":"speech","startMs":98220,"durationMs":8740,"voiceLineId":"v11"},{"id":"act_speak_concrete_summation_3","kind":"speech","startMs":106960,"durationMs":10640,"voiceLineId":"v12"},{"id":"act_speak_concrete_summation_4","kind":"speech","startMs":117600,"durationMs":8740,"voiceLineId":"v13"},{"id":"act_point_convention_callout","kind":"point","startMs":126640,"durationMs":600,"targetObjectId":"convention_callout"},{"id":"act_speak_convention_callout_0","kind":"speech","startMs":126840,"durationMs":6080,"voiceLineId":"v14"},{"id":"act_write_convention_callout","kind":"write","startMs":126940,"durationMs":34200,"targetObjectId":"convention_callout"},{"id":"act_speak_convention_callout_1","kind":"speech","startMs":132920,"durationMs":11780,"voiceLineId":"v15"},{"id":"act_speak_convention_callout_2","kind":"speech","startMs":144700,"durationMs":10640,"voiceLineId":"v16"},{"id":"act_speak_convention_callout_3","kind":"speech","startMs":155340,"durationMs":9500,"voiceLineId":"v17"}]},"durationMs":165140,"reviewRounds":1}]}