{
  "name": "ai-live-tutor-rebuild-server",
  "version": "1.0.0",
  "description": "AI Live Tutor Rebuild Server - Agent 1 PDF/Text to Mermaid/Table Visual Agent",
  "main": "server.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "check": "node -c app.js && node -c server.js",
    "test": "jest --config ../tests/server/jest.config.js --rootDir ../tests/server",
    "test:unit": "jest --config ../tests/server/jest.config.js --testPathPattern=unit",
    "test:integration": "jest --config ../tests/server/jest.config.js --testPathPattern=integration"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "testTimeout": 15000,
    "clearMocks": true,
    "restoreMocks": true
  },
  "dependencies": {
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  }
}
