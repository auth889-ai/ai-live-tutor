    pageImageUse: "visual_preview_layout_diagram_shape_only",
    ocrIsHelperOnly: true,
    garbledOcrDetected: Boolean(meta.garbledOcrDetected || visualMeta.garbledOcrDetected),

    pageImagesIncluded: pageImages.length > 0,
    pageImageCount: Number(meta.pageImageCount || visualMeta.pageImageCount || pageImages.length || 0),
    visualContextPageImageCount: Number(
      meta.visualContextPageImageCount || safeArray(visualContext.pageImages).length || 0
    ),
    richSourcePackPageImageCount: Number(meta.richSourcePackPageImageCount || visualMeta.richSourcePackPageImageCount || 0),
    geminiVisionPageImagesAvailable: Boolean(
      meta.geminiVisionPageImagesAvailable ||
        visualMeta.geminiVisionPageImagesAvailable ||
