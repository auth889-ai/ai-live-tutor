/**
 * Pulls selected_page_vision_agent.py proof from multiple possible places.
 * This is important because different orchestrator versions may put agent output in:
 * - result.selectedPageVision
 * - result.visualContext.selectedPageVision
 * - result.metadata.selectedPageVision
 * - stage2Response.metadata.selectedPageVision
 * - result.agentOutputs.SelectedPageVisionAgent
 */
function collectSelectedPageVisionProof(stage2Response, sourceContext = {}) {
  const root = safeObject(stage2Response);
  const result = extractStage2Result(root);

  const candidates = [
    result.selectedPageVision,
    safeObject(result.visualContext).selectedPageVision,
    safeObject(result.metadata).selectedPageVision,
    safeObject(root.metadata).selectedPageVision,
    safeObject(result.agentOutputs).SelectedPageVisionAgent,
    safeObject(result.agents).SelectedPageVisionAgent,
    safeObject(result.sourceVision).selectedPageVision,
    safeObject(sourceContext).selectedPageVision,
    safeObject(sourceContext.visualContext).selectedPageVision,
  ]
    .map(safeObject)
    .filter((x) => Object.keys(x).length);

  const merged = {};
  for (const candidate of candidates) {
    Object.assign(merged, candidate);
  }

  const metaCandidates = [
    safeObject(merged.metadata),
    safeObject(result.metadata),
    safeObject(root.metadata),
    safeObject(safeObject(result.visualContext).metadata),
    safeObject(safeObject(sourceContext.visualContext).metadata),
  ];

  const meta = {};
  for (const item of metaCandidates) Object.assign(meta, item);

  const pageImageAnalyses = firstArray(
    merged.pageImageAnalyses,
    result.pageImageAnalyses,
    safeObject(result.visualContext).pageImageAnalyses,
    safeObject(sourceContext.visualContext).pageImageAnalyses
  );

  const detectedDiagrams = firstArray(
    merged.detectedDiagrams,
    result.detectedDiagramsFromVision,
    safeObject(result.visualContext).detectedDiagramsFromVision
  );

  const diagramSummary = cleanText(
    merged.diagramSummary ||
      result.diagramSummaryFromVision ||
      safeObject(result.visualContext).diagramSummary ||
      meta.diagramSummary ||
      "",
    8000
  );

  const selectedPageVisionUsed = Boolean(
    merged.selectedPageVisionUsed ||
      meta.selectedPageVisionUsed ||
      pageImageAnalyses.length ||
      diagramSummary
  );

  return {
    selectedPageVision: merged,
    selectedPageVisionAgentConnected: selectedPageVisionUsed || Boolean(meta.selectedPageVisionUsed),
    selectedPageVisionUsed,
    imageBytesLoaded: Boolean(meta.imageBytesLoaded),
    imageBytesLength: Number(meta.imageBytesLength || 0),
    resolvedLocalPathExists: Boolean(meta.resolvedLocalPathExists),
    geminiVisionCalled: Boolean(meta.geminiVisionCalled),
    geminiVisionCallCount: Number(meta.geminiVisionCallCount || 0),
    modelVisionUsed: Boolean(meta.modelVisionUsed),
    visionModel: cleanText(meta.visionModel || "", 160),
    pageImageAnalysisCount: Number(meta.pageImageAnalysisCount || pageImageAnalyses.length || 0),
    detectedDiagramCount: Number(meta.detectedDiagramCount || detectedDiagrams.length || 0),
    diagramSummary,
    fallbackUsed: false,
    usedSmartFallback: false,
  };
}

function estimateJsonBytes(value) {
  try {
    return Buffer.byteLength(JSON.stringify(value || null), "utf8");
  } catch {
    return 0;
  }
}

function chunkItemsByBytes(items = [], maxBytes = 650000) {
  const chunks = [];
  let current = [];
  let currentBytes = 2;

  for (const item of safeArray(items)) {
    const size = Math.max(2, estimateJsonBytes(item));

    if (current.length && currentBytes + size > maxBytes) {
      chunks.push(current);
      current = [];
      currentBytes = 2;
    }

    current.push(item);
    currentBytes += size;
  }

  if (current.length) chunks.push(current);
  return chunks;
}

async function replaceStage2Artifacts({ ownerKey, sessionId, resourceId, treeId, boardId, artifacts }) {
  await GoogleLiveTutorStage2Artifact.deleteMany({ ownerKey, sessionId });

  const docs = [];

  for (const [type, itemsOrPayload] of Object.entries(safeObject(artifacts))) {
    if (Array.isArray(itemsOrPayload)) {
      const chunks = chunkItemsByBytes(itemsOrPayload, 650000);

      chunks.forEach((chunk, chunkIndex) => {
        docs.push({
          ownerKey,
          sessionId,
          resourceId,
          treeId,
          boardId,
          type,
          chunkIndex,
          itemCount: chunk.length,
          byteSize: estimateJsonBytes(chunk),
          items: chunk,
          payload: null,
          metadata: {
            fallbackUsed: false,
            usedSmartFallback: false,
          },
        });
      });

      if (!chunks.length) {
        docs.push({
          ownerKey,
          sessionId,
          resourceId,
          treeId,
          boardId,
          type,
          chunkIndex: 0,
          itemCount: 0,
          byteSize: 2,
          items: [],
          payload: null,
          metadata: {
            fallbackUsed: false,
            usedSmartFallback: false,
          },
        });
      }
    } else if (itemsOrPayload !== undefined && itemsOrPayload !== null) {
      docs.push({
        ownerKey,
        sessionId,
        resourceId,
        treeId,
        boardId,
        type,
        chunkIndex: 0,
        itemCount: 1,
        byteSize: estimateJsonBytes(itemsOrPayload),
        items: [],
        payload: itemsOrPayload,
        metadata: {
          fallbackUsed: false,
          usedSmartFallback: false,
        },
      });
    }
  }

  if (!docs.length) return 0;

  await GoogleLiveTutorStage2Artifact.insertMany(docs, { ordered: false });
  return docs.length;
}

async function loadStage2Artifacts({ ownerKey, sessionId }) {
  const docs = await GoogleLiveTutorStage2Artifact.find({ ownerKey, sessionId })
    .sort({ type: 1, chunkIndex: 1 })
    .lean();

  const out = {};

  for (const doc of docs) {
    const type = doc.type;

    if (safeArray(doc.items).length || doc.itemCount === 0) {
      if (!Array.isArray(out[type])) out[type] = [];
      out[type].push(...safeArray(doc.items));
    } else if (doc.payload !== undefined && doc.payload !== null) {
      out[type] = doc.payload;
    }
  }

  return out;
}

function hasFallbackTrue(value, depth = 0) {
  if (!value || depth > 12) return false;
  if (Array.isArray(value)) return value.some((x) => hasFallbackTrue(x, depth + 1));
  if (typeof value !== "object") return false;

  if (
    value.fallbackUsed === true ||
    value.fakeFallbackUsed === true ||
    value.usedSmartFallback === true
  ) {
    return true;
  }

  return Object.values(value).some((x) => hasFallbackTrue(x, depth + 1));
}

function ensureValidStage2Result(stage2Response, fallbackChunks = [], sourceContext = {}) {
  if (hasFallbackTrue(stage2Response)) {
    const error = new Error("Stage2 rejected: fallbackUsed=true / usedSmartFallback=true is not allowed.");
    error.statusCode = 502;
    throw error;
  }

  const result = extractStage2Result(stage2Response);

  const boardCommands = collectBoardCommands(result);
  const voiceScript = collectVoiceScript(result);
  const subtitles = collectSubtitles(result);
  const boardSections = collectBoardSections(result);
  const premiumBoardScreens = collectPremiumBoardScreens(result);
  const compiledDiagrams = collectCompiledDiagrams(result);
  const sourceRefs = collectSourceRefs(result, fallbackChunks, sourceContext);

  const errors = [];

  if (!boardCommands.length) errors.push("boardCommands is empty");
  if (!voiceScript.length) errors.push("voiceScript is empty");
  if (!subtitles.length) errors.push("subtitles is empty");
  if (!sourceRefs.length) errors.push("sourceRefs is empty");

  if (!safeArray(sourceContext.selectedEvidence || sourceContext.exactChunks || sourceContext.selectedNodeExactChunks).length) {
    errors.push("selectedEvidence is empty");
  }

  if (errors.length) {
    const error = new Error(`Stage2 output is weak/incomplete: ${errors.join(", ")}`);
    error.statusCode = 502;
    error.errors = errors;
    error.resultPreview = {
      boardCommands: boardCommands.length,
      voiceScript: voiceScript.length,
      subtitles: subtitles.length,
      boardSections: boardSections.length,
      premiumBoardScreens: premiumBoardScreens.length,
      compiledDiagrams: compiledDiagrams.length,
      sourceRefs: sourceRefs.length,
    };
    throw error;
  }

  return true;
}

