async function interruptAndRepair(input = {}) {
  await ensureMongo();

  const body = safeObject(input.body || input);

  const owner = normalizeOwnerContext({
    ownerKey: input.ownerKey || body.ownerKey || input.context?.ownerKey,
    offlineUserId: body.offlineUserId || input.context?.offlineUserId || input.ownerKey,
    deviceId: body.deviceId || input.context?.deviceId,
  });

  const sessionId = inlineText(body.sessionId || input.sessionId, 260);

  if (!sessionId) {
    const error = new Error("sessionId is required for interrupt repair.");
    error.statusCode = 400;
    throw error;
  }

  const replay = await getStage2Session({
    ...body,
    ownerKey: owner.ownerKey,
    sessionId,
  });

  const repairPayload = {
    mode: "interrupt_repair",
    sessionId,
    owner,
    question: cleanText(
      body.question || body.interruptText || body.message || "Student interrupted the lesson.",
      2200
    ),
    currentTime: Number(body.currentTime || 0),
    currentCommandIndex: Number(body.currentCommandIndex || 0),
    visibleCommandIds: safeArray(body.visibleCommandIds),
    visibleBlockIds: safeArray(body.visibleBlockIds),
    selectedNode: replay.session?.selectedNode,
    sourceRefs: replay.session?.sourceRefs,
    boardCommands: replay.boardCommands,
    voiceScript: replay.voiceScript,
    subtitles: replay.subtitles,
    selectedPageVision: replay.selectedPageVision,
    timeoutPolicy: getTimeoutPolicy(body),
    strictNoFallback: true,
    requireNoFallback: true,
    metadata: {
      fallbackUsed: false,
      usedSmartFallback: false,
    },
  };

  const repair = await runStage2Pipeline(repairPayload);
  const result = extractStage2Result(repair);

  const newCommands = collectBoardCommands(result);
  const newVoiceScript = collectVoiceScript(result);
  const newSubtitles = collectSubtitles(result);

  if (!newCommands.length || !newVoiceScript.length) {
    const error = new Error("Interrupt repair returned weak output: commands/voiceScript missing.");
    error.statusCode = 502;
    throw error;
  }

  const interruptId = makeId("interrupt");

  await GoogleLiveTutorStage2Session.findOneAndUpdate(
    { ownerKey: owner.ownerKey, sessionId },
    {
      $push: {
        interrupts: {
          interruptId,
          question: repairPayload.question,
          currentCommandIndex: repairPayload.currentCommandIndex,
          createdAt: new Date(),
          metadata: {
            fallbackUsed: false,
            usedSmartFallback: false,
          },
        },
      },
      $set: {
        "playbackState.paused": false,
        "playbackState.lastInterruptId": interruptId,
        status: "repaired",
      },
    }
  );

  return {
    ok: true,
    sessionId,
    interruptId,
    boardCommands: newCommands,
    voiceScript: newVoiceScript,
    subtitles: newSubtitles,
    repairOptions: safeArray(result.repairOptions),
    metadata: {
      fallbackUsed: false,
      usedSmartFallback: false,
    },
  };
}

