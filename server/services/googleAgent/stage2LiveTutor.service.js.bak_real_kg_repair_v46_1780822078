  return {
    contextBuilderVersion: meta.contextBuilderVersion || meta.version || "unknown",
    sourceContextBuilderMethod: meta.sourceContextBuilderMethod || "",
    parallelContextBuilt: Boolean(meta.parallelContextBuilt),
    contextBudgets: safeObject(meta.contextBudgets),
    contextTimingMs: safeObject(meta.contextTimingMs),

    selectedEvidenceSeparated: true,
    relatedEvidenceSeparated: true,
    comparisonEvidenceSeparated: true,

    selectedEvidenceCount: Number(
      meta.selectedEvidenceCount ||
        safeArray(sourceContext.selectedEvidence || sourceContext.exactChunks || sourceContext.selectedNodeExactChunks).length
    ),
    samePageEvidenceCount: Number(
      meta.samePageEvidenceCount ||
        safeArray(sourceContext.samePageEvidence || sourceContext.samePageChunks).length
    ),
    nearbyEvidenceCount: Number(
      meta.nearbyEvidenceCount ||
        safeArray(sourceContext.nearbyEvidence || sourceContext.nearbyChunks).length
    ),
    relatedEvidenceCount: Number(
      meta.relatedEvidenceCount ||
        meta.relatedChunkCount ||
        safeArray(sourceContext.relatedEvidence || sourceContext.relatedChunks).length
    ),
    comparisonEvidenceCount: Number(
      meta.comparisonEvidenceCount || safeArray(sourceContext.comparisonEvidence).length
    ),

    selectedPageFullTextIncluded: Boolean(selectedPageFullText),
    selectedPageFullTextChars: selectedPageFullText.length,
    selectedFullPageCount: Number(meta.selectedPageCount || meta.selectedFullPageCount || 0),

    fullPdfKnown: true,
    fullPdfSummaryIncluded: Boolean(
      sourceContext.fullPdfSummary?.fullPdfSummary ||
        sourceContext.fullPdfSummary?.summary ||
        sourceContext.fullPdfSummary
    ),
    fullPdfOutlineIncluded: Boolean(
      sourceContext.fullPdfOutline?.modules?.length ||
