  )
    .map(safeObject)
    .filter((item) => Object.keys(item).length);
}

function collectCompiledDiagrams(result) {
  const r = safeObject(result);

  return firstArray(
    r.compiledDiagrams,
    r.diagrams,
    safeObject(r.diagramArtifacts).compiledDiagrams,
    safeObject(r.visualPlan).compiledDiagrams
  )
    .map(safeObject)
    .filter((item) => Object.keys(item).length);
}

function normalizeSourceRef(ref) {
  const r = safeObject(ref);

  return {
    chunkId: inlineText(r.chunkId || r.id || "", 260),
    sourceRef: inlineText(r.sourceRef || r.ref || "", 420),
    pageRef: inlineText(r.pageRef || "", 420),
    page: Number(r.page || r.pageNo || r.pageNumber || 0) || 0,
    quote: cleanText(r.quote || r.text || r.snippet || "", 1400),
    confidence: Number.isFinite(Number(r.confidence)) ? Number(r.confidence) : 0.75,
    resourceId: inlineText(r.resourceId || "", 260),
    evidenceRole: inlineText(r.evidenceRole || r.role || "", 100),
    metadata: safeObject(r.metadata),
  };
}

function collectSourceRefs(result, fallbackChunks = [], sourceContext = {}) {
  const r = safeObject(result);

  const refs = [
    ...safeArray(r.sourceRefs),
    ...safeArray(r.sources),
    ...safeArray(sourceContext.sourceRefs),
    ...safeArray(sourceContext.selectedSourceRefs),
    ...safeArray(fallbackChunks)
      .map((chunk) => (safeObject(chunk).sourceRef ? chunk : null))
      .filter(Boolean),
  ];

  return dedupeBy(
    refs.map(normalizeSourceRef),
    (ref) => `${ref.chunkId}|${ref.sourceRef}|${ref.page}|${ref.quote.slice(0, 60)}`
  )
    .filter((ref) => ref.chunkId || ref.sourceRef || ref.page || ref.quote)
    .slice(0, 160);
}

function sourceRefsFromEvidence(items, role) {
  return safeArray(items)
    .map((item) => {
      const obj = safeObject(item);
      return normalizeSourceRef({
        ...obj,
        evidenceRole: role || obj.evidenceRole,
        quote: obj.quote || obj.textPreview || obj.text || obj.ocrText || "",
      });
    })
    .filter((ref) => ref.chunkId || ref.sourceRef || ref.page || ref.quote)
    .slice(0, 100);
}

function collectSourceCards(result, fallbackChunks = [], sourceContext = {}) {
  const r = safeObject(result);
  const cards = firstArray(r.sourceCards, r.evidenceCards, safeObject(r.visualPlan).sourceCards);

  if (cards.length) {
    return cards.map(safeObject).filter((x) => Object.keys(x).length);
  }

  return safeArray(fallbackChunks).slice(0, 10).map((chunk, index) => {
    const c = safeObject(chunk);
    return {
      id: `source_card_${index + 1}`,
      title: c.heading || c.title || `Source p.${c.page || "?"}`,
      page: Number(c.page || 0),
      quote: cleanText(c.textPreview || c.text || c.quote || "", 1200),
      sourceRefs: [normalizeSourceRef(c)],
      role: c.evidenceRole || "selectedEvidence",
      sourceTruth: "pdf_extracted_text_chunk",
    };
  });
}

function collectDiagramArtifacts(result) {
  const r = safeObject(result);
  const artifacts = safeObject(r.diagramArtifacts || r.diagramsByType);

  return {
    ...artifacts,
    mermaid: firstArray(artifacts.mermaid, r.mermaidDiagrams, r.mermaid).map(safeObject),
    reactFlow: firstArray(artifacts.reactFlow, r.reactFlowDiagrams, r.reactFlow).map(safeObject),
    html: firstArray(artifacts.html, r.htmlDiagrams).map(safeObject),
