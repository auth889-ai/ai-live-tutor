async function runPythonStage2Direct(payload) {
  const python = getPythonBinary();
  const script = getStage2Script();
  const timeoutPolicy = getTimeoutPolicy(payload);
  const timeoutMs = timeoutPolicy.totalMs;

  if (!fs.existsSync(script)) {
    const error = new Error(`Python Stage2 script not found: ${script}`);
    error.statusCode = 500;
    error.code = "STAGE2_PYTHON_SCRIPT_MISSING";
    throw error;
  }

  const finalPayload = {
    ...safeObject(payload),
    timeoutMs,
    stage2TimeoutMs: timeoutMs,
    timeoutPolicy,
    stage2ContextTimeoutMs: timeoutPolicy.contextMs,
    stage2AgentTimeoutMs: timeoutPolicy.agentMs,
    stage2ExternalTimeoutMs: timeoutPolicy.externalMs,
    stage2TtsTimeoutMs: timeoutPolicy.ttsMs,
    metadata: {
      ...safeObject(payload.metadata),
      timeoutPolicy,
      fallbackUsed: false,
      usedSmartFallback: false,
    },
  };

  return new Promise((resolve, reject) => {
    const child = spawn(python, [script, "--mode", finalPayload.mode || "teach_node_pipeline"], {
      cwd: process.cwd(),
      env: {
        ...process.env,
        PYTHONUNBUFFERED: "1",
        STAGE2_TOTAL_TIMEOUT_MS: String(timeoutPolicy.totalMs),
        GOOGLE_STAGE2_LIVE_TUTOR_TIMEOUT_MS: String(timeoutPolicy.totalMs),
        STAGE2_LIVE_TUTOR_TIMEOUT_MS: String(timeoutPolicy.totalMs),
        STAGE2_CONTEXT_TIMEOUT_MS: String(timeoutPolicy.contextMs),
        STAGE2_AGENT_TIMEOUT_MS: String(timeoutPolicy.agentMs),
        STAGE2_EXTERNAL_TIMEOUT_MS: String(timeoutPolicy.externalMs),
        STAGE2_TTS_TIMEOUT_MS: String(timeoutPolicy.ttsMs),
      },
      stdio: ["pipe", "pipe", "pipe"],
    });

    let stdout = "";
    let stderr = "";
    let settled = false;
    const startedAt = Date.now();

    const timer = setTimeout(() => {
      if (settled) return;

      settled = true;

      try {
        child.kill("SIGKILL");
      } catch {
        // ignore
      }

      const error = new Error(`Python Stage2 timed out after ${timeoutMs}ms. Script=${script}`);
      error.statusCode = 504;
      error.code = "STAGE2_PYTHON_TIMEOUT";
      error.stderr = stderr.slice(-5000);
      error.stdout = stdout.slice(-5000);
      error.timeoutPolicy = timeoutPolicy;
      error.runtimeMs = Date.now() - startedAt;
      reject(error);
    }, timeoutMs);

    child.stdout.on("data", (chunk) => {
      stdout += chunk.toString();
    });

    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString();
    });

    child.on("error", (error) => {
      if (settled) return;

      settled = true;
      clearTimeout(timer);
      error.message = `Failed to start Python Stage2. python=${python} script=${script}. ${error.message}`;
      error.statusCode = 500;
      reject(error);
    });

    child.on("close", (code, signal) => {
      if (settled) return;

      settled = true;
      clearTimeout(timer);

      const runtimeMs = Date.now() - startedAt;

      if (code !== 0) {
        const error = new Error(
          `Python Stage2 exited with code ${code}, signal=${signal || ""}. ${stderr.slice(-1500)}`
        );
        error.statusCode = 502;
        error.code = "STAGE2_PYTHON_EXIT_NONZERO";
        error.stderr = stderr;
        error.stdout = stdout;
        error.timeoutPolicy = timeoutPolicy;
        error.runtimeMs = runtimeMs;
        reject(error);
        return;
      }

      try {
        const parsed = parseJsonFromText(stdout);
        resolve({
          ...safeObject(parsed),
          metadata: {
            ...safeObject(parsed.metadata),
            timeoutPolicy,
            runtimeMs,
            directPythonUsed: true,
            fallbackUsed: false,
            usedSmartFallback: false,
          },
        });
      } catch (error) {
        error.statusCode = 502;
        error.stderr = stderr;
        error.stdout = stdout;
        error.timeoutPolicy = timeoutPolicy;
        error.runtimeMs = runtimeMs;
        reject(error);
      }
    });

    child.stdin.write(JSON.stringify(finalPayload));
    child.stdin.end();
  });
}

function unwrapBridge(mod) {
  const candidates = [];

  if (mod) candidates.push(mod);
  if (mod?.default) candidates.push(mod.default);
  if (mod?.stage2Bridge) candidates.push(mod.stage2Bridge);
  if (mod?.service) candidates.push(mod.service);
  if (mod?.bridge) candidates.push(mod.bridge);

  return candidates;
}

async function runStage2Pipeline(payload) {
  const finalPayload = {
    ...safeObject(payload),
    timeoutPolicy: getTimeoutPolicy(payload),
  };

  finalPayload.timeoutMs = finalPayload.timeoutPolicy.totalMs;
  finalPayload.stage2TimeoutMs = finalPayload.timeoutPolicy.totalMs;

  const candidates = unwrapBridge(stage2Bridge);
  const methodNames = [
    "runStage2PythonAdk",
    "teachSelectedNode",
    "runStage2LiveTutor",
    "run",
    "teachNode",
    "teach",
    "invoke",
    "call",
    "execute",
    "start",
  ];

  for (const candidate of candidates) {
    if (typeof candidate === "function") return candidate(finalPayload);

    for (const name of methodNames) {
      if (candidate && typeof candidate[name] === "function") {
        return candidate[name](finalPayload);
      }
    }
  }

  if (envTrue(["STAGE2_ALLOW_DIRECT_PYTHON", "LIVE_TUTOR_ALLOW_DIRECT_PYTHON"], true)) {
    return runPythonStage2Direct(finalPayload);
  }

  const error = new Error("No runnable Stage 2 bridge found and direct Python disabled.");
  error.statusCode = 500;
  throw error;
}

