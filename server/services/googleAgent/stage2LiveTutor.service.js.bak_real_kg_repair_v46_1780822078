function collectLessonTranscript(result, voiceScript = []) {
  const r = safeObject(result);
  const explicit = cleanText(r.lessonTranscript || r.transcript || r.teacherTranscript || "", 40000);

  if (explicit) return explicit;

  return cleanText(
    safeArray(voiceScript)
      .map((line) => safeObject(line).text)
      .filter(Boolean)
      .join("\n"),
    40000
  );
