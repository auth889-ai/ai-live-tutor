    ),

    ocrBlockCount: Number(meta.ocrBlockCount || visualMeta.ocrBlockCount || safeArray(sourceContext.ocrBlocks).length || 0),
    tableCount: Number(meta.tableCount || visualMeta.tableCount || safeArray(sourceContext.tables || visualContext.tables).length || 0),
    figureCount: Number(meta.figureCount || visualMeta.figureCount || safeArray(sourceContext.figures || visualContext.figures).length || 0),
    layoutBlockCount: Number(
      meta.layoutBlockCount || visualMeta.layoutBlockCount || safeArray(sourceContext.layoutBlocks || visualContext.layoutBlocks).length || 0
    ),

    mongo16mbSafe: true,
    artifactCount,
    fallbackUsed: false,
    usedSmartFallback: false,
  };
}

function normalizeLessonResponse({
  stage2Response,
  sourceContext,
  sessionId,
  owner,
  resourceId,
  treeId,
  boardId,
  selectedNode,
  timeoutPolicy,
}) {
  const result = extractStage2Result(stage2Response);

  const boardCommands = collectBoardCommands(result);
  const voiceScript = collectVoiceScript(result);
  const subtitles = collectSubtitles(result);
  const boardSections = collectBoardSections(result);
  const premiumBoardScreens = collectPremiumBoardScreens(result);
  const compiledDiagrams = collectCompiledDiagrams(result);
  const diagramArtifacts = collectDiagramArtifacts(result);
  const htmlPreviews = collectHtmlPreviews(result);
  const imagePreviews = collectImagePreviews(result, sourceContext);
  const sourceRefs = collectSourceRefs(
    result,
    safeArray(sourceContext.selectedEvidence || sourceContext.exactChunks || sourceContext.selectedNodeExactChunks),
    sourceContext
  );
  const sourceCards = collectSourceCards(
    result,
    safeArray(sourceContext.selectedEvidence || sourceContext.exactChunks || sourceContext.selectedNodeExactChunks),
    sourceContext
  );
  const quiz = collectQuiz(result);
  const lessonTranscript = collectLessonTranscript(result, voiceScript);
  const agentTrace = collectAgentTrace(stage2Response);
  const visionProof = collectSelectedPageVisionProof(stage2Response, sourceContext);

  const contextProof = mergeContextProof(sourceContext, 0);

  const metadata = {
    ...safeObject(result.metadata),
    ...safeObject(stage2Response.metadata),
    ...contextProof,
    ...visionProof,

    timeoutPolicy,
    engine: "strict-parallel-context-artifact-proof-v17-stage2-vision-fixed",
    stage2Service: "stage2LiveTutor.service.js",

    fallbackUsed: false,
    usedSmartFallback: false,
  };

  return {
    ok: true,
    sessionId,
    owner,
    resourceId,
    treeId,
    boardId,
    selectedNode,

    boardCommands,
    commands: boardCommands,
    voiceScript,
    subtitles,
    boardSections,
    premiumBoardScreens,
    boardScreens: premiumBoardScreens,
    compiledDiagrams,
    diagramArtifacts,
    htmlPreviews,
    imagePreviews,
    sourceRefs,
    sourceCards,
    quiz,
    lessonTranscript,
    agentTrace,

    selectedPageVision: visionProof.selectedPageVision || {},
    externalResources: safeObject(sourceContext.externalResources).externalResources || [],
    visualRules: sourceContext.visualRules,

    metadata,

    result: {
      ...result,
      boardCommands,
      voiceScript,
      subtitles,
      boardSections,
      premiumBoardScreens,
      compiledDiagrams,
      diagramArtifacts,
      htmlPreviews,
      imagePreviews,
      sourceRefs,
      sourceCards,
      quiz,
      lessonTranscript,
      agentTrace,
      selectedPageVision: visionProof.selectedPageVision || {},
      metadata: {
        ...safeObject(result.metadata),
        ...contextProof,
        ...visionProof,
        timeoutPolicy,
        fallbackUsed: false,
        usedSmartFallback: false,
      },
    },
  };
}

