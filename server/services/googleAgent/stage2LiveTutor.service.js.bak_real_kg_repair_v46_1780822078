async function getStage2Session(input = {}) {
  await ensureMongo();

  const body = safeObject(input.body || input);

  const owner = normalizeOwnerContext({
    ownerKey: input.ownerKey || body.ownerKey || input.context?.ownerKey,
    offlineUserId: body.offlineUserId || input.context?.offlineUserId || input.ownerKey,
    deviceId: body.deviceId || input.context?.deviceId,
  });

  const sessionId = inlineText(body.sessionId || input.sessionId, 260);

  if (!sessionId) {
    const error = new Error("sessionId is required.");
    error.statusCode = 400;
    throw error;
  }

  const session = await GoogleLiveTutorStage2Session.findOne({
    ownerKey: owner.ownerKey,
    sessionId,
  }).lean();

  if (!session) {
    const error = new Error(`Stage2 session not found: ${sessionId}`);
    error.statusCode = 404;
    throw error;
  }

  const artifacts = await loadStage2Artifacts({ ownerKey: owner.ownerKey, sessionId });

  return {
    ok: true,
    sessionId,
    session,
    ...artifacts,

    premiumBoardScreens: safeArray(artifacts.premiumBoardScreens || session.premiumBoardScreens),
    boardScreens: safeArray(artifacts.premiumBoardScreens || session.boardScreens),
    boardSections: safeArray(artifacts.boardSections || session.boardSections),
    boardCommands: safeArray(artifacts.boardCommands || session.boardCommands),
    commands: safeArray(artifacts.boardCommands || session.commands),
    voiceScript: safeArray(artifacts.voiceScript || session.voiceScript),
    subtitles: safeArray(artifacts.subtitles || session.subtitles),
    compiledDiagrams: safeArray(artifacts.compiledDiagrams || session.compiledDiagrams),
    diagramArtifacts: safeObject(artifacts.diagramArtifacts),
    htmlPreviews: safeArray(artifacts.htmlPreviews),
    imagePreviews: safeArray(artifacts.imagePreviews),
    sourceCards: safeArray(artifacts.sourceCards),
    externalResources: safeArray(artifacts.externalResources),
    agentTrace: safeArray(artifacts.agentTrace || session.agentTrace),
    lessonTranscript: cleanText(artifacts.lessonTranscript || "", 60000),
    quiz: safeObject(artifacts.quiz || session.quiz),
    selectedPageVision: safeObject(artifacts.selectedPageVision || session.metadata?.selectedPageVision),

    metadata: {
