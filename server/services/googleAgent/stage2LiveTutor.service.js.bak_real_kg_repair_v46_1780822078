function getTimeoutPolicy(body = {}) {
  const b = safeObject(body);
  const incoming = safeObject(b.timeoutPolicy || b.metadata?.timeoutPolicy);

  const totalMs = boundedNumber(
    b.stage2TimeoutMs || b.timeoutMs || incoming.totalMs,
    envNumber(
      [
        "STAGE2_TOTAL_TIMEOUT_MS",
        "GOOGLE_STAGE2_LIVE_TUTOR_TOTAL_TIMEOUT_MS",
        "GOOGLE_STAGE2_LIVE_TUTOR_TIMEOUT_MS",
        "STAGE2_LIVE_TUTOR_TIMEOUT_MS",
        "GOOGLE_LIVE_TUTOR_TIMEOUT_MS",
        "LIVE_TUTOR_AGENT_TIMEOUT_MS",
      ],
      30 * 60 * 1000
    ),
    30 * 1000,
    60 * 60 * 1000
  );

  const contextMs = boundedNumber(
    b.stage2ContextTimeoutMs || incoming.contextMs,
    envNumber(["STAGE2_CONTEXT_TIMEOUT_MS", "GOOGLE_STAGE2_CONTEXT_TIMEOUT_MS"], 60 * 1000),
    5 * 1000,
    totalMs
  );

  const agentMs = boundedNumber(
    b.stage2AgentTimeoutMs || incoming.agentMs,
    envNumber(["STAGE2_AGENT_TIMEOUT_MS", "GOOGLE_STAGE2_AGENT_TIMEOUT_MS"], 180 * 1000),
    10 * 1000,
    totalMs
  );

  const externalMs = boundedNumber(
    b.stage2ExternalTimeoutMs || incoming.externalMs,
    envNumber(["STAGE2_EXTERNAL_TIMEOUT_MS", "GOOGLE_STAGE2_EXTERNAL_TIMEOUT_MS"], 8 * 1000),
    1000,
    Math.min(totalMs, 120 * 1000)
  );

  const ttsMs = boundedNumber(
    b.stage2TtsTimeoutMs || incoming.ttsMs,
    envNumber(["STAGE2_TTS_TIMEOUT_MS", "GOOGLE_STAGE2_TTS_TIMEOUT_MS"], 60 * 1000),
    5 * 1000,
    Math.min(totalMs, 10 * 60 * 1000)
  );

  return {
    contextMs,
    agentMs,
    externalMs,
    ttsMs,
    totalMs,
    source: "stage2-service-timeout-policy-v17-stage2-vision-proof",
  };
}

