}

async function loadTreeAndBoard({ ownerKey, treeId, boardId }) {
  const tree = treeId
    ? await GoogleLiveTutorConceptTree.findOne({ ownerKey, treeId }).lean()
    : null;

  const board = boardId
    ? await GoogleLiveTutorBoard.findOne({ ownerKey, boardId }).lean()
    : treeId
      ? await GoogleLiveTutorBoard.findOne({ ownerKey, treeId }).sort({ updatedAt: -1 }).lean()
      : null;

  return { tree, board };
}

function selectNode({ body, tree }) {
  const bodyNode = safeObject(body.selectedNode || body.node);

  if (bodyNode.nodeId || bodyNode.id || bodyNode.label || bodyNode.title) {
    const id = normalizeNodeId(bodyNode.nodeId || bodyNode.id || bodyNode.label || bodyNode.title, "selected_node");
    return {
      ...bodyNode,
      nodeId: inlineText(bodyNode.nodeId || bodyNode.id || id, 220),
      id: inlineText(bodyNode.id || bodyNode.nodeId || id, 220),
      label: inlineText(bodyNode.label || bodyNode.title || bodyNode.nodeId || bodyNode.id || id, 360),
      title: inlineText(bodyNode.title || bodyNode.label || bodyNode.nodeId || bodyNode.id || id, 360),
      sourceRefs: safeArray(bodyNode.sourceRefs || bodyNode.refs || bodyNode.sources),
    };
  }

  const nodeId = normalizeNodeId(body.nodeId || body.selectedNodeId, "");
  if (!nodeId || !tree) return {};

  const found = safeArray(tree.nodes).find((node) => {
    const n = safeObject(node);
    return normalizeNodeId(n.nodeId || n.id || n.label || n.title, "") === nodeId;
  });

  if (!found) return {};

  return {
    ...found,
    nodeId: inlineText(found.nodeId || found.id || nodeId, 220),
    id: inlineText(found.id || found.nodeId || nodeId, 220),
    label: inlineText(found.label || found.title || found.nodeId || nodeId, 360),
    title: inlineText(found.title || found.label || found.nodeId || nodeId, 360),
    sourceRefs: safeArray(found.sourceRefs || found.refs || found.sources),
  };
}

/**
 * Version-safe sourceContextBuilder adapter.
 * Version 17/earlier files used different names:
 * - buildSelectedNodeSourceContext
 * - buildRichSourceContext
 * - buildSourceContext
 * - buildSelectedNodeContext
 * - buildContextForStage2
 * - buildNodeSourceContext
 *
 * This adapter prevents Stage2 from crashing only because a method was renamed.
 */
function getSourceContextBuildFunction() {
  const candidates = [
    "buildSourceContext",
    "buildSelectedNodeContext",
    "buildContextForStage2",
    "buildNodeSourceContext",
    "buildSelectedNodeSourceContext",
    "buildRichSourceContext",
  ];

  for (const name of candidates) {
    if (sourceContextBuilder && typeof sourceContextBuilder[name] === "function") {
      return {
        name,
        fn: sourceContextBuilder[name].bind(sourceContextBuilder),
      };
    }
  }

  const exported = sourceContextBuilder && typeof sourceContextBuilder === "object"
    ? Object.keys(sourceContextBuilder)
    : [];

  const error = new Error(
    `sourceContextBuilder has no compatible build function. Exported keys: ${exported.join(", ")}`
  );
  error.statusCode = 500;
  error.code = "SOURCE_CONTEXT_BUILDER_METHOD_MISSING";
  throw error;
}

function normalizeSourceRefsCompat(refs) {
  if (sourceContextBuilder && typeof sourceContextBuilder.normalizeSourceRefs === "function") {
    return sourceContextBuilder.normalizeSourceRefs(refs);
  }

  if (
    sourceContextBuilder &&
    sourceContextBuilder._internals &&
    typeof sourceContextBuilder._internals.normalizeSourceRefs === "function"
  ) {
    return sourceContextBuilder._internals.normalizeSourceRefs(refs);
  }

  return dedupeBy(
    safeArray(refs)
      .map((ref) => {
        const r = safeObject(ref);
        return {
          resourceId: inlineText(r.resourceId || r.resource_id || "", 260),
          chunkId: inlineText(r.chunkId || r.chunk_id || r.id || "", 260),
          sourceRef: inlineText(r.sourceRef || r.source_ref || r.ref || "", 420),
          pageRef: inlineText(r.pageRef || r.page_ref || "", 420),
          page: Number(r.page || r.pageNo || r.pageNumber || 0) || 0,
          quote: cleanText(r.quote || r.text || r.snippet || r.textPreview || "", 1400),
          confidence: Number.isFinite(Number(r.confidence)) ? Number(r.confidence) : 0.78,
        };
      })
      .filter((ref) => ref.chunkId || ref.sourceRef || ref.page || ref.quote),
    (ref) => `${ref.chunkId}|${ref.sourceRef}|${ref.page}|${ref.quote.slice(0, 80)}`
  );
}

function externalSearchEnabledCompat() {
  if (sourceContextBuilder && typeof sourceContextBuilder.externalSearchEnabled === "function") {
    return Boolean(sourceContextBuilder.externalSearchEnabled());
  }

  const raw =
    process.env.LIVE_TUTOR_ENABLE_EXTERNAL_RESOURCES ||
    process.env.GOOGLE_LIVE_TUTOR_ENABLE_EXTERNAL_RESOURCES ||
    process.env.STAGE2_ENABLE_EXTERNAL_RESOURCES ||
    "";

  if (!raw) return false;
  return ["1", "true", "yes", "y", "on"].includes(String(raw).trim().toLowerCase());
}

async function buildSourceContextCompat({
  owner,
  resourceId,
  resource,
  selectedNode,
  question,
  body,
  timeoutPolicy,
}) {
  const { name, fn } = getSourceContextBuildFunction();

  const input = {
    ownerKey: owner.ownerKey,
    offlineUserId: owner.offlineUserId,
    deviceId: owner.deviceId,
    resourceId,
    resource,
    selectedNode,
    node: selectedNode,
    question,
    body: {
      ...safeObject(body),
      ownerKey: owner.ownerKey,
      offlineUserId: owner.offlineUserId,
      deviceId: owner.deviceId,
      resourceId,
      selectedNode,
      node: selectedNode,
      question,
      timeoutPolicy,
      stage2ContextTimeoutMs: timeoutPolicy.contextMs,
      stage2ExternalTimeoutMs: timeoutPolicy.externalMs,
      enableExternalResources:
        body.enableExternalResources !== undefined
          ? body.enableExternalResources
          : externalSearchEnabledCompat(),
    },
    context: {
      ownerKey: owner.ownerKey,
      offlineUserId: owner.offlineUserId,
      deviceId: owner.deviceId,
      resourceId,
      resource,
    },
  };

  const result = await fn(input);
  const sourceContext = safeObject(result);

  if (!sourceContext || !Object.keys(sourceContext).length) {
    const error = new Error(`sourceContextBuilder.${name} returned empty context.`);
    error.statusCode = 502;
    error.code = "SOURCE_CONTEXT_EMPTY";
    throw error;
  }

  return {
    ...sourceContext,
    metadata: {
      ...safeObject(sourceContext.metadata),
      sourceContextBuilderMethod: name,
      sourceContextBuilder: "sourceContextBuilder.service.js",
      fallbackUsed: false,
      usedSmartFallback: false,
    },
  };
}

function parseJsonFromText(raw) {
  const text = safeString(raw).trim();
  if (!text) throw new Error("Python Stage2 returned empty output.");

  const candidates = [text];
  const fenced = text.match(/```(?:json)?\s*([\s\S]*?)```/i);
  if (fenced?.[1]) candidates.push(fenced[1].trim());

  const first = text.indexOf("{");
  const last = text.lastIndexOf("}");
  if (first >= 0 && last > first) candidates.push(text.slice(first, last + 1));

  for (const candidate of candidates) {
    try {
      return JSON.parse(
        candidate
          .replace(/^```json/i, "")
          .replace(/```/g, "")
          .replace(/,\s*}/g, "}")
          .replace(/,\s*]/g, "]")
          .trim()
      );
    } catch {
      // try next candidate
    }
  }

  throw new Error(`Could not parse JSON from Python Stage2 output. Preview: ${text.slice(0, 1500)}`);
}

