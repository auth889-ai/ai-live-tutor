function collectImagePreviews(result, sourceContext = {}) {
  const r = safeObject(result);
  const direct = firstArray(r.imagePreviews, safeObject(r.visualPlan).imagePreviews);

  const pageImages = safeArray(sourceContext.pageImages || sourceContext.visualContext?.pageImages).slice(0, 8);

  return dedupeBy(
    [...direct, ...pageImages].map(safeObject),
    (item) => `${item.id || ""}|${item.url || item.src || ""}|${item.path || ""}|${item.page || ""}`
  )
    .filter((item) => Object.keys(item).length)
    .map((item) => ({
      ...item,
      imageTextIsTruth: false,
