function normalizeNodeId(value, fallback = "") {
  const normalized = inlineText(value || fallback, 220)
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "_")
    .replace(/^_+|_+$/g, "");
  return normalized || fallback;
}

