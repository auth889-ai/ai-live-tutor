def _entry_priority(entry: JsonDict, selected_pages: List[int]) -> float:
    role = _text(entry.get("role"), 120)
    page = int(entry.get("page") or 0)

    score = 0.0

    if role == "selectedPageFullText":
        score += 10.0
    if role == "selectedEvidence":
        score += 9.0
    if role == "chunk":
        score += 7.0
    if role == "samePageEvidence":
        score += 6.0
    if role == "nearbyEvidence":
        score += 3.0
    if role == "comparisonEvidence":
        score += 1.0

    if page in set(selected_pages):
        score += 8.0
    elif selected_pages and any(abs(page - p) <= 1 for p in selected_pages):
        score += 3.0

    return score


def _facts_from_entry(entry: JsonDict, query: str, selected_pages: List[int]) -> List[Tuple[float, str, JsonDict]]:
    text = _clean_source_text(entry.get("text"), 120000)
    facts = _atomic_facts_from_text(text)
    priority = _entry_priority(entry, selected_pages)

    out: List[Tuple[float, str, JsonDict]] = []

    for fact in facts:
        score = _score_fact(query, fact, role_bonus=priority)
        out.append((score, fact, entry))

    return out


def _evidence_role_for_entry(entry: JsonDict, selected_pages: List[int]) -> str:
    role = _text(entry.get("role"), 120)
    page = int(entry.get("page") or 0)

    if role in {"selectedPageFullText", "selectedEvidence", "chunk"} and (
        not selected_pages or page in set(selected_pages)
    ):
        return "selectedEvidence"

    if role == "samePageEvidence" or page in set(selected_pages):
        return "samePageEvidence"

    if role == "nearbyEvidence" or (selected_pages and any(abs(page - p) <= 1 for p in selected_pages)):
        return "nearbyEvidence"

    if role == "comparisonEvidence":
        return "comparisonEvidence"

    return "relatedEvidence"


def _make_evidence_item(
    *,
    fact: str,
    entry: JsonDict,
    role: str,
    score: float,
    index: int,
) -> JsonDict:
    page = int(entry.get("page") or 0)
    resource_id = _text(entry.get("resourceId"), 260)
    chunk_id = _text(entry.get("chunkId") or f"{role}_{page}_{index}", 260)
    page_ref = _text(entry.get("pageRef"), 420)
    source_ref = _text(entry.get("sourceRef"), 420)

    if not page_ref and resource_id and page:
        page_ref = f"resource:{resource_id}:page:{page}"

    if not source_ref and page_ref:
        source_ref = f"{page_ref}:fact:{index}"

    quote = _remove_urls(fact, 900)
    text = _clean_source_text(entry.get("text"), 26000)
    metadata = _safe_dict(entry.get("metadata"))

    ref = _source_ref(
        resource_id=resource_id,
        chunk_id=chunk_id,
        source_ref=source_ref,
        page_ref=page_ref,
        page=page,
        quote=quote,
        confidence=min(0.98, max(0.45, score / 28.0)),
        role=role,
    )

    return {
        "resourceId": resource_id,
        "chunkId": chunk_id,
        "sourceRef": source_ref,
        "pageRef": page_ref,
        "page": page,
        "heading": _text(entry.get("heading"), 260),
        "title": _text(entry.get("title"), 260),
        "text": text,
        "textPreview": _text(text, 1600),
        "quote": quote,
        "score": round(float(score or 0.0), 4),
        "sourceRefs": [ref] if quote else [],
        "evidenceRole": role,
        "contentFlags": _content_flags(text, metadata),
        "diagramHints": _diagram_hints(text),
        "figures": _safe_list(entry.get("figures")),
        "tables": _safe_list(entry.get("tables")),
        "layoutBlocks": _safe_list(entry.get("layoutBlocks")),
        "metadata": {
            **metadata,
            "agent": "RagRetrievalAgent",
            "evidenceRole": role,
            "cleanDynamicRagV10": True,
            "diverseTeachingFactsV10": True,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


def _dedupe_facts(scored_facts: List[Tuple[float, str, JsonDict]]) -> List[Tuple[float, str, JsonDict]]:
    scored_facts = sorted(scored_facts, key=lambda x: x[0], reverse=True)

    out: List[Tuple[float, str, JsonDict]] = []
    seen = set()

    for score, fact, entry in scored_facts:
        if not _is_good_fact(fact):
            continue

        key = _fact_key(fact)
        if not key or key in seen:
            continue

        seen.add(key)
        out.append((score, fact, entry))

    return out


def _group_evidence(
    query: str,
    entries: List[JsonDict],
    selected_pages: List[int],
) -> Tuple[List[JsonDict], List[JsonDict], List[JsonDict], List[JsonDict], List[JsonDict]]:
    scored: List[Tuple[float, str, JsonDict]] = []

    for entry in entries:
        scored.extend(_facts_from_entry(entry, query, selected_pages))

    diverse = _dedupe_facts(scored)

    groups: Dict[str, List[JsonDict]] = defaultdict(list)

    for index, (score, fact, entry) in enumerate(diverse):
        role = _evidence_role_for_entry(entry, selected_pages)

        item = _make_evidence_item(
            fact=fact,
            entry=entry,
            role=role,
            score=score,
            index=index + 1,
        )

        groups[role].append(item)

    selected = groups["selectedEvidence"][:14]
    same = groups["samePageEvidence"][:10]
    nearby = groups["nearbyEvidence"][:12]
    related = groups["relatedEvidence"][:8]
    comparison = groups["comparisonEvidence"][:8]

    # If selected page facts were all labeled selectedEvidence, add a few as samePage support too.
    if not same and len(selected) > 2:
        same = [
            {
                **_safe_dict(x),
                "evidenceRole": "samePageEvidence",
                "metadata": {
                    **_safe_dict(_safe_dict(x).get("metadata")),
                    "derivedSamePageSupport": True,
                },
            }
            for x in selected[1:4]
        ]

    return selected, same, nearby, related, comparison


def _refs_from_groups(groups: Iterable[List[JsonDict]]) -> List[JsonDict]:
    refs: List[JsonDict] = []

    for group in groups:
        for item in group:
            item = _safe_dict(item)
            for ref in _safe_list(item.get("sourceRefs")):
                r = _safe_dict(ref)
                quote = _remove_urls(r.get("quote"), 900)
                if quote:
                    r["quote"] = quote
                    refs.append(r)

    return dedupe_source_refs(refs)


def _build_page_contexts(entries: List[JsonDict], groups: Iterable[List[JsonDict]]) -> List[JsonDict]:
    by_page: Dict[int, List[JsonDict]] = defaultdict(list)

    for entry in entries:
        page = int(entry.get("page") or 0)
        if page > 0:
            by_page[page].append(entry)

    for group in groups:
        for item in group:
            page = int(_safe_dict(item).get("page") or 0)
            if page > 0:
                by_page[page].append(_safe_dict(item))

    contexts: List[JsonDict] = []

    for page, items in sorted(by_page.items()):
        text = "\n".join(_text(_safe_dict(x).get("text"), 2000) for x in items)
        refs = _refs_from_groups([[x for x in items if _safe_dict(x).get("sourceRefs")]])

        contexts.append(
            {
                "page": page,
                "chunkCount": len(items),
                "combinedTextExcerpt": _text(_clean_source_text(text), 12000),
                "sourceRefs": refs[:12],
                "metadata": {
                    "builtByRagRetrievalAgentV10": True,
                    "fallbackUsed": False,
                    "usedSmartFallback": False,
                },
            }
        )

    return contexts[:30]


def _preserve_background(payload: JsonDict) -> Tuple[str, Any, str]:
    st = _safe_dict(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))

    full_pdf_summary = _text(
        payload.get("fullPdfSummary")
        or payload.get("pdfSummary")
        or st.get("fullPdfSummary")
        or "",
        50000,
    )

    full_pdf_outline = (
        payload.get("fullPdfOutline")
        or st.get("fullPdfOutline")
        or {}
    )

    full_pdf_outline_text = _text(
        payload.get("fullPdfOutlineText")
        or st.get("fullPdfOutlineText")
        or "",
        50000,
    )

    return full_pdf_summary, full_pdf_outline, full_pdf_outline_text


def _selected_page_full_text(payload: JsonDict) -> str:
    st = _safe_dict(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    return _text(
        payload.get("selectedPageFullText")
        or payload.get("selectedPageFullTextExcerpt")
        or st.get("selectedPageFullText")
        or "",
        120000,
    )


