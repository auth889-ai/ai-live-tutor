STOP_WORDS = {
    "the", "and", "for", "with", "that", "this", "from", "into", "about",
    "what", "when", "then", "than", "your", "you", "are", "was", "were",
    "can", "will", "how", "why", "all", "also", "use", "used", "using",
    "have", "has", "had", "not", "but", "or", "of", "to", "in", "on",
    "a", "an", "is", "it", "as", "by", "be", "if", "so", "we", "they",
    "their", "them", "our", "us", "i", "me", "my", "do", "does", "did",
    "teach", "explain", "selected", "node", "human", "private", "tutor",
    "details", "detailed", "board", "voice", "quiz", "concept", "world",
    "class", "teacher", "source", "grounded", "plan",
}

URL_RE = re.compile(r"https?://\S+|www\.\S+", re.IGNORECASE)
DATE_RE = re.compile(r"\b\d{1,2}/\d{1,2}/\d{2,4}\b")
TOKEN_RE = re.compile(r"[a-z0-9_]{2,}", re.IGNORECASE)
SPACE_RE = re.compile(r"\s+")


# =============================================================================
# Safe helpers
# =============================================================================

def _text(value: Any, limit: int = 4000) -> str:
    try:
        return clean_text(value or "", limit)
    except Exception:
        return str(value or "")[:limit]


def _safe_dict(value: Any) -> JsonDict:
    try:
        return safe_dict(value)
    except Exception:
        return value if isinstance(value, dict) else {}


def _safe_list(value: Any) -> List[Any]:
    try:
        return safe_list(value)
    except Exception:
        return value if isinstance(value, list) else []


def _tokens(value: Any) -> List[str]:
    raw = _text(value, 200000).lower()
    return [w for w in TOKEN_RE.findall(raw) if w not in STOP_WORDS]


def _score_text(query: str, text: str) -> float:
    q = set(_tokens(query))
    t = set(_tokens(text))
    if not q or not t:
        return 0.0

    overlap = len(q.intersection(t))
    density = overlap / max(1, len(t))
    return overlap + density


def _node(payload: JsonDict) -> JsonDict:
    return _safe_dict(payload.get("selectedNode") or payload.get("node"))


def _title(payload: JsonDict) -> str:
    node = _node(payload)
    return _text(
        node.get("title")
        or node.get("label")
        or node.get("name")
        or node.get("nodeId")
        or payload.get("topic")
        or payload.get("question")
        or "selected concept",
        280,
    )


def _query(payload: JsonDict, context: AgentContext) -> str:
    node = _node(payload)

    pieces = [
        payload.get("query"),
        payload.get("question"),
        getattr(context, "question", ""),
        node.get("title"),
        node.get("label"),
        node.get("shortDefinition"),
        node.get("definition"),
        node.get("summary"),
    ]

    for ref in _safe_list(node.get("sourceRefs")) + _safe_list(payload.get("sourceRefs")):
        quote = _text(_safe_dict(ref).get("quote"), 2000)
        if quote:
            pieces.append(quote)

    return _text(" ".join(_text(x, 3000) for x in pieces if _text(x, 3000)), 20000)


def _selected_pages(payload: JsonDict) -> List[int]:
    node = _node(payload)
    pages: List[int] = []

    raw_pages = (
        _safe_list(node.get("pages"))
        + _safe_list(node.get("pageRefs"))
        + _safe_list(payload.get("selectedPages"))
    )

    for value in raw_pages:
        try:
            p = int(value)
            if p > 0:
                pages.append(p)
        except Exception:
            pass

    for ref in _safe_list(node.get("sourceRefs")) + _safe_list(payload.get("sourceRefs")):
        r = _safe_dict(ref)
        try:
            p = int(r.get("page") or r.get("pageNumber") or 0)
            if p > 0:
                pages.append(p)
        except Exception:
            pass

    return sorted(set(pages))


def _get_attr(obj: Any, name: str, default: Any = "") -> Any:
    if isinstance(obj, dict):
        return obj.get(name, default)
    return getattr(obj, name, default)


def _get_chunk_metadata(chunk: Any) -> JsonDict:
    return _safe_dict(_get_attr(chunk, "metadata", {}))


def _get_chunk_page(chunk: Any) -> int:
    try:
        return int(_get_attr(chunk, "page", 0) or _get_attr(chunk, "pageNumber", 0) or 0)
    except Exception:
        return 0


def _get_chunk_id(chunk: Any) -> str:
    return _text(_get_attr(chunk, "chunkId", "") or _get_attr(chunk, "id", ""), 260)


def _get_chunk_resource_id(chunk: Any) -> str:
    return _text(_get_attr(chunk, "resourceId", "") or _get_attr(chunk, "resource_id", ""), 260)


def _get_chunk_source_ref(chunk: Any) -> str:
    return _text(_get_attr(chunk, "sourceRef", "") or _get_attr(chunk, "ref", ""), 420)


def _get_chunk_page_ref(chunk: Any) -> str:
    return _text(_get_attr(chunk, "pageRef", "") or _get_attr(chunk, "sourceRef", ""), 420)


def _get_chunk_text(chunk: Any) -> str:
    metadata = _get_chunk_metadata(chunk)
    pieces = [
        _get_attr(chunk, "title", ""),
        _get_attr(chunk, "heading", ""),
        _get_attr(chunk, "text", ""),
        _get_attr(chunk, "textPreview", ""),
        _get_attr(chunk, "ocrText", ""),
        metadata.get("ocrText"),
    ]

    for fig in _safe_list(metadata.get("figures")):
        f = _safe_dict(fig)
        pieces.append(f.get("caption") or f.get("text") or fig)

    return "\n".join(_text(x, 60000) for x in pieces if _text(x, 60000))


# =============================================================================
# Cleaning and fact extraction
# =============================================================================

def _remove_urls(value: Any, limit: int = 5000) -> str:
    text = _text(value, limit)
    text = URL_RE.sub(" ", text)
    text = DATE_RE.sub(" ", text)
    text = SPACE_RE.sub(" ", text)
    return text.strip(" -*•\t\r\n")


def _is_noise_line(line: str) -> bool:
    low = line.strip().lower()
    if not low:
        return True

    if URL_RE.fullmatch(low):
        return True

    if re.fullmatch(r"[\d\s:/\-.]+", low):
        return True

    if re.fullmatch(r"(page|pg\.?)?\s*\d+", low):
        return True

    if len(low) <= 2:
        return True

    return False


def _clean_source_text(value: Any, limit: int = 100000) -> str:
    raw = _text(value, limit)
    if not raw:
        return ""

    lines: List[str] = []
    seen = set()

    for raw_line in raw.splitlines():
        line = _remove_urls(raw_line, 3000)
        if _is_noise_line(line):
            continue

        key = SPACE_RE.sub(" ", line.lower()).strip()
        if not key or key in seen:
            continue

        seen.add(key)
        lines.append(line)

    # If PDF text is one long line, still keep it.
    if not lines:
        collapsed = _remove_urls(raw, limit)
        return "" if _is_noise_line(collapsed) else _text(collapsed, limit)

    # Remove exact duplicate paragraphs.
    out: List[str] = []
    seen_para = set()
    for para in "\n".join(lines).split("\n"):
        p = _text(para, 4000)
        key = SPACE_RE.sub(" ", p.lower()).strip()
        if not key or key in seen_para:
            continue
        seen_para.add(key)
        out.append(p)

    return _text("\n".join(out), limit)


def _is_good_fact(value: Any) -> bool:
    fact = _remove_urls(value, 1200)
    if not fact:
        return False

    low = fact.lower()

    if URL_RE.search(low):
        return False

    if _is_noise_line(low):
        return False

    words = fact.split()
    if len(words) < 4:
        return False

    if len(words) > 34:
        return False

    useful = bool(
        re.search(
            r"\b("
            r"is|are|means|contains?|contain|has|have|joined|join|surrounding|using|"
            r"key|measure|attribute|dimension|fact|table|schema|normalized|foreign|"
            r"relationship|example|called|defined|consists|includes|represents"
            r")\b",
            low,
        )
    )

    return useful


def _fact_key(value: Any) -> str:
    text = _remove_urls(value, 1000).lower()
    words = [w for w in TOKEN_RE.findall(text) if w not in STOP_WORDS]
    return " ".join(words[:14])


def _split_bullet_line(line: str) -> List[str]:
    parts: List[str] = []

    # Normal bullet markers.
    if "*" in line or "•" in line:
        parts.extend(p.strip(" -*•\t") for p in re.split(r"\s*[\*•]\s*", line) if p.strip(" -*•\t"))
    else:
        parts.append(line)

    # Numbered mini bullets inside a line.
    expanded: List[str] = []
    for part in parts:
        mini = re.split(r"\s+(?=\d+[\).\s])", part)
        expanded.extend(p.strip(" -\t") for p in mini if p.strip(" -\t"))

    return expanded


def _strip_title_prefix(sentence: str) -> str:
    text = sentence.strip()

    # Remove common short title at front if followed by a normal sentence.
    words = text.split()
    if len(words) > 7:
        first_two = " ".join(words[:2]).lower()
        first_three = " ".join(words[:3]).lower()
        if first_two in {"star schema", "fact table", "dimension table"}:
            return " ".join(words[2:]).strip()
        if first_three in {"understanding star schema"}:
            return " ".join(words[3:]).strip()

    return text


def _atomic_facts_from_text(value: Any) -> List[str]:
    cleaned = _clean_source_text(value, 120000)
    if not cleaned:
        return []

    candidates: List[str] = []

    for line in cleaned.splitlines():
        line = _remove_urls(line, 5000)
        if not line or _is_noise_line(line):
            continue

        for part in _split_bullet_line(line):
            part = _strip_title_prefix(part)
            part = _remove_urls(part, 2000)
            if not part:
                continue

            # Split ordinary sentences.
            pieces = re.split(r"(?<=[.!?।])\s+", part)

            for piece in pieces:
                piece = _remove_urls(piece, 1200).strip(" -*•\t")
                if not piece:
                    continue

                # Split semicolon-separated facts.
                for mini in re.split(r"\s*;\s*", piece):
                    mini = _remove_urls(mini, 1000).strip(" -*•\t")
                    if not mini:
                        continue

                    words = mini.split()
                    if len(words) > 34:
                        mini = " ".join(words[:34]).strip()

                    if _is_good_fact(mini):
                        candidates.append(mini)

    out: List[str] = []
    seen = set()

    for fact in candidates:
        key = _fact_key(fact)
        if not key or key in seen:
            continue
        seen.add(key)
        out.append(fact)

    return out


def _score_fact(query: str, fact: str, role_bonus: float = 0.0) -> float:
    low = fact.lower()
    score = _score_text(query, fact) + role_bonus

    if re.search(r"\b(is|are|means|defined|called|consists|includes|represents)\b", low):
        score += 1.2

    if re.search(r"\b(contains?|contain|has|have|attribute|measure|key)\b", low):
        score += 1.5

    if re.search(r"\b(joined|join|surrounding|relationship|foreign key|using)\b", low):
        score += 2.0

    if re.search(r"\b(not joined|not normalized|may not|do not|does not|avoid|confuse)\b", low):
        score += 2.5

    if re.search(r"\b(example|such as|for example|e\.g\.)\b", low):
        score += 0.8

    return score


def _content_flags(text: str, metadata: Optional[JsonDict] = None) -> JsonDict:
    metadata = metadata or {}
    lower = _text(text, 120000).lower()

    return {
        "hasSql": bool(re.search(r"\b(select|insert|update|delete|create|alter|drop|join)\b", lower)),
        "hasCode": bool(re.search(r"\b(def|function|class|return|for|while|if|console\.log|print)\b", lower)),
        "hasTable": bool(metadata.get("tableLike"))
        or lower.count("|") >= 4
        or bool(re.search(r"\b(row|column|field|attribute)\b", lower)),
        "hasFigureOrDiagram": bool(metadata.get("figureLike"))
        or bool(re.search(r"\b(diagram|figure|schema|graph|chart|flow|arrow|table)\b", lower)),
        "hasDefinition": bool(re.search(r"\b(is|are|means|defined|definition|called|characterized)\b", lower)),
        "hasExample": bool(re.search(r"\b(example|for example|e\.g\.|such as|use case)\b", lower)),
        "hasMistakeRisk": bool(re.search(r"\b(confuse|mistake|wrong|avoid|not|however|but|risk|problem)\b", lower)),
    }


def _diagram_hints(text: str) -> List[str]:
    lower = _text(text, 120000).lower()
    hints: List[str] = []

    def add(value: str) -> None:
        if value not in hints:
            hints.append(value)

    if re.search(r"\b(schema|fact table|dimension table|foreign key|primary key)\b", lower):
        add("schema-diagram")
    if re.search(r"\b(entity|relationship|erd|table|attribute|column)\b", lower):
        add("er-diagram")
    if re.search(r"\b(flow|workflow|process|step|pipeline|sequence)\b", lower):
        add("flowchart")
    if re.search(r"\b(compare|comparison|versus|difference|before|after)\b", lower):
        add("comparison-table")
    if re.search(r"\b(sql|query|join|select)\b", lower):
        add("sql-or-query-panel")
    if re.search(r"\b(wrong|risk|mistake|avoid|confuse)\b", lower):
        add("mistake-warning-card")

    return hints


# =============================================================================
# Source entries
