        normalize_chunks,
        safe_dict,
        safe_list,
    )
except Exception:
    from google_agent.live_tutor_agents.base_agent import BaseLiveTutorAgent
    from google_agent.live_tutor_agents.contracts import (
        AgentContext,
        JsonDict,
        SourceChunk,
        ValidationResult,
        clean_text,
        dedupe_source_refs,
        normalize_chunks,
