def _source_ref(
    *,
    resource_id: str,
    chunk_id: str,
    source_ref: str,
    page_ref: str,
    page: int,
    quote: str,
    confidence: float,
    role: str,
) -> JsonDict:
    quote = _remove_urls(quote, 900)

    return {
        "resourceId": _text(resource_id, 260),
        "chunkId": _text(chunk_id, 260),
        "sourceRef": _text(source_ref, 420),
        "pageRef": _text(page_ref, 420),
        "page": int(page or 0),
        "quote": quote,
        "confidence": round(float(confidence or 0.0), 4),
        "evidenceRole": _text(role, 120),
    }


def _entry_from_chunk(chunk: Any, role: str = "chunk") -> JsonDict:
    page = _get_chunk_page(chunk)
    resource_id = _get_chunk_resource_id(chunk)
    chunk_id = _get_chunk_id(chunk)
    source_ref = _get_chunk_source_ref(chunk)
    page_ref = _get_chunk_page_ref(chunk)

    if not page_ref and resource_id and page:
        page_ref = f"resource:{resource_id}:page:{page}"
    if not source_ref and page_ref:
        source_ref = f"{page_ref}:chunk:{chunk_id or 'unknown'}"

    text = _get_chunk_text(chunk)
    metadata = _get_chunk_metadata(chunk)

    return {
        "role": role,
        "page": page,
        "resourceId": resource_id,
        "chunkId": chunk_id,
        "sourceRef": source_ref,
        "pageRef": page_ref,
        "title": _text(_get_attr(chunk, "title", ""), 260),
        "heading": _text(_get_attr(chunk, "heading", ""), 260),
        "text": text,
        "metadata": metadata,
    }


def _entry_from_evidence(raw: Any, role: str) -> JsonDict:
    item = _safe_dict(raw)
    page = int(item.get("page") or item.get("pageNumber") or 0)
    resource_id = _text(item.get("resourceId"), 260)
    chunk_id = _text(item.get("chunkId") or item.get("id"), 260)
    source_ref = _text(item.get("sourceRef"), 420)
    page_ref = _text(item.get("pageRef"), 420)

    text = _text(
        item.get("text")
        or item.get("fullText")
        or item.get("textPreview")
        or item.get("quote")
        or item.get("ocrText")
        or "",
        80000,
    )

    refs = _safe_list(item.get("sourceRefs"))
    if not text and refs:
        text = "\n".join(_text(_safe_dict(r).get("quote"), 1000) for r in refs)

    return {
        "role": role,
        "page": page,
        "resourceId": resource_id,
        "chunkId": chunk_id,
        "sourceRef": source_ref,
        "pageRef": page_ref,
        "title": _text(item.get("title") or item.get("pageTitle"), 260),
        "heading": _text(item.get("heading"), 260),
        "text": text,
        "metadata": _safe_dict(item.get("metadata")),
        "figures": _safe_list(item.get("figures")),
        "tables": _safe_list(item.get("tables")),
        "layoutBlocks": _safe_list(item.get("layoutBlocks")),
    }


def _entry_from_page_context(raw: Any, payload: JsonDict, role: str) -> JsonDict:
    ctx = _safe_dict(raw)
    page = int(ctx.get("page") or ctx.get("pageNumber") or 0)

    text = _text(
        ctx.get("fullText")
        or ctx.get("combinedTextExcerpt")
        or ctx.get("text")
        or ctx.get("ocrText")
        or "",
        90000,
    )

    if not text:
        chunk_texts = []
        for chunk in _safe_list(ctx.get("chunks")):
            c = _safe_dict(chunk)
            chunk_texts.append(_text(c.get("text") or c.get("textPreview") or c.get("quote"), 20000))
        text = "\n".join(x for x in chunk_texts if x)

    resource_id = _text(ctx.get("resourceId") or payload.get("resourceId"), 260)
    page_ref = _text(ctx.get("pageRef") or (f"resource:{resource_id}:page:{page}" if resource_id and page else ""), 420)

    return {
        "role": role,
        "page": page,
        "resourceId": resource_id,
        "chunkId": _text(ctx.get("chunkId") or f"pagectx_p{page}", 260),
        "sourceRef": _text(ctx.get("sourceRef") or f"{page_ref}:pagectx", 420),
        "pageRef": page_ref,
        "title": _text(ctx.get("title") or ctx.get("pageTitle"), 260),
        "heading": _text(ctx.get("heading") or ctx.get("relation"), 260),
        "text": text,
        "metadata": _safe_dict(ctx.get("metadata")),
        "figures": _safe_list(ctx.get("figures")),
        "tables": _safe_list(ctx.get("tables")),
        "layoutBlocks": _safe_list(ctx.get("layoutBlocks")),
    }


def _entry_from_full_page(payload: JsonDict) -> Optional[JsonDict]:
    source_truth = _safe_dict(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))

    text = _text(
        payload.get("selectedPageFullText")
        or source_truth.get("selectedPageFullText")
        or payload.get("selectedPageFullTextExcerpt")
        or "",
        120000,
    )

    if not text:
        return None

    pages = _selected_pages(payload)
    page = pages[0] if pages else int(payload.get("page") or 0)
    resource_id = _text(payload.get("resourceId"), 260)
    page_ref = f"resource:{resource_id}:page:{page}" if resource_id and page else ""

    return {
        "role": "selectedPageFullText",
        "page": page,
        "resourceId": resource_id,
        "chunkId": f"selected_page_full_text_p{page}",
        "sourceRef": f"{page_ref}:fulltext",
        "pageRef": page_ref,
        "title": f"{_title(payload)} — selected page",
        "heading": "Selected page full text",
        "text": text,
        "metadata": {
            "source": "selectedPageFullText",
            "pdfExtractedTextIsTruth": True,
        },
    }


def _all_source_entries(payload: JsonDict) -> List[JsonDict]:
    entries: List[JsonDict] = []

    full_page = _entry_from_full_page(payload)
    if full_page:
        entries.append(full_page)

    for chunk in normalize_chunks(_safe_list(payload.get("chunks"))):
        entries.append(_entry_from_chunk(chunk, role="chunk"))

    source_truth = _safe_dict(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))

    for raw in (
        _safe_list(payload.get("selectedEvidence"))
        + _safe_list(source_truth.get("selectedEvidence"))
    ):
        entries.append(_entry_from_evidence(raw, "selectedEvidence"))

    for raw in (
        _safe_list(payload.get("samePageEvidence"))
        + _safe_list(source_truth.get("samePageEvidence"))
    ):
        entries.append(_entry_from_evidence(raw, "samePageEvidence"))

    for raw in (
        _safe_list(payload.get("nearbyEvidence"))
        + _safe_list(source_truth.get("nearbyEvidence"))
    ):
        entries.append(_entry_from_evidence(raw, "nearbyEvidence"))

    for raw in (
        _safe_list(payload.get("relatedEvidence"))
        + _safe_list(source_truth.get("relatedEvidence"))
    ):
        entries.append(_entry_from_evidence(raw, "relatedEvidence"))

    for raw in (
        _safe_list(payload.get("comparisonEvidence"))
        + _safe_list(source_truth.get("comparisonEvidence"))
    ):
        entries.append(_entry_from_evidence(raw, "comparisonEvidence"))

    page_contexts = (
        _safe_list(payload.get("pageContexts"))
        + _safe_list(payload.get("selectedPageContexts"))
        + _safe_list(source_truth.get("pageContexts"))
    )

    for raw in page_contexts:
        ctx = _safe_dict(raw)
        relation = _text(ctx.get("relation"), 120).lower()
        role = "pageContext"
        if "selected" in relation:
            role = "samePageEvidence"
        elif "nearby" in relation:
            role = "nearbyEvidence"
        elif "comparison" in relation:
            role = "comparisonEvidence"
        entries.append(_entry_from_page_context(raw, payload, role))

    # Dedupe entries by page/source/text start.
    out: List[JsonDict] = []
    seen = set()

    for e in entries:
        text = _clean_source_text(e.get("text"), 20000)
        if not text:
            continue
        e["text"] = text
        key = f"{e.get('page')}|{e.get('sourceRef')}|{text[:180].lower()}"
        if key in seen:
            continue
        seen.add(key)
        out.append(e)

    return out


