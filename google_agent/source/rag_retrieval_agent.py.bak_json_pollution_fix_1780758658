class RagRetrievalAgent(BaseLiveTutorAgent):
    agent_name = "RagRetrievalAgent"
    agent_group = "source"
    default_mode = "retrieve_selected_node"
    uses_adk = False

    @property
    def instruction(self) -> str:
        return """
Build clean dynamic sourceTruthPacket for the selected tutor node.
Use only real source text.
Return diverse selectedEvidence, samePageEvidence, nearbyEvidence, sourceRefs, pageContexts.
No fake fallback. No topic hardcoding.
"""

    def validate_input(self, payload: JsonDict) -> ValidationResult:
        errors: List[str] = []
        warnings: List[str] = []

        has_chunks = bool(_safe_list(payload.get("chunks")))
        has_full_page = bool(_selected_page_full_text(payload))
        has_page_contexts = bool(
            _safe_list(payload.get("pageContexts"))
            or _safe_list(_safe_dict(payload.get("sourceTruthPacket")).get("pageContexts"))
            or _safe_list(_safe_dict(payload.get("sourceTruth")).get("pageContexts"))
        )
        has_existing_evidence = bool(
            _safe_list(payload.get("selectedEvidence"))
            or _safe_list(_safe_dict(payload.get("sourceTruthPacket")).get("selectedEvidence"))
        )

        if not (has_chunks or has_full_page or has_page_contexts or has_existing_evidence):
            errors.append(
                "RagRetrievalAgent requires chunks, selectedPageFullText, pageContexts, or selectedEvidence."
            )

        if not _node(payload):
            warnings.append("selectedNode missing; retrieval will use question/sourceRefs only.")

        return ValidationResult(
            ok=not errors,
            errors=errors,
            warnings=warnings,
            validator="RagRetrievalAgent.validate_input.cleanDynamicV10",
            fallbackUsed=False,
        )

    def build_prompt(self, payload: JsonDict, context: AgentContext) -> str:
        return ""

    def run_without_adk(self, payload: JsonDict, context: AgentContext) -> JsonDict:
        query = _query(payload, context)
        selected_pages = _selected_pages(payload)
        entries = _all_source_entries(payload)

        selected, same, nearby, related, comparison = _group_evidence(query, entries, selected_pages)

        source_refs = _refs_from_groups([selected, same, nearby, related, comparison])
        page_contexts = _build_page_contexts(entries, [selected, same, nearby, related, comparison])

        full_pdf_summary, full_pdf_outline, full_pdf_outline_text = _preserve_background(payload)
        selected_page_text = _selected_page_full_text(payload)

        combined_text = "\n".join(_text(x.get("text"), 4000) for x in selected + same + nearby)
        flags = _content_flags(combined_text, {})
        hints = _diagram_hints(combined_text)

        source_truth_packet = {
            "selectedEvidence": selected,
            "samePageEvidence": same,
            "nearbyEvidence": nearby,
            "relatedEvidence": related,
            "comparisonEvidence": comparison,
            "externalEvidence": [],
            "pageContexts": page_contexts,
            "sourceRefs": source_refs,
            "selectedPageFullText": selected_page_text,
            "fullPdfSummary": full_pdf_summary,
            "fullPdfOutline": full_pdf_outline,
            "fullPdfOutlineText": full_pdf_outline_text,
            "diagramHints": hints,
            "contentFlags": flags,
            "rules": {
                "selectedEvidenceIsMainTruth": True,
                "samePageEvidenceSupportsSelectedNode": True,
                "nearbyEvidenceSupportsOnly": True,
                "comparisonEvidenceOnlyForComparison": True,
                "pdfExtractedTextIsTruth": True,
                "ocrIsHelperOnly": True,
                "imageTextIsTruth": False,
                "noInventedFacts": True,
            },
            "metadata": {
                "sourceTruthPacketV10": True,
                "cleanDynamicRagV10": True,
                "diverseTeachingFactsV10": True,
                "realSourceOnly": True,
                "noHardcodedTopic": True,
                "selectedEvidenceCount": len(selected),
                "samePageEvidenceCount": len(same),
                "nearbyEvidenceCount": len(nearby),
                "relatedEvidenceCount": len(related),
                "comparisonEvidenceCount": len(comparison),
                "pageContextCount": len(page_contexts),
                "sourceRefCount": len(source_refs),
                "hasSelectedPageFullText": bool(selected_page_text),
                "hasFullPdfSummary": bool(full_pdf_summary),
                "hasFullPdfOutlineText": bool(full_pdf_outline_text),
                "fallbackUsed": False,
                "usedSmartFallback": False,
            },
        }

        return {
            "query": query,
            "chunks": selected,
            "selectedEvidence": selected,
            "samePageEvidence": same,
            "nearbyEvidence": nearby,
            "relatedEvidence": related,
            "comparisonEvidence": comparison,
            "externalEvidence": [],
            "pageContexts": page_contexts,
            "sourceRefs": source_refs,
            "diagramHints": hints,
            "contentFlags": flags,
            "sourceTruthPacket": source_truth_packet,
            "rankingPreview": [
                {
                    "page": item.get("page"),
                    "chunkId": item.get("chunkId"),
                    "score": item.get("score"),
                    "quote": item.get("quote"),
                    "role": item.get("evidenceRole"),
                }
                for item in (selected + same + nearby)[:14]
            ],
            "metadata": {
                "agent": self.agent_name,
                "retrievalMode": "clean_dynamic_source_truth_v10",
                "realSeparateAgent": True,
                "dynamicSourceRanking": True,
                "sourceTruthLayerV10": True,
                "cleanDynamicRagV10": True,
                "diverseTeachingFactsV10": True,
                "realSourceOnly": True,
                "noHardcodedTopic": True,
                "fallbackUsed": False,
                "usedSmartFallback": False,
                "chunkCountInput": len(_safe_list(payload.get("chunks"))),
                "sourceEntryCount": len(entries),
                "selectedEvidenceCount": len(selected),
                "samePageEvidenceCount": len(same),
                "nearbyEvidenceCount": len(nearby),
                "pageContextCount": len(page_contexts),
                "sourceRefCount": len(source_refs),
            },
        }

    def normalize_output(self, raw: JsonDict, payload: JsonDict, context: AgentContext) -> JsonDict:
        raw = _safe_dict(raw)
        st = _safe_dict(raw.get("sourceTruthPacket"))

        selected = _safe_list(raw.get("selectedEvidence")) or _safe_list(st.get("selectedEvidence"))
        same = _safe_list(raw.get("samePageEvidence")) or _safe_list(st.get("samePageEvidence"))
        nearby = _safe_list(raw.get("nearbyEvidence")) or _safe_list(st.get("nearbyEvidence"))
        related = _safe_list(raw.get("relatedEvidence")) or _safe_list(st.get("relatedEvidence"))
        comparison = _safe_list(raw.get("comparisonEvidence")) or _safe_list(st.get("comparisonEvidence"))
        page_contexts = _safe_list(raw.get("pageContexts")) or _safe_list(st.get("pageContexts"))
        refs = dedupe_source_refs([_safe_dict(x) for x in (_safe_list(raw.get("sourceRefs")) or _safe_list(st.get("sourceRefs")))])

        if not st:
            full_pdf_summary, full_pdf_outline, full_pdf_outline_text = _preserve_background(payload)
            st = {
                "selectedEvidence": selected,
                "samePageEvidence": same,
                "nearbyEvidence": nearby,
                "relatedEvidence": related,
                "comparisonEvidence": comparison,
                "externalEvidence": _safe_list(raw.get("externalEvidence")),
                "pageContexts": page_contexts,
                "sourceRefs": refs,
                "selectedPageFullText": _selected_page_full_text(payload),
                "fullPdfSummary": full_pdf_summary,
                "fullPdfOutline": full_pdf_outline,
                "fullPdfOutlineText": full_pdf_outline_text,
                "diagramHints": _safe_list(raw.get("diagramHints")),
                "contentFlags": _safe_dict(raw.get("contentFlags")),
                "metadata": {},
            }

        st["metadata"] = {
            **_safe_dict(st.get("metadata")),
            "sourceTruthPacketV10": True,
            "cleanDynamicRagV10": True,
            "diverseTeachingFactsV10": True,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        }

        return {
            "query": _text(raw.get("query") or _query(payload, context), 4000),
            "chunks": _safe_list(raw.get("chunks")) or selected,
            "selectedEvidence": selected,
            "samePageEvidence": same,
            "nearbyEvidence": nearby,
            "relatedEvidence": related,
            "comparisonEvidence": comparison,
            "externalEvidence": _safe_list(raw.get("externalEvidence")),
            "pageContexts": page_contexts,
            "sourceRefs": refs,
            "diagramHints": _safe_list(raw.get("diagramHints")) or _safe_list(st.get("diagramHints")),
            "contentFlags": _safe_dict(raw.get("contentFlags")) or _safe_dict(st.get("contentFlags")),
            "sourceTruthPacket": st,
            "rankingPreview": _safe_list(raw.get("rankingPreview")),
            "metadata": {
                **_safe_dict(raw.get("metadata")),
                "agent": self.agent_name,
                "sourceTruthLayerV10": True,
                "cleanDynamicRagV10": True,
                "diverseTeachingFactsV10": True,
                "fallbackUsed": False,
                "usedSmartFallback": False,
                "selectedEvidenceCount": len(selected),
                "samePageEvidenceCount": len(same),
                "nearbyEvidenceCount": len(nearby),
                "pageContextCount": len(page_contexts),
                "sourceRefCount": len(refs),
            },
        }

    def validate_output(self, output: JsonDict, payload: JsonDict, context: AgentContext) -> ValidationResult:
        errors: List[str] = []
        warnings: List[str] = []

        selected = _safe_list(output.get("selectedEvidence"))
        same = _safe_list(output.get("samePageEvidence"))
        nearby = _safe_list(output.get("nearbyEvidence"))
        refs = _safe_list(output.get("sourceRefs"))
        page_contexts = _safe_list(output.get("pageContexts"))

        if len(selected) < 3:
            errors.append(f"selectedEvidence too thin: expected >=3, got {len(selected)}.")

        if len(refs) < 3:
            errors.append(f"sourceRefs too thin: expected >=3, got {len(refs)}.")

        if not page_contexts:
            errors.append("pageContexts are required.")

        if not same:
            warnings.append("samePageEvidence is empty; selected evidence will support same-page context.")

        if not nearby:
            warnings.append("nearbyEvidence is empty; comparison/support pages may be weak.")

        seen_quotes = set()
        duplicate_quotes = 0

        for index, item in enumerate(selected[:12]):
            e = _safe_dict(item)
            quote = _remove_urls(e.get("quote"), 900)

            if not quote:
                errors.append(f"selectedEvidence[{index}] missing quote.")

            if URL_RE.search(quote):
                errors.append(f"selectedEvidence[{index}] quote contains URL.")

            key = _fact_key(quote)
            if key in seen_quotes:
                duplicate_quotes += 1
            seen_quotes.add(key)

            if not _safe_list(e.get("sourceRefs")):
                errors.append(f"selectedEvidence[{index}] missing sourceRefs.")

        if duplicate_quotes >= 3:
            warnings.append(f"selectedEvidence has repeated quote meanings: {duplicate_quotes} duplicates.")

        for index, ref in enumerate(refs[:20]):
            r = _safe_dict(ref)
            quote = _remove_urls(r.get("quote"), 900)

            if int(r.get("page") or 0) <= 0:
                errors.append(f"sourceRefs[{index}] missing valid page.")

            if not quote:
                errors.append(f"sourceRefs[{index}] missing quote.")

            if URL_RE.search(quote):
                errors.append(f"sourceRefs[{index}] quote contains URL.")

        st = _safe_dict(output.get("sourceTruthPacket"))
        if not st:
            errors.append("sourceTruthPacket is required.")
        else:
            if not _text(st.get("selectedPageFullText")):
                warnings.append("sourceTruthPacket.selectedPageFullText missing.")
            if not _text(st.get("fullPdfSummary")):
                warnings.append("sourceTruthPacket.fullPdfSummary missing.")
            if not _text(st.get("fullPdfOutlineText")):
                warnings.append("sourceTruthPacket.fullPdfOutlineText missing.")

        meta = _safe_dict(output.get("metadata"))
        if meta.get("fallbackUsed") is True or meta.get("usedSmartFallback") is True:
            errors.append("RagRetrievalAgent fallback is not allowed.")

        return ValidationResult(
            ok=not errors,
            errors=errors,
            warnings=warnings,
            validator="RagRetrievalAgent.validate_output.cleanDynamicV10",
            fallbackUsed=False,
        )


def run(payload: JsonDict) -> JsonDict:
    import asyncio

    agent = RagRetrievalAgent()
    return asyncio.run(agent.run(payload)).to_dict()


