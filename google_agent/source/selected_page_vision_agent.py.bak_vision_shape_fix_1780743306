        "selectedPageAnalyses": selected_analyses,
        "nearbyPageAnalyses": nearby_analyses,
        "pageImageAnalyses": analyses,
        "detectedDiagrams": diagrams,
        "diagramElements": diagram_elements[:120],
        "relationships": relationships[:120],
