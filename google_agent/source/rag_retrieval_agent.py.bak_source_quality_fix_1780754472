class RagRetrievalAgent(BaseLiveTutorAgent):
    agent_name = "RagRetrievalAgent"
    agent_group = "source"
    default_mode = "retrieve_selected_node"
    uses_adk = False

    @property
    def instruction(self) -> str:
        return """
Retrieve and expand real source evidence for the selected tutor node.
Never invent.
Use selectedPageFullText/pageContexts/chunks/sourceRefs.
Return rich selectedEvidence, samePageEvidence, nearbyEvidence, sourceRefs, pageContexts.
"""

    def validate_input(self, payload: JsonDict) -> ValidationResult:
        errors = []
        warnings = []

        has_chunks = bool(safe_list(payload.get("chunks")))
        has_full_page = bool(_text(payload.get("selectedPageFullText"), 1000))
        has_page_contexts = bool(safe_list(payload.get("pageContexts")) or safe_list(safe_dict(payload.get("sourceTruth")).get("pageContexts")))
        has_refs = bool(safe_list(payload.get("sourceRefs")) or safe_list(_node(payload).get("sourceRefs")))

        if not (has_chunks or has_full_page or has_page_contexts or has_refs):
            errors.append(
                "RagRetrievalAgent requires chunks, selectedPageFullText, pageContexts, or sourceRefs."
            )

        if not _node(payload):
            warnings.append("selectedNode is missing; retrieval will use question/sourceRefs only.")

        return ValidationResult(
            ok=not errors,
            errors=errors,
            warnings=warnings,
            validator="RagRetrievalAgent.validate_input.richSourceTruthV5",
            fallbackUsed=False,
        )

    def build_prompt(self, payload: JsonDict, context: AgentContext) -> str:
        return ""

    def run_without_adk(self, payload: JsonDict, context: AgentContext) -> JsonDict:
        query = _query(payload, context)
        chunks = normalize_chunks(safe_list(payload.get("chunks")))

        selected_from_chunks: List[JsonDict] = []
        same_from_chunks: List[JsonDict] = []
        nearby_from_chunks: List[JsonDict] = []
        related_from_chunks: List[JsonDict] = []

        if chunks:
            selected_from_chunks, same_from_chunks, nearby_from_chunks, related_from_chunks = _chunk_evidence(
                query,
                chunks,
                payload,
            )

        selected_from_page = _full_page_evidence(query, payload)
        selected_from_refs = _node_source_ref_evidence(query, payload)

        page_selected, page_same, page_nearby, page_comparison = _page_context_evidence(query, payload)

        existing_selected = _normalize_existing_evidence(
            safe_list(payload.get("selectedEvidence"))
            + safe_list(safe_dict(payload.get("sourceTruth")).get("selectedEvidence"))
            + safe_list(safe_dict(payload.get("sourceTruthPacket")).get("selectedEvidence")),
            query,
            "selectedEvidence",
        )
        existing_same = _normalize_existing_evidence(
            safe_list(payload.get("samePageEvidence"))
            + safe_list(safe_dict(payload.get("sourceTruth")).get("samePageEvidence"))
            + safe_list(safe_dict(payload.get("sourceTruthPacket")).get("samePageEvidence")),
            query,
            "samePageEvidence",
        )
        existing_nearby = _normalize_existing_evidence(
            safe_list(payload.get("nearbyEvidence"))
            + safe_list(safe_dict(payload.get("sourceTruth")).get("nearbyEvidence"))
            + safe_list(safe_dict(payload.get("sourceTruthPacket")).get("nearbyEvidence")),
            query,
            "nearbyEvidence",
        )

        selected_evidence = _dedupe_evidence(
            sorted(
                selected_from_refs
                + selected_from_chunks
                + selected_from_page
                + page_selected
                + existing_selected,
                key=lambda x: float(safe_dict(x).get("score") or 0),
                reverse=True,
            ),
            limit=16,
        )

        same_page_evidence = _dedupe_evidence(
            sorted(
                page_same
                + same_from_chunks
                + existing_same,
                key=lambda x: float(safe_dict(x).get("score") or 0),
                reverse=True,
            ),
            limit=12,
        )

        # If samePage is still empty but selected page has multiple selected evidences,
        # use lower-ranked selected-page facts as samePage support.
        if not same_page_evidence and len(selected_evidence) > 1:
            same_page_evidence = [
                {**safe_dict(x), "evidenceRole": "samePageEvidence"}
                for x in selected_evidence[1:5]
            ]

        nearby_evidence = _dedupe_evidence(
            sorted(
                page_nearby
                + nearby_from_chunks
                + existing_nearby,
                key=lambda x: float(safe_dict(x).get("score") or 0),
                reverse=True,
            ),
            limit=14,
        )

        related_evidence = _dedupe_evidence(
            sorted(
                related_from_chunks,
                key=lambda x: float(safe_dict(x).get("score") or 0),
                reverse=True,
            ),
            limit=10,
        )

        comparison_evidence = _dedupe_evidence(
            sorted(
                page_comparison,
                key=lambda x: float(safe_dict(x).get("score") or 0),
                reverse=True,
            ),
            limit=12,
        )

        page_contexts = _build_page_contexts(
            payload,
            [selected_evidence, same_page_evidence, nearby_evidence, related_evidence, comparison_evidence],
        )

        source_refs = _refs_from_evidence(
            [selected_evidence, same_page_evidence, nearby_evidence, related_evidence, comparison_evidence]
        )

        # If still too few refs, lift refs from pageContexts.
        if len(source_refs) < 5:
            for ctx in page_contexts:
                source_refs.extend([safe_dict(r) for r in safe_list(safe_dict(ctx).get("sourceRefs"))])
            source_refs = dedupe_source_refs(source_refs)

        all_text = "\n".join(
            [_text(x.get("text"), 4000) for x in selected_evidence + same_page_evidence + nearby_evidence]
        )

        flags = _content_flags(all_text, {})
        hints = []
        for item in selected_evidence + same_page_evidence + nearby_evidence:
            for hint in safe_list(safe_dict(item).get("diagramHints")):
                if hint not in hints:
                    hints.append(hint)

        selected_page_full_text = _text(
            payload.get("selectedPageFullText")
            or safe_dict(payload.get("sourceTruth")).get("selectedPageFullText")
            or safe_dict(payload.get("sourceTruthPacket")).get("selectedPageFullText")
            or "",
            80000,
        )

        full_pdf_summary = _text(
            payload.get("fullPdfSummary")
            or payload.get("pdfSummary")
            or safe_dict(payload.get("sourceTruth")).get("fullPdfSummary")
            or safe_dict(payload.get("sourceTruthPacket")).get("fullPdfSummary")
            or "",
            50000,
        )

        full_pdf_outline_text = _text(
            payload.get("fullPdfOutlineText")
            or safe_dict(payload.get("sourceTruth")).get("fullPdfOutlineText")
            or safe_dict(payload.get("sourceTruthPacket")).get("fullPdfOutlineText")
            or "",
            50000,
        )

        source_truth_packet = {
            "selectedEvidence": selected_evidence,
            "samePageEvidence": same_page_evidence,
            "nearbyEvidence": nearby_evidence,
            "relatedEvidence": related_evidence,
            "comparisonEvidence": comparison_evidence,
            "externalEvidence": [],
            "pageContexts": page_contexts,
            "sourceRefs": source_refs,
            "selectedPageFullText": selected_page_full_text,
            "fullPdfSummary": full_pdf_summary,
            "fullPdfOutline": payload.get("fullPdfOutline")
                or safe_dict(payload.get("sourceTruth")).get("fullPdfOutline")
                or safe_dict(payload.get("sourceTruthPacket")).get("fullPdfOutline"),
            "fullPdfOutlineText": full_pdf_outline_text,
            "diagramHints": hints,
            "contentFlags": flags,
            "rules": {
                "selectedEvidenceIsMainTruth": True,
                "samePageEvidenceSupportsSelectedNode": True,
                "nearbyEvidenceSupportsOnly": True,
                "comparisonEvidenceOnlyForComparison": True,
                "pdfExtractedTextIsTruth": True,
                "ocrIsHelperOnly": True,
                "imageTextIsTruth": False,
            },
            "metadata": {
                "sourceTruthPacketV5": True,
                "richEvidenceExpansionV5": True,
                "selectedEvidenceCount": len(selected_evidence),
                "samePageEvidenceCount": len(same_page_evidence),
                "nearbyEvidenceCount": len(nearby_evidence),
                "pageContextCount": len(page_contexts),
                "sourceRefCount": len(source_refs),
                "hasSelectedPageFullText": bool(selected_page_full_text),
                "hasFullPdfSummary": bool(full_pdf_summary),
                "hasFullPdfOutlineText": bool(full_pdf_outline_text),
                "fallbackUsed": False,
                "usedSmartFallback": False,
            },
        }

        return {
            "query": query,
            "chunks": selected_evidence,
            "selectedEvidence": selected_evidence,
            "samePageEvidence": same_page_evidence,
            "nearbyEvidence": nearby_evidence,
            "relatedEvidence": related_evidence,
            "comparisonEvidence": comparison_evidence,
            "externalEvidence": [],
            "pageContexts": page_contexts,
            "sourceRefs": source_refs,
            "diagramHints": hints,
            "contentFlags": flags,
            "sourceTruthPacket": source_truth_packet,
            "rankingPreview": [
                {
                    "page": item.get("page"),
                    "chunkId": item.get("chunkId"),
                    "score": item.get("score"),
                    "quote": item.get("quote"),
                    "role": item.get("evidenceRole"),
                }
                for item in (selected_evidence + same_page_evidence + nearby_evidence)[:14]
            ],
            "metadata": {
                "agent": self.agent_name,
                "retrievalMode": "rich_source_truth_v5",
                "realSeparateAgent": True,
                "dynamicSourceRanking": True,
                "sourceTruthLayerV5": True,
                "richEvidenceExpansionV5": True,
                "fallbackUsed": False,
                "usedSmartFallback": False,
                "chunkCountInput": len(chunks),
                "selectedEvidenceCount": len(selected_evidence),
                "samePageEvidenceCount": len(same_page_evidence),
                "nearbyEvidenceCount": len(nearby_evidence),
                "pageContextCount": len(page_contexts),
                "sourceRefCount": len(source_refs),
            },
        }

    def normalize_output(self, raw: JsonDict, payload: JsonDict, context: AgentContext) -> JsonDict:
        raw = safe_dict(raw)

        source_truth_packet = safe_dict(raw.get("sourceTruthPacket"))

        selected = safe_list(raw.get("selectedEvidence")) or safe_list(source_truth_packet.get("selectedEvidence"))
        same = safe_list(raw.get("samePageEvidence")) or safe_list(source_truth_packet.get("samePageEvidence"))
        nearby = safe_list(raw.get("nearbyEvidence")) or safe_list(source_truth_packet.get("nearbyEvidence"))
        related = safe_list(raw.get("relatedEvidence")) or safe_list(source_truth_packet.get("relatedEvidence"))
        comparison = safe_list(raw.get("comparisonEvidence")) or safe_list(source_truth_packet.get("comparisonEvidence"))
        page_contexts = safe_list(raw.get("pageContexts")) or safe_list(source_truth_packet.get("pageContexts"))

        refs = safe_list(raw.get("sourceRefs")) or safe_list(source_truth_packet.get("sourceRefs"))
        refs = dedupe_source_refs([safe_dict(x) for x in refs])

        if not source_truth_packet:
            source_truth_packet = {
                "selectedEvidence": selected,
                "samePageEvidence": same,
                "nearbyEvidence": nearby,
                "relatedEvidence": related,
                "comparisonEvidence": comparison,
                "externalEvidence": safe_list(raw.get("externalEvidence")),
                "pageContexts": page_contexts,
                "sourceRefs": refs,
                "selectedPageFullText": _text(payload.get("selectedPageFullText"), 80000),
                "fullPdfSummary": _text(payload.get("fullPdfSummary") or payload.get("pdfSummary"), 50000),
                "fullPdfOutline": payload.get("fullPdfOutline"),
                "fullPdfOutlineText": _text(payload.get("fullPdfOutlineText"), 50000),
                "diagramHints": safe_list(raw.get("diagramHints")),
                "contentFlags": safe_dict(raw.get("contentFlags")),
                "metadata": {
                    "sourceTruthPacketV5": True,
                    "fallbackUsed": False,
                },
            }

        return {
            "query": _text(raw.get("query") or _query(payload, context), 4000),
            "chunks": safe_list(raw.get("chunks")) or selected,
            "selectedEvidence": selected,
            "samePageEvidence": same,
            "nearbyEvidence": nearby,
            "relatedEvidence": related,
            "comparisonEvidence": comparison,
            "externalEvidence": safe_list(raw.get("externalEvidence")),
            "pageContexts": page_contexts,
            "sourceRefs": refs,
            "diagramHints": safe_list(raw.get("diagramHints")) or safe_list(source_truth_packet.get("diagramHints")),
            "contentFlags": safe_dict(raw.get("contentFlags")) or safe_dict(source_truth_packet.get("contentFlags")),
            "sourceTruthPacket": source_truth_packet,
            "rankingPreview": safe_list(raw.get("rankingPreview")),
            "metadata": {
                **safe_dict(raw.get("metadata")),
                "agent": self.agent_name,
                "sourceTruthLayerV5": True,
                "richEvidenceExpansionV5": True,
                "selectedEvidenceCount": len(selected),
                "samePageEvidenceCount": len(same),
                "nearbyEvidenceCount": len(nearby),
                "pageContextCount": len(page_contexts),
                "sourceRefCount": len(refs),
                "fallbackUsed": False,
                "usedSmartFallback": False,
            },
        }

    def validate_output(self, output: JsonDict, payload: JsonDict, context: AgentContext) -> ValidationResult:
        errors = []
        warnings = []

        selected = safe_list(output.get("selectedEvidence"))
        same = safe_list(output.get("samePageEvidence"))
        nearby = safe_list(output.get("nearbyEvidence"))
        refs = safe_list(output.get("sourceRefs"))
        page_contexts = safe_list(output.get("pageContexts"))

        if len(selected) < 3:
            errors.append(
                f"selectedEvidence too thin: expected >=3, got {len(selected)}."
            )
        if len(refs) < 5:
            errors.append(
                f"sourceRefs too thin: expected >=5, got {len(refs)}."
            )
        if not page_contexts:
            errors.append("pageContexts are required.")

        if not same:
            warnings.append("samePageEvidence is empty; selected evidence will be used as same-page support downstream.")
        if not nearby:
            warnings.append("nearbyEvidence is empty; downstream comparison may be weaker.")

        for index, item in enumerate(selected[:8]):
            e = safe_dict(item)
            if not _text(e.get("text")) and not _text(e.get("textPreview")):
                errors.append(f"selectedEvidence[{index}] missing text/textPreview.")
            if not safe_list(e.get("sourceRefs")):
                errors.append(f"selectedEvidence[{index}] missing sourceRefs.")

        for index, ref in enumerate(refs[:12]):
            r = safe_dict(ref)
            if int(r.get("page") or 0) <= 0:
                errors.append(f"sourceRefs[{index}] missing valid page.")
            if not _text(r.get("quote")):
                errors.append(f"sourceRefs[{index}] missing quote.")

        source_truth_packet = safe_dict(output.get("sourceTruthPacket"))
        if not source_truth_packet:
            errors.append("sourceTruthPacket is required.")
        else:
            if not _text(source_truth_packet.get("selectedPageFullText")):
                warnings.append("sourceTruthPacket.selectedPageFullText missing.")
            if not _text(source_truth_packet.get("fullPdfSummary")):
                warnings.append("sourceTruthPacket.fullPdfSummary missing.")
            if not _text(source_truth_packet.get("fullPdfOutlineText")):
                warnings.append("sourceTruthPacket.fullPdfOutlineText missing.")

        meta = safe_dict(output.get("metadata"))
        if meta.get("fallbackUsed") is True or meta.get("usedSmartFallback") is True:
            errors.append("RagRetrievalAgent fallback is not allowed.")

        return ValidationResult(
            ok=not errors,
            errors=errors,
            warnings=warnings,
            validator="RagRetrievalAgent.validate_output.richSourceTruthV5",
            fallbackUsed=False,
        )


def run(payload: JsonDict) -> JsonDict:
    import asyncio

    agent = RagRetrievalAgent()
    return asyncio.run(agent.run(payload)).to_dict()


