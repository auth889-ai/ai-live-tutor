def _text(value: Any, limit: int = 4000) -> str:
    return clean_text(value or "", limit)


def _wc(value: Any) -> int:
    return len(_text(value, 100000).split())


def _tok(text: Any) -> List[str]:
    raw = _text(text, 200000).lower()
    words = re.findall(r"[a-z0-9_]{2,}", raw)
    return [w for w in words if w not in STOP_WORDS]


def _uniq_keep_order(items: Iterable[Any]) -> List[Any]:
    seen = set()
    out = []
    for item in items:
        key = repr(item)
        if key in seen:
            continue
        seen.add(key)
        out.append(item)
    return out


def _node(payload: JsonDict) -> JsonDict:
    return safe_dict(payload.get("selectedNode") or payload.get("node"))


def _title(payload: JsonDict) -> str:
    node = _node(payload)
    return _text(
        node.get("title")
        or node.get("label")
        or node.get("name")
        or node.get("nodeId")
        or payload.get("question")
        or "selected concept",
        280,
    )


def _selected_pages(payload: JsonDict) -> List[int]:
    node = _node(payload)
    pages = []

    for value in (
        safe_list(node.get("pages"))
        + safe_list(node.get("pageRefs"))
        + safe_list(payload.get("selectedPages"))
    ):
        try:
            p = int(value)
            if p > 0:
                pages.append(p)
        except Exception:
            pass

    for ref in safe_list(node.get("sourceRefs")) + safe_list(payload.get("sourceRefs")):
        try:
            p = int(safe_dict(ref).get("page") or safe_dict(ref).get("pageNumber") or 0)
            if p > 0:
                pages.append(p)
        except Exception:
            pass

    return sorted(set(pages))


def _query(payload: JsonDict, context: AgentContext) -> str:
    node = _node(payload)
    pieces = [
        payload.get("query"),
        payload.get("question"),
        context.question,
        node.get("title"),
        node.get("label"),
        node.get("shortDefinition"),
        node.get("definition"),
        node.get("summary"),
    ]

    for ref in safe_list(node.get("sourceRefs")) + safe_list(payload.get("sourceRefs")):
        q = _text(safe_dict(ref).get("quote"), 2000)
        if q:
            pieces.append(q)

    return _text(" ".join(_text(x, 3000) for x in pieces if _text(x, 3000)), 20000)


def _score_text(query: str, text: str) -> float:
    q = _tok(query)
    t = _tok(text)
    if not q or not t:
        return 0.0

    qset = set(q)
    tset = set(t)
    overlap = len(qset.intersection(tset))
    density = overlap / max(1, len(tset))
    title_bonus = overlap * 0.65
    return overlap + density + title_bonus


def _split_sentences(text: str, max_sentences: int = 80) -> List[str]:
    text = _text(text, 60000)
    if not text:
        return []

    parts = re.split(r"(?<=[.!?।])\s+|\n{1,}", text)
    cleaned = []
    for p in parts:
        p = _text(p, 1000)
        if len(p) < 25:
            continue
        cleaned.append(p)

    if not cleaned and text:
        chunks = []
        words = text.split()
        for i in range(0, len(words), 35):
            chunks.append(" ".join(words[i:i + 35]))
        cleaned = [_text(c, 1000) for c in chunks if len(c.split()) >= 8]

    return cleaned[:max_sentences]


def _best_quotes(query: str, text: str, count: int = 6, max_len: int = 700) -> List[str]:
    sentences = _split_sentences(text, 140)
    scored = []
    for s in sentences:
        score = _score_text(query, s)
        if re.search(r"\b(definition|means|called|characterized|schema|table|dimension|fact|join|normalized|denormalized)\b", s.lower()):
            score += 1.5
        if re.search(r"\b(example|such as|for example|e\.g\.|when|why|because)\b", s.lower()):
            score += 0.8
        if re.search(r"\b(not|avoid|problem|wrong|confuse|however|but)\b", s.lower()):
            score += 0.6
        scored.append((score, s))

    scored.sort(key=lambda x: x[0], reverse=True)
    quotes = []
    for score, s in scored:
        if score <= 0 and quotes:
            continue
        q = _text(s, max_len)
        if q and q not in quotes:
            quotes.append(q)
        if len(quotes) >= count:
            break

    return quotes


def _source_ref(
    *,
    resource_id: str = "",
    chunk_id: str = "",
    source_ref: str = "",
    page_ref: str = "",
    page: int = 0,
    quote: str = "",
    confidence: float = 0.8,
    role: str = "",
) -> JsonDict:
    return {
        "resourceId": _text(resource_id, 260),
        "chunkId": _text(chunk_id, 260),
        "sourceRef": _text(source_ref, 420),
        "pageRef": _text(page_ref, 420),
        "page": int(page or 0),
        "quote": _text(quote, 900),
        "confidence": round(float(confidence or 0.0), 4),
        "evidenceRole": _text(role, 120),
    }


def _ref_from_existing(ref: Any, quote_override: str = "", role: str = "") -> JsonDict:
    r = safe_dict(ref)
    return _source_ref(
        resource_id=r.get("resourceId"),
        chunk_id=r.get("chunkId") or r.get("id"),
        source_ref=r.get("sourceRef") or r.get("pageRef") or r.get("chunkId") or r.get("id"),
        page_ref=r.get("pageRef") or r.get("sourceRef"),
        page=int(r.get("page") or r.get("pageNumber") or 0),
        quote=quote_override or r.get("quote") or r.get("textPreview") or r.get("text"),
        confidence=float(r.get("confidence") or 0.8),
        role=role or r.get("evidenceRole") or r.get("role"),
    )


def _source_ref_from_chunk(chunk: SourceChunk, quote: str, score: float, role: str) -> JsonDict:
    return _source_ref(
        resource_id=chunk.resourceId,
        chunk_id=chunk.chunkId,
        source_ref=chunk.sourceRef,
        page_ref=chunk.pageRef,
        page=int(chunk.page or 0),
        quote=quote,
        confidence=min(0.98, max(0.35, score / 14.0)),
        role=role,
    )


def _chunk_to_text(chunk: SourceChunk) -> str:
    return "\n".join(
        [
            _text(chunk.title, 500),
            _text(chunk.heading, 500),
            _text(chunk.textPreview, 2000),
            _text(chunk.text, 50000),
            _text(safe_dict(chunk.metadata).get("ocrText"), 10000),
        ]
    )


def _content_flags(text: str, metadata: JsonDict) -> JsonDict:
    lower = _text(text, 100000).lower()
    return {
        "hasSql": bool(re.search(r"\b(select|insert|update|delete|create|alter|drop|join)\b", lower)),
        "hasCode": bool(re.search(r"\b(def|function|class|return|for|while|if|console\.log|print)\b", lower)),
        "hasTable": bool(metadata.get("tableLike")) or lower.count("|") >= 4 or bool(re.search(r"\b(row|column|field|attribute)\b", lower)),
        "hasFigureOrDiagram": bool(metadata.get("figureLike")) or bool(re.search(r"\b(diagram|figure|schema|graph|chart|flow|arrow|table)\b", lower)),
        "hasDefinition": bool(re.search(r"\b(is|are|means|defined|definition|called|characterized)\b", lower)),
        "hasExample": bool(re.search(r"\b(example|for example|e\.g\.|such as|use case)\b", lower)),
        "hasMistakeRisk": bool(re.search(r"\b(confuse|mistake|wrong|avoid|not|however|but|risk|problem)\b", lower)),
    }


def _diagram_hints(text: str) -> List[str]:
    lower = _text(text, 100000).lower()
    hints = []

    def add(x: str) -> None:
        if x not in hints:
            hints.append(x)

    if re.search(r"\b(star schema|snowflake|fact table|dimension table|foreign key|primary key|schema)\b", lower):
        add("schema-diagram")
    if re.search(r"\b(entity|relationship|erd|table|attribute|column)\b", lower):
        add("er-diagram")
    if re.search(r"\b(flow|workflow|process|step|pipeline|sequence)\b", lower):
        add("flowchart")
    if re.search(r"\b(compare|comparison|versus|difference|before|after)\b", lower):
        add("comparison-table")
    if re.search(r"\b(sql|query|join|select)\b", lower):
        add("sql-or-query-panel")
    if re.search(r"\b(wrong|risk|mistake|avoid|confuse)\b", lower):
        add("mistake-warning-card")

    return hints


