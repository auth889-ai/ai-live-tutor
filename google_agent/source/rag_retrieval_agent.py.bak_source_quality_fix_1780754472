# === RAG_QUALITY_CLEANING_V6 ===
# Purpose:
# - V5 increased evidence count, but quote quality could be poor:
#   URL-only quotes, duplicate page text, empty nearby quotes.
# - V6 keeps dynamic source-grounded behavior but cleans evidence quality.
# - No static topic. No hardcoded Star Schema. No fake fallback.

_URL_RE_V6 = re.compile(r"https?://\S+|www\.\S+", re.I)


def _strip_urls_v6(text: Any) -> str:
    return _URL_RE_V6.sub(" ", _text(text, 200000))


def _is_bad_quote_v6(text: Any) -> bool:
    q = _text(text, 2000).strip()
    if not q:
        return True

    low = q.lower()

    # URL-only or mostly URL/source/date lines are not teaching evidence.
    no_url = _strip_urls_v6(q).strip()
    if len(no_url) < 20:
        return True

    if low.startswith("http://") or low.startswith("https://") or low.startswith("www."):
        # Allow if after URL there is a real concept sentence.
        if len(no_url.split()) < 6:
            return True

    # Slide/date/page-only noise.
    if re.fullmatch(r"[\d/:\-\s]+", q):
        return True
    if re.fullmatch(r"(page|pg\.?)?\s*\d+", low):
        return True

    # Too short to teach.
    if len(no_url.split()) < 5:
        return True

    return False


def _clean_source_text_v6(text: Any, limit: int = 60000) -> str:
    raw = _text(text, limit)
    if not raw:
        return ""

    lines = []
    seen = set()

    for line in raw.splitlines():
        line = _text(line, 1200).strip()
        if not line:
            continue

        # Remove URL-only lines.
        without_url = _strip_urls_v6(line).strip()
        if not without_url:
            continue

        # Remove repeated slide footer/date-only lines.
        low = without_url.lower()
        if re.fullmatch(r"[\d/:\-\s]+", low):
            continue
        if re.fullmatch(r"(pg\.?|page)?\s*\d+", low):
            continue

        # Remove repeated title/page-label noise if it repeats exactly.
        key = re.sub(r"\s+", " ", without_url).lower()
        if key in seen:
            continue
        seen.add(key)

        lines.append(without_url)

    cleaned = "\n".join(lines)

    # Collapse exact repeated paragraphs.
    paras = []
    seen_para = set()
    for para in re.split(r"\n{2,}", cleaned):
        p = _text(para, 3000)
        if not p:
            continue
        key = re.sub(r"\s+", " ", p).lower()
        if key in seen_para:
            continue
        seen_para.add(key)
        paras.append(p)

    return _text("\n".join(paras), limit)


def _split_sentences(text: str, max_sentences: int = 120) -> List[str]:
    """
    Override V5 splitter.
    Converts bullet lines into evidence sentences and removes URL/date noise.
    """
    text = _clean_source_text_v6(text, 80000)
    if not text:
        return []

    raw_parts = []
    for line in text.splitlines():
        line = _text(line, 1500).strip()
        if not line:
            continue

        # Split bullet chains like "* A * B * C" into separate facts.
        if "*" in line:
            parts = [p.strip(" -*•\t") for p in re.split(r"\s*\*\s*", line) if p.strip(" -*•\t")]
            raw_parts.extend(parts)
        else:
            raw_parts.append(line)

    parts = []
    for part in raw_parts:
        # Then split normal sentences.
        for s in re.split(r"(?<=[.!?।])\s+", part):
            s = _text(s, 1000).strip(" -*•\t")
            if not s:
                continue
            if _is_bad_quote_v6(s):
                continue
            parts.append(s)

    # If still too few because PDF is bullet-heavy, keep meaningful bullet fragments.
    if len(parts) < 3:
        for line in raw_parts:
            s = _text(line, 1000).strip(" -*•\t")
            if not _is_bad_quote_v6(s):
                parts.append(s)

    # Dedupe similar sentences.
    out = []
    seen = set()
    for p in parts:
        key = re.sub(r"[^a-z0-9]+", " ", p.lower()).strip()
        if not key or key in seen:
            continue
        seen.add(key)
        out.append(p)
        if len(out) >= max_sentences:
            break

    return out


def _quote_quality_bonus_v6(sentence: str) -> float:
    low = _text(sentence, 2000).lower()
    bonus = 0.0

    # Prefer definition/relationship/characteristic facts.
    if re.search(r"\b(is|are|means|contains|contain|joined|surrounding|using|called|defined|characteristics?)\b", low):
        bonus += 2.0
    if re.search(r"\b(fact|measure|dimension|attribute|key|foreign key|table|schema|relationship|normalized|denormalized)\b", low):
        bonus += 2.0
    if re.search(r"\b(not joined|not normalized|may not|do not|does not|avoid|confuse|mistake)\b", low):
        bonus += 1.3
    if re.search(r"\b(example|for example|such as|e\.g\.)\b", low):
        bonus += 0.8

    # Penalize leftover source/date noise.
    if "http" in low or "www." in low:
        bonus -= 3.0
    if re.search(r"\b2/6/2022\b|\bpage\b|\bpg\b", low):
        bonus -= 1.0

    return bonus


def _best_quotes(query: str, text: str, count: int = 6, max_len: int = 700) -> List[str]:
    """
    Override V5 quote picker.
    Must not choose URL-only or empty/noisy quotes.
    """
    cleaned = _clean_source_text_v6(text, 80000)
    sentences = _split_sentences(cleaned, 180)

    scored = []
    for s in sentences:
        if _is_bad_quote_v6(s):
            continue

        score = _score_text(query, s) + _quote_quality_bonus_v6(s)
        scored.append((score, s))

    scored.sort(key=lambda x: x[0], reverse=True)

    quotes = []
    seen = set()
    for score, s in scored:
        q = _text(s, max_len)
        if _is_bad_quote_v6(q):
            continue

        key = re.sub(r"[^a-z0-9]+", " ", q.lower()).strip()
        if key in seen:
            continue
        seen.add(key)

        quotes.append(q)
        if len(quotes) >= count:
            break

    # Last resort: create quote from cleaned paragraph, still not fake.
    if not quotes:
        for s in _split_sentences(cleaned, 20):
            if not _is_bad_quote_v6(s):
                quotes.append(_text(s, max_len))
                break

    return quotes


def _chunk_to_text(chunk: SourceChunk) -> str:
    """
    Override V5 chunk text builder.
    Avoid duplicating title + preview + full text repeatedly.
    """
    pieces = []

    full_text = _clean_source_text_v6(chunk.text, 60000)
    preview = _clean_source_text_v6(chunk.textPreview, 5000)
    ocr = _clean_source_text_v6(safe_dict(chunk.metadata).get("ocrText"), 20000)

    # Prefer full text; add preview only if it contains something not already present.
    if full_text:
        pieces.append(full_text)
    elif preview:
        pieces.append(preview)

    if ocr and ocr.lower() not in "\n".join(pieces).lower():
        pieces.append(ocr)

    # Add figure captions because they are teacher-useful.
    figs = safe_list(safe_dict(chunk.metadata).get("figures"))
    for fig in figs:
        caption = _text(safe_dict(fig).get("caption") or safe_dict(fig).get("text") or fig, 2000)
        caption = _clean_source_text_v6(caption, 2000)
        if caption and caption.lower() not in "\n".join(pieces).lower():
            pieces.append(caption)

    return _text("\n".join(pieces), 80000)


def _evidence_item(
    *,
    role: str,
    page: int,
    text: str,
    title: str = "",
    heading: str = "",
    resource_id: str = "",
    chunk_id: str = "",
    source_ref: str = "",
    page_ref: str = "",
    score: float = 0.0,
    quote: str = "",
    metadata: Optional[JsonDict] = None,
) -> JsonDict:
    """
    Override V5 evidence builder.
    Cleans duplicated source text and refuses URL-only quote.
    """
    cleaned_text = _clean_source_text_v6(text, 26000)
    quotes = _best_quotes("", cleaned_text, count=1, max_len=900)
    clean_quote = _text(quote, 900)

    if _is_bad_quote_v6(clean_quote):
        clean_quote = quotes[0] if quotes else _text(cleaned_text, 900)

    if _is_bad_quote_v6(clean_quote):
        clean_quote = _text(cleaned_text, 900)

    if not page_ref and resource_id and page:
        page_ref = f"resource:{resource_id}:page:{page}"
    if not source_ref and page_ref:
        source_ref = f"{page_ref}:chunk:{chunk_id or 'synthetic'}"

    ref = _source_ref(
        resource_id=resource_id,
        chunk_id=chunk_id,
        source_ref=source_ref,
        page_ref=page_ref,
        page=page,
        quote=clean_quote,
        confidence=min(0.98, max(0.35, score / 14.0 if score else 0.78)),
        role=role,
    )

    meta = safe_dict(metadata)
    flags = _content_flags(cleaned_text, meta)
    hints = _diagram_hints(cleaned_text)

    return {
        "resourceId": _text(resource_id, 260),
        "chunkId": _text(chunk_id, 260),
        "sourceRef": _text(source_ref, 420),
        "pageRef": _text(page_ref, 420),
        "page": int(page or 0),
        "heading": _text(heading, 260),
        "title": _text(title, 260),
        "text": cleaned_text,
        "textPreview": _text(cleaned_text, 1600),
        "quote": clean_quote,
        "score": round(float(score or 0.0), 4),
        "sourceRefs": [ref] if not _is_bad_quote_v6(clean_quote) else [],
        "evidenceRole": role,
        "contentFlags": flags,
        "diagramHints": hints,
        "metadata": {
            **meta,
            "agent": "RagRetrievalAgent",
            "evidenceRole": role,
            "richEvidenceV6": True,
            "quoteCleanedV6": True,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


def _refs_from_evidence(groups: Iterable[List[JsonDict]]) -> List[JsonDict]:
    """
    Override V5 ref collector.
    Drop refs with empty/URL-only quotes.
    """
    refs = []
    for group in groups:
        for item in group:
            item = safe_dict(item)
            for r in safe_list(item.get("sourceRefs")):
                r = safe_dict(r)
                if _is_bad_quote_v6(r.get("quote")):
                    continue
                refs.append(r)

            if item.get("quote") and not _is_bad_quote_v6(item.get("quote")):
                refs.append(
                    _source_ref(
                        resource_id=item.get("resourceId"),
                        chunk_id=item.get("chunkId"),
                        source_ref=item.get("sourceRef"),
                        page_ref=item.get("pageRef"),
                        page=int(item.get("page") or 0),
                        quote=item.get("quote"),
                        confidence=0.82,
                        role=item.get("evidenceRole"),
                    )
                )

    return dedupe_source_refs(refs)


# Patch normalize_output to mark V6 metadata while preserving class behavior.
_ORIG_RAG_NORMALIZE_OUTPUT_V6 = RagRetrievalAgent.normalize_output


def _rag_normalize_output_v6(self, raw: JsonDict, payload: JsonDict, context: AgentContext) -> JsonDict:
    out = _ORIG_RAG_NORMALIZE_OUTPUT_V6(self, raw, payload, context)

    # Clean final evidence groups again before orchestrator sees them.
    for key in ["selectedEvidence", "samePageEvidence", "nearbyEvidence", "relatedEvidence", "comparisonEvidence"]:
        cleaned_items = []
        for item in safe_list(out.get(key)):
            item = safe_dict(item)
            item["text"] = _clean_source_text_v6(item.get("text"), 26000)
            item["textPreview"] = _text(item.get("text"), 1600)

            quote = item.get("quote")
            if _is_bad_quote_v6(quote):
                qs = _best_quotes(out.get("query") or "", item.get("text"), count=1)
                quote = qs[0] if qs else _text(item.get("text"), 900)

            item["quote"] = quote
            item["sourceRefs"] = [
                r for r in safe_list(item.get("sourceRefs"))
                if not _is_bad_quote_v6(safe_dict(r).get("quote"))
            ]

            if not item["sourceRefs"] and not _is_bad_quote_v6(quote):
                item["sourceRefs"] = [
                    _source_ref(
                        resource_id=item.get("resourceId"),
                        chunk_id=item.get("chunkId"),
                        source_ref=item.get("sourceRef"),
                        page_ref=item.get("pageRef"),
                        page=int(item.get("page") or 0),
                        quote=quote,
                        confidence=0.82,
                        role=item.get("evidenceRole") or key,
                    )
                ]

            cleaned_items.append(item)

        out[key] = cleaned_items

    refs = _refs_from_evidence(
        [
            safe_list(out.get("selectedEvidence")),
            safe_list(out.get("samePageEvidence")),
            safe_list(out.get("nearbyEvidence")),
            safe_list(out.get("relatedEvidence")),
            safe_list(out.get("comparisonEvidence")),
        ]
    )
    out["sourceRefs"] = refs

    st = safe_dict(out.get("sourceTruthPacket"))
    st["selectedEvidence"] = out["selectedEvidence"]
    st["samePageEvidence"] = out["samePageEvidence"]
    st["nearbyEvidence"] = out["nearbyEvidence"]
    st["relatedEvidence"] = out["relatedEvidence"]
    st["comparisonEvidence"] = out["comparisonEvidence"]
    st["sourceRefs"] = refs
    st["metadata"] = {
        **safe_dict(st.get("metadata")),
        "sourceTruthPacketV6": True,
        "quoteCleaningV6": True,
        "sourceRefCount": len(refs),
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }
    out["sourceTruthPacket"] = st

    out["metadata"] = {
        **safe_dict(out.get("metadata")),
        "richEvidenceExpansionV6": True,
        "quoteCleaningV6": True,
        "sourceRefCount": len(refs),
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }
    return out


RagRetrievalAgent.normalize_output = _rag_normalize_output_v6


# === RAG_TEACHER_QUALITY_V7 ===
# Purpose:
# V5/V6 may increase evidence count but still keep URL-only quotes,
# duplicated page text, and empty sourceRefs. V7 makes RAG output teacher-ready.
#
# No fake fallback.
# No hardcoded Star Schema.
# Only uses real source text already present in payload/chunks/pageContexts.

_URL_ONLY_RE_V7 = re.compile(r"^\s*(https?://\S+|www\.\S+)\s*$", re.I)
_URL_RE_V7 = re.compile(r"https?://\S+|www\.\S+", re.I)


def _rag_v7_text(value, limit=4000):
    try:
        return clean_text(value or "", limit)
    except Exception:
        return str(value or "")[:limit]


def _rag_v7_strip_urls(value):
    return _URL_RE_V7.sub(" ", _rag_v7_text(value, 200000))


def _rag_v7_bad_quote(value):
    q = _rag_v7_text(value, 3000).strip()
    if not q:
        return True

    if _URL_ONLY_RE_V7.match(q):
        return True

    no_url = _rag_v7_strip_urls(q).strip()
    if len(no_url.split()) < 5:
        return True

    low = no_url.lower()
    if re.fullmatch(r"[\d/:\-\s]+", low):
        return True
    if re.fullmatch(r"(page|pg\.?)?\s*\d+", low):
        return True

    return False


def _rag_v7_clean_source(value, limit=80000):
    raw = _rag_v7_text(value, limit)
    if not raw:
        return ""

    lines = []
    seen = set()

    for line in raw.splitlines():
        line = _rag_v7_text(line, 1800).strip()
        if not line:
            continue

        # Remove URL-only lines, but keep concept sentence after URL if present.
        line_no_url = _rag_v7_strip_urls(line).strip()
        if not line_no_url:
            continue

        low = line_no_url.lower()
        if re.fullmatch(r"[\d/:\-\s]+", low):
            continue
        if re.fullmatch(r"(page|pg\.?)?\s*\d+", low):
            continue

        key = re.sub(r"\s+", " ", line_no_url).lower().strip()
        if key in seen:
            continue
        seen.add(key)
        lines.append(line_no_url)

    cleaned = "\n".join(lines)

    # Remove exact repeated paragraphs/chunks.
    paras = []
    seen_para = set()
    for para in re.split(r"\n{2,}", cleaned):
        p = _rag_v7_text(para, 5000)
        if not p:
            continue
        key = re.sub(r"\s+", " ", p).lower().strip()
        if key in seen_para:
            continue
        seen_para.add(key)
        paras.append(p)

    return _rag_v7_text("\n".join(paras), limit)


def _rag_v7_sentence_candidates(value):
    text = _rag_v7_clean_source(value, 100000)
    if not text:
        return []

    parts = []
    for line in text.splitlines():
        line = _rag_v7_text(line, 2000).strip()
        if not line:
            continue

        # Bullet-heavy PDF pages: split "* A * B * C".
        if "*" in line:
            bits = [b.strip(" -*•\t") for b in re.split(r"\s*\*\s*", line) if b.strip(" -*•\t")]
            parts.extend(bits)
        else:
            parts.append(line)

    candidates = []
    for part in parts:
        # Split ordinary sentences.
        for sent in re.split(r"(?<=[.!?।])\s+", part):
            sent = _rag_v7_text(sent, 1200).strip(" -*•\t")
            if not sent:
                continue
            if _rag_v7_bad_quote(sent):
                continue
            candidates.append(sent)

    # Deduplicate.
    out = []
    seen = set()
    for c in candidates:
        key = re.sub(r"[^a-z0-9]+", " ", c.lower()).strip()
        if not key or key in seen:
            continue
        seen.add(key)
        out.append(c)

    return out


def _rag_v7_quality_score(query, sentence):
    low = _rag_v7_text(sentence, 3000).lower()
    score = _score_text(query, sentence)

    # Prefer factual teaching statements.
    if re.search(r"\b(is|are|means|contains|contain|joined|surrounding|using|called|defined|characteristic|benefit|drawback)\b", low):
        score += 2.0
    if re.search(r"\b(fact|measure|dimension|attribute|key|foreign key|table|schema|normalized|denormalized|relationship)\b", low):
        score += 2.0
    if re.search(r"\b(not joined|not normalized|not be|may not|do not|does not)\b", low):
        score += 1.5
    if re.search(r"\b(example|for example|such as|e\.g\.)\b", low):
        score += 0.8

    # Penalize source noise.
    if "http" in low or "www." in low:
        score -= 4.0
    if re.search(r"\b2/6/2022\b|\bpage\b|\bpg\b", low):
        score -= 1.0

    return score


def _best_quotes(query: str, text: str, count: int = 6, max_len: int = 700) -> List[str]:
    """
    V7 override: choose teacher-useful source facts, not URLs.
    """
    candidates = _rag_v7_sentence_candidates(text)
    scored = []

    for sent in candidates:
        if _rag_v7_bad_quote(sent):
            continue
        scored.append((_rag_v7_quality_score(query, sent), sent))

    scored.sort(key=lambda x: x[0], reverse=True)

    quotes = []
    seen = set()
    for _score, sent in scored:
        q = _rag_v7_text(sent, max_len)
        if _rag_v7_bad_quote(q):
            continue
        key = re.sub(r"[^a-z0-9]+", " ", q.lower()).strip()
        if key in seen:
            continue
        seen.add(key)
        quotes.append(q)
        if len(quotes) >= count:
            break

    return quotes


def _chunk_to_text(chunk: SourceChunk) -> str:
    """
    V7 override: avoid duplicated preview/full text/OCR.
    """
    parts = []

    full_text = _rag_v7_clean_source(chunk.text, 70000)
    preview = _rag_v7_clean_source(chunk.textPreview, 7000)
    ocr = _rag_v7_clean_source(safe_dict(chunk.metadata).get("ocrText"), 30000)

    if full_text:
        parts.append(full_text)
    elif preview:
        parts.append(preview)

    joined = "\n".join(parts).lower()
    if ocr and ocr.lower() not in joined:
        parts.append(ocr)

    # Add figure captions, because they are useful for board/vision handoff.
    figs = safe_list(safe_dict(chunk.metadata).get("figures"))
    for fig in figs:
        f = safe_dict(fig)
        caption = _rag_v7_clean_source(
            f.get("caption") or f.get("text") or f.get("figure") or fig,
            2500,
        )
        if caption and caption.lower() not in "\n".join(parts).lower():
            parts.append(caption)

    return _rag_v7_text("\n".join(parts), 90000)


def _source_ref(
    *,
    resource_id: str = "",
    chunk_id: str = "",
    source_ref: str = "",
    page_ref: str = "",
    page: int = 0,
    quote: str = "",
    confidence: float = 0.8,
    role: str = "",
) -> JsonDict:
    """
    V7 override: never create sourceRef with empty or URL-only quote.
    """
    clean_quote = _rag_v7_text(quote, 900)
    if _rag_v7_bad_quote(clean_quote):
        clean_quote = ""

    return {
        "resourceId": _rag_v7_text(resource_id, 260),
        "chunkId": _rag_v7_text(chunk_id, 260),
        "sourceRef": _rag_v7_text(source_ref, 420),
        "pageRef": _rag_v7_text(page_ref, 420),
        "page": int(page or 0),
        "quote": clean_quote,
        "confidence": round(float(confidence or 0.0), 4),
        "evidenceRole": _rag_v7_text(role, 120),
    }


def _evidence_item(
    *,
    role: str,
    page: int,
    text: str,
    title: str = "",
    heading: str = "",
    resource_id: str = "",
    chunk_id: str = "",
    source_ref: str = "",
    page_ref: str = "",
    score: float = 0.0,
    quote: str = "",
    metadata: Optional[JsonDict] = None,
) -> JsonDict:
    """
    V7 override: evidence text and quote are cleaned teacher-ready facts.
    """
    cleaned_text = _rag_v7_clean_source(text, 26000)
    clean_quote = _rag_v7_text(quote, 900)

    if _rag_v7_bad_quote(clean_quote):
        qlist = _best_quotes("", cleaned_text, count=1, max_len=900)
        clean_quote = qlist[0] if qlist else ""

    if not page_ref and resource_id and page:
        page_ref = f"resource:{resource_id}:page:{page}"
    if not source_ref and page_ref:
        source_ref = f"{page_ref}:chunk:{chunk_id or 'synthetic'}"

    ref = _source_ref(
        resource_id=resource_id,
        chunk_id=chunk_id,
        source_ref=source_ref,
        page_ref=page_ref,
        page=page,
        quote=clean_quote,
        confidence=min(0.98, max(0.35, score / 14.0 if score else 0.78)),
        role=role,
    )

    meta = safe_dict(metadata)
    flags = _content_flags(cleaned_text, meta)
    hints = _diagram_hints(cleaned_text)

    return {
        "resourceId": _rag_v7_text(resource_id, 260),
        "chunkId": _rag_v7_text(chunk_id, 260),
        "sourceRef": _rag_v7_text(source_ref, 420),
        "pageRef": _rag_v7_text(page_ref, 420),
        "page": int(page or 0),
        "heading": _rag_v7_text(heading, 260),
        "title": _rag_v7_text(title, 260),
        "text": cleaned_text,
        "textPreview": _rag_v7_text(cleaned_text, 1600),
        "quote": clean_quote,
        "score": round(float(score or 0.0), 4),
        "sourceRefs": [ref] if ref.get("quote") else [],
        "evidenceRole": role,
        "contentFlags": flags,
        "diagramHints": hints,
        "metadata": {
            **meta,
            "agent": "RagRetrievalAgent",
            "evidenceRole": role,
            "richEvidenceV7": True,
            "teacherQualityQuoteV7": True,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


def _refs_from_evidence(groups: Iterable[List[JsonDict]]) -> List[JsonDict]:
    """
    V7 override: only meaningful sourceRefs survive.
    """
    refs = []

    for group in groups:
        for item in group:
            item = safe_dict(item)

            for r in safe_list(item.get("sourceRefs")):
                r = safe_dict(r)
                if not _rag_v7_bad_quote(r.get("quote")):
                    refs.append(r)

            q = item.get("quote")
            if not _rag_v7_bad_quote(q):
                refs.append(
                    _source_ref(
                        resource_id=item.get("resourceId"),
                        chunk_id=item.get("chunkId"),
                        source_ref=item.get("sourceRef"),
                        page_ref=item.get("pageRef"),
                        page=int(item.get("page") or 0),
                        quote=q,
                        confidence=0.86,
                        role=item.get("evidenceRole"),
                    )
                )

    refs = [r for r in refs if not _rag_v7_bad_quote(safe_dict(r).get("quote"))]
    return dedupe_source_refs(refs)


_ORIG_RAG_NORMALIZE_OUTPUT_V7 = RagRetrievalAgent.normalize_output


def _rag_normalize_output_v7(self, raw: JsonDict, payload: JsonDict, context: AgentContext) -> JsonDict:
    out = _ORIG_RAG_NORMALIZE_OUTPUT_V7(self, raw, payload, context)

    query = out.get("query") or _query(payload, context)

    for key in [
        "selectedEvidence",
        "samePageEvidence",
        "nearbyEvidence",
        "relatedEvidence",
        "comparisonEvidence",
    ]:
        cleaned_group = []

        for item in safe_list(out.get(key)):
            item = safe_dict(item)
            item["text"] = _rag_v7_clean_source(item.get("text"), 26000)
            item["textPreview"] = _rag_v7_text(item.get("text"), 1600)

            quote = item.get("quote")
            if _rag_v7_bad_quote(quote):
                qlist = _best_quotes(query, item.get("text"), count=1, max_len=900)
                quote = qlist[0] if qlist else ""

            item["quote"] = quote

            # Rebuild sourceRefs from the cleaned quote.
            item["sourceRefs"] = []
            if not _rag_v7_bad_quote(quote):
                item["sourceRefs"] = [
                    _source_ref(
                        resource_id=item.get("resourceId") or payload.get("resourceId"),
                        chunk_id=item.get("chunkId"),
                        source_ref=item.get("sourceRef"),
                        page_ref=item.get("pageRef"),
                        page=int(item.get("page") or 0),
                        quote=quote,
                        confidence=0.86,
                        role=item.get("evidenceRole") or key,
                    )
                ]

            item["metadata"] = {
                **safe_dict(item.get("metadata")),
                "teacherQualityQuoteV7": True,
                "fallbackUsed": False,
                "usedSmartFallback": False,
            }

            # Keep evidence even if sourceRefs empty, but sourceRefs count will only use clean refs.
            cleaned_group.append(item)

        out[key] = cleaned_group

    refs = _refs_from_evidence(
        [
            safe_list(out.get("selectedEvidence")),
            safe_list(out.get("samePageEvidence")),
            safe_list(out.get("nearbyEvidence")),
            safe_list(out.get("relatedEvidence")),
            safe_list(out.get("comparisonEvidence")),
        ]
    )
    out["sourceRefs"] = refs

    st = safe_dict(out.get("sourceTruthPacket"))
    st["selectedEvidence"] = out["selectedEvidence"]
    st["samePageEvidence"] = out["samePageEvidence"]
    st["nearbyEvidence"] = out["nearbyEvidence"]
    st["relatedEvidence"] = out["relatedEvidence"]
    st["comparisonEvidence"] = out["comparisonEvidence"]
    st["sourceRefs"] = refs
    st["metadata"] = {
        **safe_dict(st.get("metadata")),
        "sourceTruthPacketV7": True,
        "teacherQualityQuoteV7": True,
        "sourceRefCount": len(refs),
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }
    out["sourceTruthPacket"] = st

    out["metadata"] = {
        **safe_dict(out.get("metadata")),
        "richEvidenceExpansionV7": True,
        "teacherQualityQuoteV7": True,
        "sourceRefCount": len(refs),
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }

    return out


RagRetrievalAgent.normalize_output = _rag_normalize_output_v7
