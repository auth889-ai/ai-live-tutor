def _evidence_item(
    *,
    role: str,
    page: int,
    text: str,
    title: str = "",
    heading: str = "",
    resource_id: str = "",
    chunk_id: str = "",
    source_ref: str = "",
    page_ref: str = "",
    score: float = 0.0,
    quote: str = "",
    metadata: Optional[JsonDict] = None,
) -> JsonDict:
    text = _text(text, 26000)
    quote = _text(quote or text, 900)

    if not page_ref and resource_id and page:
        page_ref = f"resource:{resource_id}:page:{page}"
    if not source_ref and page_ref:
        source_ref = f"{page_ref}:chunk:{chunk_id or 'synthetic'}"

    ref = _source_ref(
        resource_id=resource_id,
        chunk_id=chunk_id,
        source_ref=source_ref,
        page_ref=page_ref,
        page=page,
        quote=quote,
        confidence=min(0.98, max(0.35, score / 14.0 if score else 0.78)),
        role=role,
    )

    meta = safe_dict(metadata)
    flags = _content_flags(text, meta)
    hints = _diagram_hints(text)

    return {
        "resourceId": _text(resource_id, 260),
        "chunkId": _text(chunk_id, 260),
        "sourceRef": _text(source_ref, 420),
        "pageRef": _text(page_ref, 420),
        "page": int(page or 0),
        "heading": _text(heading, 260),
        "title": _text(title, 260),
        "text": text,
        "textPreview": _text(text, 1600),
        "quote": quote,
        "score": round(float(score or 0.0), 4),
        "sourceRefs": [ref],
        "evidenceRole": role,
        "contentFlags": flags,
        "diagramHints": hints,
        "metadata": {
            **meta,
            "agent": "RagRetrievalAgent",
            "evidenceRole": role,
            "richEvidenceV5": True,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


def _normalize_existing_evidence(items: List[Any], query: str, role: str) -> List[JsonDict]:
    out = []
    for raw in items:
        item = safe_dict(raw)
        if not item:
            continue

        page = int(item.get("page") or item.get("pageNumber") or 0)
        text = _text(
            item.get("text")
            or item.get("fullText")
            or item.get("textPreview")
            or item.get("quote")
            or item.get("ocrText")
            or "",
            26000,
        )

        if not text:
            refs = safe_list(item.get("sourceRefs"))
            text = " ".join(_text(safe_dict(r).get("quote"), 900) for r in refs)

        if not text:
            continue

        quotes = _best_quotes(query, text, count=1)
        quote = quotes[0] if quotes else _text(text, 700)

        out.append(
            _evidence_item(
                role=role,
                page=page,
                text=text,
                title=item.get("title") or item.get("pageTitle"),
                heading=item.get("heading"),
                resource_id=item.get("resourceId"),
                chunk_id=item.get("chunkId") or item.get("id"),
                source_ref=item.get("sourceRef"),
                page_ref=item.get("pageRef"),
                score=float(item.get("score") or _score_text(query, text)),
                quote=quote,
                metadata=safe_dict(item.get("metadata")),
            )
        )

    return out


def _chunk_evidence(query: str, chunks: List[SourceChunk], payload: JsonDict) -> Tuple[List[JsonDict], List[JsonDict], List[JsonDict], List[JsonDict]]:
    selected_pages = set(_selected_pages(payload))
    node = _node(payload)

    selected_chunk_ids = set()
    selected_source_refs = set()
    for ref in safe_list(node.get("sourceRefs")) + safe_list(payload.get("sourceRefs")):
        r = safe_dict(ref)
        if _text(r.get("chunkId")):
            selected_chunk_ids.add(_text(r.get("chunkId"), 260))
        if _text(r.get("sourceRef")):
            selected_source_refs.add(_text(r.get("sourceRef"), 420))

    scored = []
    for chunk in chunks:
        text = _chunk_to_text(chunk)
        score = _score_text(query, text)

        if chunk.chunkId in selected_chunk_ids:
            score += 12
        if chunk.sourceRef in selected_source_refs:
            score += 10
        if int(chunk.page or 0) in selected_pages:
            score += 7

        flags = _content_flags(text, safe_dict(chunk.metadata))
        if flags["hasDefinition"]:
            score += 1.2
        if flags["hasFigureOrDiagram"]:
            score += 1.1
        if flags["hasExample"]:
            score += 0.8

        scored.append((score, chunk))

    scored.sort(key=lambda x: x[0], reverse=True)

    selected = []
    same_page = []
    nearby = []
    related = []

    for score, chunk in scored[:120]:
        page = int(chunk.page or 0)
        text = _chunk_to_text(chunk)
        quotes = _best_quotes(query, text, count=1)
        quote = quotes[0] if quotes else _text(text, 700)

        if page in selected_pages or chunk.chunkId in selected_chunk_ids or chunk.sourceRef in selected_source_refs:
            role = "selectedEvidence"
            target = selected
        elif selected_pages and any(abs(page - p) <= 1 for p in selected_pages):
            role = "nearbyEvidence"
            target = nearby
        elif selected_pages and page in selected_pages:
            role = "samePageEvidence"
            target = same_page
        else:
            role = "relatedEvidence"
            target = related

        target.append(
            _evidence_item(
                role=role,
                page=page,
                text=text,
                title=chunk.title,
                heading=chunk.heading,
                resource_id=chunk.resourceId,
                chunk_id=chunk.chunkId,
                source_ref=chunk.sourceRef,
                page_ref=chunk.pageRef,
                score=score,
                quote=quote,
                metadata=safe_dict(chunk.metadata),
            )
        )

    return selected, same_page, nearby, related


def _page_context_evidence(query: str, payload: JsonDict) -> Tuple[List[JsonDict], List[JsonDict], List[JsonDict], List[JsonDict]]:
    selected_pages = set(_selected_pages(payload))
    contexts = []

    for key in ["pageContexts", "selectedPageContexts"]:
        contexts.extend(safe_list(payload.get(key)))

    source_truth = safe_dict(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    contexts.extend(safe_list(source_truth.get("pageContexts")))

    selected = []
    same_page = []
    nearby = []
    comparison = []

    for raw in contexts:
        ctx = safe_dict(raw)
        if not ctx:
            continue

        page = int(ctx.get("page") or ctx.get("pageNumber") or 0)
        full_text = _text(
            ctx.get("fullText")
            or ctx.get("combinedTextExcerpt")
            or ctx.get("text")
            or ctx.get("ocrText")
            or "",
            50000,
        )

        if not full_text:
            chunks = safe_list(ctx.get("chunks"))
            full_text = "\n".join(_text(safe_dict(c).get("text") or safe_dict(c).get("textPreview"), 12000) for c in chunks)

        if not full_text:
            continue

        score = _score_text(query, full_text)
        role = "relatedEvidence"

        relation = _text(ctx.get("relation"), 120).lower()
        if page in selected_pages or "selected" in relation:
            role = "samePageEvidence"
            score += 6
            target = same_page
        elif selected_pages and any(abs(page - p) <= 1 for p in selected_pages):
            role = "nearbyEvidence"
            score += 3
            target = nearby
        elif "comparison" in relation:
            role = "comparisonEvidence"
            target = comparison
        else:
            target = nearby if selected_pages and any(abs(page - p) <= 2 for p in selected_pages) else comparison

        quotes = _best_quotes(query, full_text, count=2)
        if not quotes:
            quotes = [_text(full_text, 700)]

        for i, quote in enumerate(quotes[:2]):
            target.append(
                _evidence_item(
                    role=role,
                    page=page,
                    text=full_text,
                    title=ctx.get("pageTitle") or ctx.get("title"),
                    heading=ctx.get("heading"),
                    resource_id=ctx.get("resourceId") or payload.get("resourceId"),
                    chunk_id=f"pagectx_p{page}_{i + 1}",
                    source_ref=f"resource:{payload.get('resourceId')}:page:{page}:pagectx:{i + 1}",
                    page_ref=f"resource:{payload.get('resourceId')}:page:{page}",
                    score=score,
                    quote=quote,
                    metadata=safe_dict(ctx.get("metadata")),
                )
            )

    return selected, same_page, nearby, comparison


def _full_page_evidence(query: str, payload: JsonDict) -> List[JsonDict]:
    text = _text(
        payload.get("selectedPageFullText")
        or safe_dict(payload.get("sourceTruth")).get("selectedPageFullText")
        or safe_dict(payload.get("sourceTruthPacket")).get("selectedPageFullText")
        or "",
        80000,
    )

    if not text:
        return []

    pages = _selected_pages(payload)
    page = pages[0] if pages else int(payload.get("page") or 0)
    quotes = _best_quotes(query, text, count=8, max_len=750)
    out = []

    for i, quote in enumerate(quotes):
        out.append(
            _evidence_item(
                role="selectedEvidence",
                page=page,
                text=text,
                title=f"{_title(payload)} — selected page evidence",
                heading="Selected page full text",
                resource_id=payload.get("resourceId"),
                chunk_id=f"selected_page_full_text_{page}_{i + 1}",
                source_ref=f"resource:{payload.get('resourceId')}:page:{page}:fulltext:{i + 1}",
                page_ref=f"resource:{payload.get('resourceId')}:page:{page}",
                score=_score_text(query, quote) + 8,
                quote=quote,
                metadata={
                    "source": "selectedPageFullText",
                    "pdfExtractedTextIsTruth": True,
                    "evidenceExpandedFromFullPageText": True,
                },
            )
        )

    return out


def _node_source_ref_evidence(query: str, payload: JsonDict) -> List[JsonDict]:
    node = _node(payload)
    out = []
    for i, ref in enumerate(safe_list(node.get("sourceRefs")) + safe_list(payload.get("sourceRefs"))):
        r = safe_dict(ref)
        quote = _text(r.get("quote"), 900)
        if not quote:
            continue

        out.append(
            _evidence_item(
                role="selectedEvidence",
                page=int(r.get("page") or 0),
                text=quote,
                title=_title(payload),
                heading="Selected node sourceRef",
                resource_id=r.get("resourceId") or payload.get("resourceId"),
                chunk_id=r.get("chunkId") or f"node_ref_{i + 1}",
                source_ref=r.get("sourceRef"),
                page_ref=r.get("pageRef"),
                score=_score_text(query, quote) + 10,
                quote=quote,
                metadata={
                    "source": "selectedNode.sourceRefs",
                    "selectedNodeSourceRef": True,
                },
            )
        )

    return out


def _dedupe_evidence(items: List[JsonDict], limit: int = 30) -> List[JsonDict]:
    seen = set()
    out = []

    for item in items:
        item = safe_dict(item)
        quote = _text(item.get("quote") or safe_list(item.get("sourceRefs"))[0].get("quote") if safe_list(item.get("sourceRefs")) else "", 900)
        key = (
            int(item.get("page") or 0),
            _text(item.get("chunkId"), 260),
            _text(quote[:160], 180).lower(),
        )
        if key in seen:
            continue
        seen.add(key)
        out.append(item)
        if len(out) >= limit:
            break

    return out


def _refs_from_evidence(groups: Iterable[List[JsonDict]]) -> List[JsonDict]:
    refs = []
    for group in groups:
        for item in group:
            refs.extend([safe_dict(r) for r in safe_list(safe_dict(item).get("sourceRefs"))])
            if safe_dict(item).get("quote") and not safe_list(safe_dict(item).get("sourceRefs")):
                refs.append(
                    _source_ref(
                        resource_id=item.get("resourceId"),
                        chunk_id=item.get("chunkId"),
                        source_ref=item.get("sourceRef"),
                        page_ref=item.get("pageRef"),
                        page=int(item.get("page") or 0),
                        quote=item.get("quote"),
                        confidence=0.78,
                        role=item.get("evidenceRole"),
                    )
                )

    refs = [r for r in refs if _text(r.get("quote")) or _text(r.get("sourceRef"))]
    return dedupe_source_refs(refs)


def _build_page_contexts(payload: JsonDict, evidence_groups: List[List[JsonDict]]) -> List[JsonDict]:
    by_page: Dict[int, List[JsonDict]] = defaultdict(list)

    for group in evidence_groups:
        for item in group:
            page = int(safe_dict(item).get("page") or 0)
            if page > 0:
                by_page[page].append(safe_dict(item))

    contexts = []
    existing = []

    for key in ["pageContexts"]:
        existing.extend(safe_list(payload.get(key)))
    source_truth = safe_dict(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    existing.extend(safe_list(source_truth.get("pageContexts")))

    existing_pages = set()
    for ctx in existing:
        c = safe_dict(ctx)
        try:
            p = int(c.get("page") or 0)
        except Exception:
            p = 0
        if p > 0:
            existing_pages.add(p)
            contexts.append(c)

    for page, items in sorted(by_page.items()):
        if page in existing_pages:
            continue
        contexts.append(
            {
                "page": page,
                "chunkCount": len(items),
                "combinedTextExcerpt": _text(" ".join(_text(x.get("text"), 2500) for x in items), 12000),
                "sourceRefs": _refs_from_evidence([items])[:12],
                "metadata": {
                    "builtByRagRetrievalAgentV5": True,
                    "fallbackUsed": False,
                },
            }
        )

    return contexts[:30]


