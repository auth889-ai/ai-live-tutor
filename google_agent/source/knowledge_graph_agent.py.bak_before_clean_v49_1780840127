def _kg48_pollution_count(output: JsonDict, payload: JsonDict) -> int:
    bad = 0
    for ref in _l(output.get("sourceRefs")):
        q = _t(_d(ref).get("quote"), 1000)
        if _kg48_is_competing_ref(q, payload):
            bad += 1

    for group in ["nodes", "edges", "teachingPath", "misconceptionMap"]:
        for item in _l(output.get(group)):
            for ref in _l(_d(item).get("sourceRefs")):
                q = _t(_d(ref).get("quote"), 1000)
                if _kg48_is_competing_ref(q, payload):
                    bad += 1
    return bad


def _kg48_normalize_output(self, raw: JsonDict, payload: JsonDict, context: AgentContext) -> JsonDict:
    previous = _PREV_KG_NORMALIZE_OUTPUT_V48_FINAL(self, raw, payload, context)

    nodes = _l(previous.get("nodes"))
    edges = _l(previous.get("edges"))
    path = _l(previous.get("teachingPath"))
    pollution = _kg48_pollution_count(previous, payload)

    meta = _d(previous.get("metadata"))
    qs = _d(previous.get("qualitySignals"))

    weak = (
        len(nodes) < 6
        or len(edges) < 6
        or len(path) < 5
        or pollution > 0
        or not qs.get("readyForTeachingStrategy")
        or meta.get("geminiReturnedEmptyOrWeak")
        or meta.get("sourceDerivedKGRepairV46")
    )

    if weak:
        upgraded = _kg48_build_teacher_grade_kg(payload, previous)
        upgraded["metadata"]["previousPollutionCountV48"] = pollution
        upgraded["qualitySignals"]["previousPollutionCountV48"] = pollution
        return upgraded

    previous["metadata"] = {
        **_d(previous.get("metadata")),
        "teacherGradeKGV48FinalAvailable": True,
        "kgCleanForTeachingStrategy": True,
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }
    previous["qualitySignals"] = {
        **_d(previous.get("qualitySignals")),
        "teacherGradeKGV48FinalAvailable": True,
        "kgCleanForTeachingStrategy": True,
        "readyForTeachingStrategy": True,
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }
    return previous


KnowledgeGraphAgent.normalize_output = _kg48_normalize_output
