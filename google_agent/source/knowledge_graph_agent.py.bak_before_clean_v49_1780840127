}

COMPARISON_PHASES = {"comparison", "contrast", "compare"}
STOP_WORDS = {
    "the", "and", "that", "this", "with", "from", "into", "using", "used",
    "table", "tables", "schema", "data", "concept", "page", "each", "has",
    "have", "will", "would", "should", "could", "there", "their", "about",
}


def _t(value: Any, limit: int = 1200) -> str:
    try:
        return clean_text(value or "", limit)
    except Exception:
        return str(value or "")[:limit]


def _d(value: Any) -> JsonDict:
    try:
        return safe_dict(value)
    except Exception:
        return value if isinstance(value, dict) else {}


def _l(value: Any) -> List[Any]:
    try:
        return safe_list(value)
    except Exception:
        return value if isinstance(value, list) else []


def _json(value: Any, limit: int = 80000) -> str:
    try:
        return clean_text(json.dumps(value, ensure_ascii=False, indent=2), limit)
    except Exception:
        return clean_text(value, limit)


def _slug(value: Any, fallback: str) -> str:
    try:
        return normalize_id(value, fallback)
    except Exception:
        s = re.sub(r"[^a-zA-Z0-9]+", "_", str(value or "").lower()).strip("_")
        return s or fallback


def _words(value: Any) -> List[str]:
    text = _t(value, 5000).lower()
    return [
        w for w in re.findall(r"[a-zA-Z0-9_]+", text)
        if len(w) >= 3 and w not in STOP_WORDS
    ]


def _selected_node(payload: JsonDict) -> JsonDict:
    node = _d(payload.get("selectedNode") or payload.get("node"))
    rich = _d(node.get("richSourcePack") or _d(node.get("metadata")).get("richSourcePack"))

    pages = (
        _l(node.get("pages"))
        or _l(node.get("pageRefs"))
        or _l(node.get("selectedPages"))
        or _l(rich.get("pages"))
        or _l(rich.get("pageRefs"))
        or _l(payload.get("selectedPages"))
    )
    if not pages and payload.get("selectedPage"):
        pages = [payload.get("selectedPage")]

    node_id = _t(node.get("nodeId") or node.get("id") or payload.get("nodeId"), 180)
    title = _t(
        node.get("title")
        or node.get("label")
        or node.get("shortDefinition")
        or payload.get("title")
        or payload.get("question")
        or "Selected concept",
        280,
    )

    return {
        **node,
        "nodeId": node_id,
        "id": node.get("id") or node_id,
        "title": title,
        "label": node.get("label") or title,
        "pages": pages,
        "richSourcePack": rich or node.get("richSourcePack") or {},
    }


def _selected_pages(payload: JsonDict) -> List[int]:
    pages: List[int] = []

    def add_page(p: Any) -> None:
        try:
            if p is not None and str(p).strip() != "":
                pages.append(int(p))
        except Exception:
            pass

    node = _selected_node(payload)
    for p in _l(node.get("pages")):
        add_page(p)

    rich = _d(node.get("richSourcePack"))
    for p in _l(rich.get("pages") or rich.get("pageRefs")):
        add_page(p)

    for key in ["selectedEvidence", "samePageEvidence"]:
        for item in _l(payload.get(key)):
            add_page(_d(item).get("page"))

    source = _d(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    for key in ["selectedEvidence", "samePageEvidence"]:
        for item in _l(source.get(key)):
            add_page(_d(item).get("page"))

    return sorted(list(dict.fromkeys(pages)))


def _comparison_marker(value: Any) -> bool:
    t = _t(value, 2000).lower()
    return any(x in t for x in [
        "compare", "comparison", "contrast", "contrasts", "unlike",
        "whereas", "versus", " vs ", "difference between", "different from",
    ])


def _concepts(payload: JsonDict) -> List[JsonDict]:
    ce = _d(payload.get("conceptExtraction"))
    raw_items = _l(ce.get("concepts") or payload.get("concepts"))
    out: List[JsonDict] = []

    for index, raw in enumerate(raw_items):
        c = _d(raw)
        label = _t(c.get("label") or c.get("title") or c.get("name"), 260)
        if not label:
            continue

        concept_id = _slug(c.get("conceptId") or c.get("id") or label, f"concept_{index + 1}")
        source_role = _t(c.get("sourceRole") or c.get("teachingRole"), 140).lower()

        comparison = bool(
            c.get("comparisonOnly")
            or source_role in {"comparison", "contrast", "compare"}
            or _comparison_marker(c.get("relationshipToSelectedNode") or c.get("role"))
        )

        out.append({
            **c,
            "conceptId": concept_id,
            "label": label,
            "comparisonOnly": comparison,
        })

    return out


def _visual_packet(payload: JsonDict) -> JsonDict:
    vision = _d(payload.get("selectedPageVision"))
    visual_truth = _d(payload.get("visualTruth"))
    lesson_input = _d(vision.get("visualLessonInput"))

    return _d(
        payload.get("visualTeacherPacket")
        or payload.get("richVisualTeacherPacket")
        or visual_truth.get("visualTeacherPacket")
        or vision.get("visualTeacherPacket")
        or lesson_input.get("visualTeacherPacket")
        or vision
        or visual_truth
    )


def _mcp_partner_proof(payload: JsonDict) -> JsonDict:
    partner = _d(payload.get("partnerPower"))
    metadata = _d(payload.get("metadata"))
    traces = _l(payload.get("mcpTrace") or payload.get("toolTrace"))

    if not partner and metadata.get("partnerPower"):
        partner = _d(metadata.get("partnerPower"))

    return {
        "mcpUsed": bool(partner.get("mcpUsed") or metadata.get("mcpUsed")),
        "partner": _t(partner.get("partner") or metadata.get("partner") or "MongoDB", 80),
        "toolCallCount": int(
            partner.get("toolCallCount")
            or partner.get("mcpTraceCount")
            or len(_l(partner.get("toolCalls")))
            or 0
        ),
        "capabilitiesUsed": _l(partner.get("capabilitiesUsed")),
        "traceCount": len(traces),
        "strictPartnerPower": bool(partner.get("strictPartnerPower") or metadata.get("strictPartnerPower")),
    }


def _local_page_metadata(payload: JsonDict) -> List[JsonDict]:
    node = _selected_node(payload)
    rich = _d(node.get("richSourcePack"))
    vision = _d(payload.get("selectedPageVision"))
    out: List[JsonDict] = []

    for raw in _l(rich.get("pageImages")) + _l(vision.get("pageImages") or vision.get("selectedPageImages")):
        item = _d(raw)
        url = _t(item.get("pageImageUrl") or item.get("url") or item.get("src"), 500)
        path = _t(item.get("pageImagePath") or item.get("path"), 900)
        if not url and not path:
            continue

        out.append({
            "page": item.get("page"),
            "url": url,
            "src": _t(item.get("src") or url, 500),
            "path": path,
            "source": "local_server_public",
            "type": item.get("type") or "pdfPageImage",
            "imageTextIsTruth": bool(item.get("imageTextIsTruth")),
            "pdfExtractedTextIsTruth": item.get("pdfExtractedTextIsTruth", True),
            "ocrIsHelperOnly": item.get("ocrIsHelperOnly", True),
            "fullPageImageAvailableForGeminiVision": bool(item.get("fullPageImageAvailableForGeminiVision")),
        })

    seen = set()
    deduped = []
    for item in out:
        key = (item.get("page"), item.get("url"), item.get("path"))
        if key in seen:
            continue
        seen.add(key)
        deduped.append(item)

    return deduped[:16]


def _make_ref(raw: Any, role: str, payload: JsonDict, *, primary: bool = False) -> JsonDict | None:
    d = _d(raw)
    quote = _t(
        d.get("quote")
        or d.get("textPreview")
        or d.get("text")
        or d.get("content")
        or d.get("fullPageTextPreview"),
        1200,
    )
    source_ref = _t(
        d.get("sourceRef")
        or d.get("pageRef")
        or d.get("chunkId")
        or d.get("id"),
        420,
    )

    page = d.get("page")
    try:
        page = int(page) if page is not None else None
    except Exception:
        pass

    if not source_ref and page is not None:
        source_ref = f"page:{page}:{role}"

    if not quote or not source_ref:
        return None

    selected_pages = set(_selected_pages(payload))
    comparison_only = bool(d.get("comparisonOnly"))
    if role in {"comparison", "contrast"}:
        comparison_only = True
    if selected_pages and page is not None and page not in selected_pages and _comparison_marker(quote):
        comparison_only = True

    ref = {
        **d,
        "page": page,
        "sourceRef": source_ref,
        "quote": quote,
        "evidenceRole": "comparison" if comparison_only else role,
        "isPrimaryTruth": bool(primary and not comparison_only),
        "comparisonOnly": comparison_only,
    }
    return ref


def _add_refs(out: List[JsonDict], items: Any, role: str, payload: JsonDict, *, primary: bool = False) -> None:
    for item in _l(items):
        ref = _make_ref(item, role, payload, primary=primary)
        if ref:
            out.append(ref)


def _visual_relations(payload: JsonDict) -> List[JsonDict]:
    packet = _visual_packet(payload)
    raw: List[Any] = []
    for key in ["visualRelations", "relationshipWalkthrough", "relationships", "relations"]:
        raw.extend(_l(packet.get(key)))

    out: List[JsonDict] = []
    seen = set()

    for item in raw:
        d = _d(item)
        frm = _t(d.get("from") or d.get("fromLabel") or d.get("source") or d.get("left") or d.get("start"), 220)
        to = _t(d.get("to") or d.get("toLabel") or d.get("target") or d.get("right") or d.get("end"), 220)
        if not frm or not to:
            continue

        relation = _t(d.get("type") or d.get("relationship") or d.get("label") or "visual-link", 260)
        meaning = _t(d.get("meaning") or d.get("whyItMatters") or d.get("teachingRationale"), 1000)
        visual = _t(d.get("visualEvidence") or d.get("visualProof") or d.get("description"), 1000)
        proof = _t(d.get("sourceProof"), 900)
        board = _t(d.get("boardAction") or d.get("boardActionHint"), 700)
        confidence = d.get("confidence")

        try:
            conf = float(confidence) if confidence is not None else 0.0
        except Exception:
            conf = 0.0

        if conf and conf < 0.75:
            continue

        key = (_slug(frm, "from"), _slug(to, "to"), _slug(relation, "rel"))
        if key in seen:
            continue
        seen.add(key)

        out.append({
            "fromLabel": frm,
            "toLabel": to,
            "type": relation,
            "meaning": meaning,
            "boardAction": board or "highlight/trace this visual relationship",
            "visualEvidence": visual,
            "sourceProof": proof,
            "sourceType": _t(d.get("sourceType") or "visual_observation", 160),
            "confidence": confidence,
            "needsSourceVerification": bool(d.get("needsSourceVerification", not proof)),
            "sourceRefs": normalize_source_refs(_l(d.get("sourceRefs"))),
        })

    return out[:60]


def _visual_elements(payload: JsonDict) -> List[JsonDict]:
    packet = _visual_packet(payload)
    raw: List[Any] = []
    for key in ["visualElements", "diagramElementDetails", "diagramElements", "elements", "tables", "figures", "layoutBlocks"]:
        raw.extend(_l(packet.get(key)))

    out: List[JsonDict] = []
    seen = set()

    for index, item in enumerate(raw):
        d = _d(item)
        label = _t(d.get("label") or d.get("name") or d.get("text") or d.get("tableName"), 220)
        if not label:
            continue

        element_id = _slug(d.get("id") or d.get("conceptLink") or label, f"visual_{index + 1}")
        if element_id in seen:
            continue
        seen.add(element_id)

        out.append({
            "id": element_id,
            "label": label,
            "kind": _t(d.get("kind") or d.get("type") or "visual_element", 120),
            "visualRole": _t(d.get("visualRole") or d.get("role") or d.get("meaning") or d.get("description"), 700),
            "conceptMeaning": _t(d.get("conceptMeaning") or d.get("teacherExplanation") or d.get("spokenTeacherLine"), 800),
            "exactBoardMove": _t(d.get("exactBoardMove") or d.get("boardRedrawInstruction"), 600),
            "conceptLink": _t(d.get("conceptLink") or d.get("conceptId"), 180),
            "anchor": _d(d.get("anchor") or d.get("bbox") or d.get("box")),
            "confidence": d.get("confidence"),
            "sourceType": _t(d.get("sourceType"), 160),
            "needsSourceVerification": bool(d.get("needsSourceVerification")),
            "sourceRefs": normalize_source_refs(_l(d.get("sourceRefs"))),
        })

    return out[:40]


def _source_buckets(payload: JsonDict) -> JsonDict:
    explicit = _d(payload.get("sourceBuckets"))
    source = _d(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    node = _selected_node(payload)
    rich = _d(node.get("richSourcePack"))
    selected_pages = set(_selected_pages(payload))

    primary: List[JsonDict] = []
    same: List[JsonDict] = []
    support: List[JsonDict] = []
    comparison: List[JsonDict] = []
    vision_only: List[JsonDict] = []

    for key in ["primaryRefs", "selectedRefs", "selectedEvidence"]:
        _add_refs(primary, explicit.get(key), "primary", payload, primary=True)
    for key in ["samePageRefs", "samePageEvidence"]:
        _add_refs(same, explicit.get(key), "same_page", payload, primary=True)
    for key in ["supportRefs", "nearbyRefs", "nearbyEvidence", "relatedEvidence"]:
        _add_refs(support, explicit.get(key), "support", payload)
    for key in ["comparisonRefs", "comparisonEvidence"]:
        _add_refs(comparison, explicit.get(key), "comparison", payload)

    _add_refs(primary, node.get("sourceRefs"), "primary", payload, primary=True)
    _add_refs(primary, node.get("evidenceQuotes"), "primary", payload, primary=True)

    if rich.get("fullPageTextPreview"):
        page = (_l(rich.get("pages")) or _l(rich.get("pageRefs")) or _l(node.get("pages")) or [None])[0]
        primary.append({
            "page": page,
            "sourceRef": f"localFullPageText:{node.get('nodeId') or node.get('id')}:page:{page}",
            "pageRef": f"page:{page}" if page is not None else "",
            "quote": _t(rich.get("fullPageTextPreview"), 1200),
            "evidenceRole": "primary",
            "isPrimaryTruth": True,
            "comparisonOnly": False,
            "sourceStorage": "local_server_context",
            "pdfExtractedTextIsTruth": True,
        })

    for key, role, target, primary_flag in [
        ("selectedEvidence", "primary", primary, True),
        ("samePageEvidence", "same_page", same, True),
        ("nearbyEvidence", "support", support, False),
        ("relatedEvidence", "support", support, False),
        ("comparisonEvidence", "comparison", comparison, False),
    ]:
        _add_refs(target, payload.get(key), role, payload, primary=primary_flag)
        _add_refs(target, source.get(key), role, payload, primary=primary_flag)

    generic_refs: List[JsonDict] = []
    _add_refs(generic_refs, payload.get("sourceRefs"), "source", payload)
    _add_refs(generic_refs, source.get("sourceRefs"), "source", payload)

    for ref in generic_refs:
        if ref.get("comparisonOnly"):
            comparison.append(ref)
        elif ref.get("page") in selected_pages:
            same.append({**ref, "evidenceRole": "same_page", "isPrimaryTruth": True})
        else:
            support.append({**ref, "evidenceRole": "support"})

    for c in _concepts(payload):
        for raw in _l(c.get("sourceRefs")):
            ref = _make_ref(raw, "concept", payload)
            if not ref:
                continue
            if c.get("comparisonOnly") or ref.get("comparisonOnly"):
                comparison.append({**ref, "evidenceRole": "comparison", "comparisonOnly": True})
            elif ref.get("page") in selected_pages:
                same.append({**ref, "evidenceRole": "same_page", "isPrimaryTruth": True})
            else:
                support.append({**ref, "evidenceRole": "support"})

    for rel in _visual_relations(payload):
        if not rel.get("sourceProof"):
            vision_only.append({
                "sourceRef": f"vision:{_slug(rel.get('fromLabel'), 'from')}:{_slug(rel.get('toLabel'), 'to')}",
                "quote": _t(rel.get("visualEvidence") or rel.get("meaning"), 900),
                "evidenceRole": "vision_only",
                "sourceType": rel.get("sourceType") or "visual_observation",
                "comparisonOnly": False,
                "needsSourceVerification": bool(rel.get("needsSourceVerification", True)),
            })

    def clean(items: List[JsonDict], limit: int) -> List[JsonDict]:
        return dedupe_source_refs(normalize_source_refs(items))[:limit]

    primary = [r for r in primary if not r.get("comparisonOnly")]
    same = [r for r in same if not r.get("comparisonOnly")]

    if not primary and same:
        primary = [{**r, "evidenceRole": "primary", "isPrimaryTruth": True} for r in same[:4]]

    return {
        "primaryRefs": clean(primary, 20),
        "samePageRefs": clean(same, 20),
        "supportRefs": clean(support, 28),
        "comparisonRefs": clean(comparison, 18),
        "visionOnlyFacts": clean(vision_only, 24),
        "selectedPages": sorted(list(selected_pages)),
        "localPageImages": _local_page_metadata(payload),
        "mcpPartnerProof": _mcp_partner_proof(payload),
        "metadata": {
            "sourceBucketsV47": True,
            "localAndMongoMetadataMode": True,
            "localImagesArePointersNotMongoBytes": True,
        },
    }


def _refs_for_phase(payload: JsonDict, phase: str, query: Any = "", limit: int = 5) -> List[JsonDict]:
    buckets = _source_buckets(payload)
    phase = _t(phase, 100).lower() or "core"
    qwords = set(_words(query))

    if phase in COMPARISON_PHASES:
        pool = buckets["comparisonRefs"] + buckets["primaryRefs"] + buckets["samePageRefs"] + buckets["supportRefs"]
    elif phase in {"support", "detail", "example"}:
        pool = buckets["primaryRefs"] + buckets["samePageRefs"] + buckets["supportRefs"]
    else:
        pool = buckets["primaryRefs"] + buckets["samePageRefs"]

    def score(ref: JsonDict) -> int:
        role = _t(ref.get("evidenceRole"), 100)
        s = 0
        if role == "primary":
            s += 120
        if role == "same_page":
            s += 100
        if role == "support":
            s += 30
        if role == "comparison":
            s += 20 if phase in COMPARISON_PHASES else -1000
        if ref.get("isPrimaryTruth"):
            s += 35
        if ref.get("comparisonOnly") and phase not in COMPARISON_PHASES:
            s -= 1000

        rwords = set(_words(ref.get("quote")))
        if qwords and rwords:
            s += min(70, 8 * len(qwords.intersection(rwords)))
        return s

    ranked = sorted(pool, key=score, reverse=True)
    safe = [r for r in ranked if not (r.get("comparisonOnly") and phase not in COMPARISON_PHASES)]
    return dedupe_source_refs(normalize_source_refs(safe))[:limit]


def _compact_list(items: Any, limit: int, char_limit: int = 900) -> List[Any]:
    out: List[Any] = []
    for item in _l(items)[:limit]:
        if isinstance(item, dict):
            cleaned: JsonDict = {}
            for k, v in item.items():
                if isinstance(v, str):
                    cleaned[k] = _t(v, char_limit)
                elif isinstance(v, (int, float, bool)) or v is None:
                    cleaned[k] = v
                elif isinstance(v, list):
                    cleaned[k] = _compact_list(v, 12, max(220, char_limit // 2))
                elif isinstance(v, dict):
                    sub: JsonDict = {}
                    for sk, sv in v.items():
                        sub[sk] = _t(sv, max(220, char_limit // 2)) if isinstance(sv, str) else sv
                    cleaned[k] = sub
                else:
                    cleaned[k] = _t(v, max(220, char_limit // 2))
            out.append(cleaned)
        elif isinstance(item, str):
            out.append(_t(item, char_limit))
        else:
            out.append(item)
    return out


def _full_vision_packet_for_kg(payload: JsonDict) -> JsonDict:
    packet = _visual_packet(payload)
    vision = _d(payload.get("selectedPageVision"))
    visual_truth = _d(payload.get("visualTruth"))

    def first_text(*values: Any, limit: int = 1200) -> str:
        for v in values:
            t = _t(v, limit)
            if t:
                return t
        return ""

    raw_elements: List[Any] = []
    for key in ["visualElements", "diagramElementDetails", "diagramElements", "elements", "tables", "figures", "layoutBlocks"]:
        raw_elements.extend(_l(packet.get(key)))
        raw_elements.extend(_l(vision.get(key)))
        raw_elements.extend(_l(visual_truth.get(key)))

    raw_relations: List[Any] = []
    for key in ["visualRelations", "relationshipWalkthrough", "relationships", "relations"]:
        raw_relations.extend(_l(packet.get(key)))
        raw_relations.extend(_l(vision.get(key)))
        raw_relations.extend(_l(visual_truth.get(key)))

    return {
        "summary": first_text(
            packet.get("pageVisualNarrative"),
            packet.get("visualSummary"),
            packet.get("diagramSummary"),
            vision.get("pageVisualNarrative"),
            vision.get("visualSummary"),
            vision.get("diagramSummary"),
            visual_truth.get("visualSummary"),
            limit=1400,
        ),
        "elements": _compact_list(raw_elements, 40, 700),
        "relations": _compact_list(raw_relations, 60, 850),
        "teacherMarkingScript": _compact_list(packet.get("teacherMarkingScript") or vision.get("teacherMarkingScript"), 30, 700),
        "boardRedrawPlan": _compact_list(packet.get("boardRedrawPlan") or vision.get("boardRedrawPlan"), 30, 700),
        "visualTeachingSequence": _compact_list(packet.get("visualTeachingSequence") or vision.get("visualTeachingSequence"), 25, 700),
        "misconceptionRisks": _compact_list(packet.get("misconceptionRisks") or vision.get("misconceptionRisks"), 20, 700),
        "sourcePolicy": {
            "ragTextIsSourceTruth": True,
            "visionIsVisualTruth": True,
            "visionOnlyRelationAllowed": True,
            "visionOnlyCannotBeSourceProof": True,
            "visionOnlyMustSetNeedsTextConfirmation": True,
        },
    }


def _parse_json_from_text(value: Any) -> JsonDict:
    if not isinstance(value, str):
        return {}

    text = value.strip()
    if not text:
        return {}

    candidates: List[str] = []

    def add(candidate: str) -> None:
        c = str(candidate or "").strip()
        if c and c not in candidates:
            candidates.append(c)

    add(text)

    for m in re.finditer(r"```(?:json)?\s*([\s\S]*?)```", text, flags=re.IGNORECASE):
        add(m.group(1))

    no_fence = re.sub(r"^```(?:json)?\s*", "", text, flags=re.IGNORECASE)
    no_fence = re.sub(r"\s*```$", "", no_fence)
    add(no_fence)

    first = text.find("{")
    last = text.rfind("}")
    if first != -1 and last != -1 and last > first:
        add(text[first:last + 1])

    for candidate in candidates:
        try:
            obj = json.loads(candidate)
            if isinstance(obj, dict):
                return obj
        except Exception:
            continue

    return {}


def _kg_raw_score(value: Any) -> int:
    d = _d(value)
    if not d:
        return -999

    score = 0
    nodes = _l(d.get("nodes"))
    edges = _l(d.get("edges"))
    path = _l(d.get("teachingPath"))

    score += min(len(nodes), 12) * 14
    score += min(len(edges), 16) * 12
    score += min(len(path), 12) * 12

    if _t(d.get("rootNodeId")):
        score += 35
    if _d(d.get("visualGraphHints")):
        score += 25
    if _d(d.get("qualitySignals")):
        score += 20

    for key in ["requiredOutputSchema", "outputSchema", "minimum", "example"]:
        if key in d:
            score -= 80

    for n in nodes:
        nd = _d(n)
        if not _t(nd.get("nodeId")) and not _t(nd.get("label")):
            score -= 50
    for e in edges:
        ed = _d(e)
        if not _t(ed.get("edgeId")) and not _t(ed.get("from")) and not _t(ed.get("to")):
            score -= 50

    return score


def _unwrap_kg_raw(raw: Any) -> JsonDict:
    parsed = _parse_json_from_text(raw)
    root = parsed or _d(raw)

    if not root:
        return {}

    candidates: List[JsonDict] = []
    seen = set()

    def visit(value: Any, depth: int = 0) -> None:
        if depth > 8:
            return

        if isinstance(value, str):
            parsed_child = _parse_json_from_text(value)
            if parsed_child:
                visit(parsed_child, depth + 1)
            return

        d = _d(value)
        if not d:
            return

        oid = id(d)
        if oid in seen:
            return
        seen.add(oid)
        candidates.append(d)

        for key in [
            "knowledgeGraph", "knowledge_graph", "kg", "graph",
            "result", "output", "data", "response", "final", "json",
            "answer", "message", "content", "text", "raw",
        ]:
            child = d.get(key)
            if isinstance(child, (dict, str)):
                visit(child, depth + 1)

        for child in d.values():
            if isinstance(child, dict):
                keys = set(child.keys())
                if {"nodes", "edges", "teachingPath", "rootNodeId", "visualGraphHints", "knowledgeGraph", "kg", "graph"} & keys:
                    visit(child, depth + 1)
            elif isinstance(child, str) and "{" in child and "}" in child:
                visit(child, depth + 1)

    visit(root)

    if not candidates:
        return root

    candidates.sort(key=_kg_raw_score, reverse=True)
    return candidates[0]


def _edge_type(value: Any) -> str:
    t = _t(value, 800).lower()

    if any(x in t for x in ["not joined", "not join", "no direct", "do not join", "not connected"]):
        return "not-joined-to"
    if "foreign key" in t:
        return "foreign-key-enables"
    if any(x in t for x in ["join", "joined", "connect", "link", "arrow"]):
        return "joins-to"
    if any(x in t for x in ["center", "central", "hub"]):
        return "has-center"
    if any(x in t for x in ["surround", "around"]):
        return "surrounded-by"
    if any(x in t for x in ["measure", "metric"]):
        return "stores-measure"
    if any(x in t for x in ["describe", "attribute", "context"]):
        return "describes-fact"
    if _comparison_marker(t):
        return "contrasts"
    if "example" in t:
        return "example-of"
    if any(x in t for x in ["part", "contains", "has"]):
        return "part-of"
    if any(x in t for x in ["rule", "must"]):
        return "rule-for"
    if any(x in t for x in ["mistake", "misconception", "wrong", "confuse"]):
        return "misconception-of"
    return "related"


def _meaningful(value: Any) -> bool:
    t = _t(value, 1000).strip().lower()
    if not t:
        return False
    return t not in {"connects", "connected", "relationship", "visual relation", "trace this relationship with an arrow/highlight"}


def _match_node(label: Any, nodes: List[JsonDict]) -> str:
    words = set(_words(label))
    if not words:
        return ""

    best_id = ""
    best_score = 0
    for node in nodes:
        text = " ".join([
            _t(node.get("nodeId")),
            _t(node.get("label")),
            _t(node.get("summary")),
            " ".join([_t(x, 160) for x in _l(node.get("targetVisualLabels"))]),
        ])
        score = len(words.intersection(set(_words(text))))
        if score > best_score:
            best_score = score
            best_id = _t(node.get("nodeId"), 180)

    return best_id


def _phase_for_node(node: JsonDict, index: int) -> str:
    if node.get("comparisonOnly"):
        return "comparison"
    if index == 0:
        return "see_first"

    text = (_t(node.get("label")) + " " + _t(node.get("summary")) + " " + _t(node.get("teachingRole"))).lower()
    if any(x in text for x in ["center", "central", "anchor", "hub"]):
        return "anchor"
    if any(x in text for x in ["join", "foreign key", "connect", "relationship"]):
        return "relationship"
    if any(x in text for x in ["not joined", "not join", "misconception", "wrong"]):
        return "misconception_repair"
    return "define"


def _normalize_node(raw: Any, payload: JsonDict, index: int) -> JsonDict:
    raw = _d(raw)
    label = _t(raw.get("label") or raw.get("title") or raw.get("name"), 240)
    node_id = _slug(raw.get("nodeId") or raw.get("id") or label, f"node_{index + 1}")

    source_role = _t(raw.get("sourceRole") or raw.get("evidenceRole"), 120).lower()
    comparison = bool(
        raw.get("comparisonOnly")
        or source_role in {"comparison", "contrast", "compare"}
        or _comparison_marker(raw.get("phase") or raw.get("teachingRole"))
    )
    phase = "comparison" if comparison else "core"

    refs = _refs_for_phase(payload, phase, query=label + " " + _t(raw.get("summary")), limit=5)

    visual_hints = [_t(x, 700) for x in _l(raw.get("visualHints")) if _t(x, 700)]
    target_labels = [_t(x, 180) for x in _l(raw.get("targetVisualLabels")) if _t(x, 180)]
    if not target_labels and label:
        target_labels = [label]

    evidence_type = _t(raw.get("evidenceType"), 100)
    if evidence_type not in {"text_plus_vision", "text_only", "vision_only", "teaching_inference"}:
        evidence_type = (
            "text_plus_vision" if refs and visual_hints
            else "text_only" if refs
            else "vision_only" if visual_hints
            else "teaching_inference"
        )

    return {
        "nodeId": node_id,
        "label": label or f"Node {index + 1}",
        "summary": _t(raw.get("summary") or raw.get("definition") or raw.get("description"), 1200),
        "nodeType": _t(raw.get("nodeType") or ("comparison_concept" if comparison else "concept"), 120),
        "level": int(raw.get("level") or (0 if index == 0 else 1)),
        "order": int(raw.get("order") or (index + 1)),
        "importance": raw.get("importance") if raw.get("importance") is not None else (0.95 if index < 3 else 0.72),
        "teachingRole": _t(raw.get("teachingRole") or ("comparison" if comparison else "anchor" if index == 0 else "core"), 120),
        "learningGoal": _t(raw.get("learningGoal") or f"Student can explain {label} using source and visual evidence.", 1000),
        "boardPlacementHint": _t(raw.get("boardPlacementHint") or ("center" if index == 0 else "side-card"), 180),
        "visualEncoding": _t(raw.get("visualEncoding") or ("comparison" if comparison else "highlight"), 120),
        "misconceptionRisk": _t(raw.get("misconceptionRisk") or "medium", 600),
        "sourceRefs": refs,
        "visualHints": visual_hints,
        "targetVisualLabels": list(dict.fromkeys(target_labels))[:12],
        "sourceRole": "comparison" if comparison else "primary_or_same_page",
        "evidenceType": evidence_type,
        "comparisonOnly": comparison,
        "needsTextConfirmation": bool(raw.get("needsTextConfirmation") or evidence_type == "vision_only"),
        "metadata": {
            **_d(raw.get("metadata")),
            "sourceGuardV47": True,
            "noFallbackStrict": True,
        },
    }



def _derive_edge_rationale(
    *,
    label: str,
    etype: str,
    from_id: str,
    to_id: str,
    source_proof: str,
    visual_proof: str,
    board_action: str,
) -> str:
    """
    Complete missing teachingRationale for a Gemini-created edge.

    This is not fallback graph creation:
    - no new nodes
    - no new edges
    - no new facts
    It only explains why the existing edge matters using existing edge fields.
    """
    label = _t(label, 260)
    etype = _t(etype, 120)
    source_proof = _t(source_proof, 600)
    visual_proof = _t(visual_proof, 600)
    board_action = _t(board_action, 400)

    relation_phrase = label or etype or "this relationship"

    if etype == "joins-to":
        base = f"This relation matters because it shows how {from_id} connects to {to_id}, which is the join path the student must understand."
    elif etype == "not-joined-to":
        base = f"This relation matters because it prevents a common misconception: {from_id} should not be understood as directly joined to {to_id}."
    elif etype == "has-center":
        base = f"This relation matters because it identifies the central anchor concept before explaining surrounding concepts."
    elif etype == "surrounded-by":
        base = f"This relation matters because it explains the visual structure around the central concept."
    elif etype == "foreign-key-enables":
        base = f"This relation matters because it explains the mechanism that connects the related tables/concepts."
    elif etype == "stores-measure":
        base = f"This relation matters because it connects the concept to the measured facts or values students should track."
    elif etype == "describes-fact":
        base = f"This relation matters because it shows which concept provides descriptive context for the main fact/event."
    elif etype == "contrasts":
        base = f"This relation matters because it separates the selected concept from a comparison concept without mixing their source proof."
    elif etype == "misconception-of":
        base = f"This relation matters because it marks a likely wrong idea and prepares a repair step."
    elif etype == "visual-link":
        base = f"This relation matters because the PDF image visually connects the two concepts and the teacher should point to that connection."
    else:
        base = f"This relation matters because it connects {from_id} to {to_id} through: {relation_phrase}."

    proof_bits = []
    if source_proof:
        proof_bits.append("text proof is available")
    if visual_proof:
        proof_bits.append("visual proof is available")
    if board_action:
        proof_bits.append("it gives the board a clear action")

    if proof_bits:
        base += " It is useful for teaching because " + ", ".join(proof_bits) + "."

    return _t(base, 1200)


def _normalize_edge(raw: Any, payload: JsonDict, nodes: List[JsonDict], index: int) -> JsonDict | None:
    raw = _d(raw)

    from_raw = raw.get("from") or raw.get("source") or raw.get("fromNodeId") or raw.get("fromLabel")
    to_raw = raw.get("to") or raw.get("target") or raw.get("toNodeId") or raw.get("toLabel")

    from_id = _slug(from_raw, "")
    to_id = _slug(to_raw, "")

    node_ids = {n.get("nodeId") for n in nodes}
    if from_id not in node_ids:
        from_id = _match_node(from_raw, nodes)
    if to_id not in node_ids:
        to_id = _match_node(to_raw, nodes)

    if not from_id or not to_id or from_id == to_id:
        return None

    label = _t(raw.get("label") or raw.get("relationship") or raw.get("type") or "related", 260)
    etype = _t(raw.get("type"), 120)
    if etype not in VALID_EDGE_TYPES:
        etype = _edge_type(label + " " + _t(raw.get("teachingRationale")) + " " + _t(raw.get("visualProof")))

    comparison = bool(raw.get("comparisonOnly") or etype == "contrasts" or _comparison_marker(raw.get("phase") or label))
    phase = "comparison" if comparison else "core"

    rationale = _t(raw.get("teachingRationale") or raw.get("whyItMatters") or raw.get("reason"), 1200)
    board = _t(raw.get("boardActionHint") or raw.get("boardAction") or "highlight/trace the relationship", 700)
    visual_proof = _t(raw.get("visualProof") or raw.get("visualEvidence"), 1000)

    refs = _refs_for_phase(payload, phase, query=label + " " + rationale + " " + _t(raw.get("sourceProof")), limit=5)
    source_proof = _t(raw.get("sourceProof") or (refs[0].get("quote") if refs else ""), 900)

    if not _meaningful(rationale):
        rationale = _derive_edge_rationale(
            label=label,
            etype=etype,
            from_id=from_id,
            to_id=to_id,
            source_proof=source_proof,
            visual_proof=visual_proof,
            board_action=board,
        )

    evidence_type = _t(raw.get("evidenceType"), 100)
    if evidence_type not in {"text_plus_vision", "text_only", "vision_only", "teaching_inference"}:
        evidence_type = (
            "text_plus_vision" if refs and visual_proof
            else "text_only" if refs
            else "vision_only" if visual_proof
            else "teaching_inference"
        )

    if evidence_type == "vision_only":
        refs = []
        source_proof = ""

    target_labels = [_t(x, 180) for x in _l(raw.get("targetVisualLabels")) if _t(x, 180)]
    if not target_labels:
        target_labels = [_t(raw.get("fromLabel") or from_raw, 180), _t(raw.get("toLabel") or to_raw, 180)]
        target_labels = [x for x in target_labels if x]

    return {
        "edgeId": _slug(raw.get("edgeId") or raw.get("id") or f"edge_{from_id}_{to_id}_{index + 1}", f"edge_{index + 1}"),
        "from": from_id,
        "to": to_id,
        "type": etype,
        "label": label,
        "teachingRationale": rationale,
        "boardActionHint": board,
        "teacherMove": _t(raw.get("teacherMove") or f"Connect these concepts: {label}.", 1000),
        "sourceProof": source_proof if evidence_type in {"text_only", "text_plus_vision"} else "",
        "visualProof": visual_proof,
        "sourceRefs": refs,
        "targetVisualLabels": list(dict.fromkeys(target_labels))[:12],
        "sourceRole": "comparison" if comparison else "primary_or_same_page",
        "evidenceType": evidence_type,
        "comparisonOnly": comparison,
        "needsTextConfirmation": bool(raw.get("needsTextConfirmation") or evidence_type == "vision_only"),
        "metadata": {
            **_d(raw.get("metadata")),
            "sourceGuardV47": True,
            "relationSpecific": etype not in {"related", "parent-child"},
            "noFallbackStrict": True,
        },
    }


def _normalize_path_step(raw: Any, payload: JsonDict, nodes: List[JsonDict], index: int) -> JsonDict | None:
    raw = _d(raw)
    node_id = _slug(raw.get("nodeId") or raw.get("id"), "")
    node_ids = {n.get("nodeId") for n in nodes}
    if node_id not in node_ids:
        node_id = _match_node(raw.get("nodeId") or raw.get("label") or raw.get("teacherMove") or raw.get("teacherIntent"), nodes)

    if not node_id:
        return None

    node = next((n for n in nodes if n.get("nodeId") == node_id), {})
    comparison = bool(node.get("comparisonOnly"))
    phase = _t(raw.get("phase") or ("comparison" if comparison else _phase_for_node(node, index)), 120)
    if comparison:
        phase = "comparison"

    refs = _refs_for_phase(payload, "comparison" if phase in COMPARISON_PHASES else "core", query=node.get("label"), limit=5)
    target_labels = _l(raw.get("targetVisualLabels")) or _l(node.get("targetVisualLabels"))

    return {
        "pathStepId": _slug(raw.get("pathStepId") or f"path_{index + 1}_{phase}", f"path_{index + 1}"),
        "phase": phase,
        "nodeId": node_id,
        "reason": _t(raw.get("reason") or f"Teach {node.get('label')} here because it connects the selected concept to the next relationship.", 1000),
        "teacherIntent": _t(raw.get("teacherIntent") or raw.get("teacherMove") or f"Help the student connect {node.get('label')} to the selected concept.", 1000),
        "teacherMove": _t(raw.get("teacherMove") or f"Introduce {node.get('label')} using source and visual evidence.", 1200),
        "boardIntent": _t(raw.get("boardIntent") or raw.get("boardActionHint") or (_l(node.get("visualHints")) or ["highlight/write this concept"])[-1], 900),
        "boardActionHint": _t(raw.get("boardActionHint") or (_l(node.get("visualHints")) or ["highlight/write"])[-1], 900),
        "screenHint": _t(raw.get("screenHint") or ("comparison" if comparison else "overview" if index == 0 else "concept_focus"), 120),
        "targetVisualLabels": [_t(x, 180) for x in target_labels if _t(x, 180)][:12],
        "allowedEvidenceRoles": ["comparison"] if phase in COMPARISON_PHASES else ["primary", "same_page", "vision_only"],
        "forbiddenEvidenceRoles": [] if phase in COMPARISON_PHASES else ["comparison"],
        "evidenceType": node.get("evidenceType"),
        "needsTextConfirmation": bool(node.get("needsTextConfirmation")),
        "sourceRefs": refs,
    }


def _normalize_misconception(raw: Any, payload: JsonDict, nodes: List[JsonDict], index: int) -> JsonDict | None:
    raw = _d(raw)
    wrong = _t(raw.get("wrongIdea") or raw.get("risk") or raw.get("confusion"), 1000)
    correct = _t(raw.get("correctIdea") or raw.get("repairMove"), 1200)
    if not wrong and not correct:
        return None

    node_ids = {n.get("nodeId") for n in nodes}
    related = []
    for x in _l(raw.get("relatedNodeIds")):
        nid = _slug(x, "")
        if nid in node_ids:
            related.append(nid)

    if not related and nodes:
        related = [nodes[0]["nodeId"]]

    refs = _refs_for_phase(payload, "core", query=wrong + " " + correct, limit=4)

    return {
        "misconceptionId": _slug(raw.get("misconceptionId") or f"mis_{index + 1}", f"mis_{index + 1}"),
        "wrongIdea": wrong,
        "correctIdea": correct or "Use source and visual relation evidence to repair the misconception.",
        "relatedNodeIds": related,
        "boardRepairHint": _t(raw.get("boardRepairHint") or raw.get("boardRepair") or "mark the confusing relation, then show the correct relation", 900),
        "evidenceType": "text_plus_vision" if refs else "vision_only",
        "sourceRefs": refs,
    }


def _comparison_slots_from_nodes(payload: JsonDict, nodes: List[JsonDict]) -> List[JsonDict]:
    slots: List[JsonDict] = []
    for index, node in enumerate([n for n in nodes if n.get("comparisonOnly")][:8]):
        refs = _refs_for_phase(payload, "comparison", query=node.get("label"), limit=5)
        slots.append({
            "comparisonId": f"comparison_{index + 1}_{node.get('nodeId')}",
            "nodeId": node.get("nodeId"),
            "label": node.get("label"),
            "allowedOnlyAfterCoreStep": 4,
            "comparisonRefs": refs,
            "boardHint": "Use this only as a comparison/contrast card after core selected concept is clear.",
        })
    return slots


def _quality(output: JsonDict, payload: JsonDict) -> JsonDict:
    nodes = [_d(x) for x in _l(output.get("nodes"))]
    edges = [_d(x) for x in _l(output.get("edges"))]
    path = [_d(x) for x in _l(output.get("teachingPath"))]
    buckets = _d(output.get("sourceBuckets"))

    comparison_leaks = 0
    for item in nodes + edges + path:
        if item.get("comparisonOnly"):
            continue
        roles = _l(item.get("allowedEvidenceRoles"))
        if "comparison" in roles:
            continue
        for ref in _l(item.get("sourceRefs")):
            if _d(ref).get("comparisonOnly") or _t(_d(ref).get("evidenceRole")).lower() == "comparison":
                comparison_leaks += 1

    generic_edge_count = len([
        e for e in edges
        if e.get("type") in {"related", "parent-child"}
        and not _meaningful(e.get("visualProof"))
        and not _meaningful(e.get("sourceProof"))
    ])
    relation_specific = len([
        e for e in edges
        if e.get("type") not in {"related", "parent-child"}
        and _meaningful(e.get("teachingRationale"))
        and _meaningful(e.get("boardActionHint"))
    ])
    path_board = len([p for p in path if _meaningful(p.get("boardIntent")) or _meaningful(p.get("boardActionHint"))])
    path_visual = len([p for p in path if _l(p.get("targetVisualLabels"))])
    vision_only = len([e for e in edges if e.get("evidenceType") == "vision_only"])
    text_plus_vision = len([e for e in edges if e.get("evidenceType") == "text_plus_vision"])

    ready = (
        comparison_leaks == 0
        and len(nodes) >= 6
        and len(edges) >= 6
        and len(path) >= 5
        and relation_specific >= 4
        and path_board >= 5
    )

    return {
        "sourceGuardV47": True,
        "sourceGuardV43": True,
        "noFallbackStrict": True,
        "geminiAdkRequired": True,
        "geminiOutputUsed": True,
        "emergencyRepairUsed": False,
        "pythonFallbackGraphUsed": False,
        "selectedPrimaryRefCount": len(_l(buckets.get("primaryRefs"))),
        "samePageRefCount": len(_l(buckets.get("samePageRefs"))),
        "supportRefCount": len(_l(buckets.get("supportRefs"))),
        "comparisonRefCount": len(_l(buckets.get("comparisonRefs"))),
        "visionOnlyFactCount": len(_l(buckets.get("visionOnlyFacts"))),
        "localPageImageCount": len(_l(buckets.get("localPageImages"))),
        "mcpUsed": bool(_d(buckets.get("mcpPartnerProof")).get("mcpUsed")),
        "mcpToolCallCount": int(_d(buckets.get("mcpPartnerProof")).get("toolCallCount") or 0),
        "comparisonRefLeakCount": comparison_leaks,
        "genericEdgeCount": generic_edge_count,
        "relationSpecificEdgeCount": relation_specific,
        "pathStepWithBoardIntentCount": path_board,
        "pathStepWithVisualTargetCount": path_visual,
        "visionOnlyRelationCount": vision_only,
        "textPlusVisionRelationCount": text_plus_vision,
        "readyForTeachingStrategy": ready,
        "readyForVisualPlanner": ready,
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }


class KnowledgeGraphAgent(BaseLiveTutorAgent):
    agent_name = "KnowledgeGraphAgent"
    agent_group = "source"
    default_mode = "build_knowledge_graph"
    uses_adk = True

    @property
    def instruction(self) -> str:
        return """
You are KnowledgeGraphAgent for an advanced human-like Live Tutor.

You are a real Google ADK/Gemini reasoning agent.

Your job:
- Build a concept relationship map.
- Build teaching order skeleton.
- Build misconception repair map.
- Build visual graph hints for later board agents.

Your job is NOT:
- Do not write final long lesson.
- Do not create final board commands.
- Do not create voice script.
- Do not create subtitles.
- Do not generate or replace PDF page images.
- Do not create fallback content.

Strict rules:
- Use selectedNode, sourceBuckets, conceptExtraction, full structured visualTeacherPacket.
- Local PDF page images are real visual background pointers.
- PDF extracted text is source truth.
- OCR/image text is helper only unless explicitly source-grounded.
- MongoDB MCP proof is partner/storage proof, not a replacement for local PDF image bytes.
- Core/definition/relationship phases may use only primary/same_page refs or vision_only facts.
- Comparison refs may only be used in comparison/contrast slots.
- Vision-only relations must be labeled evidenceType=vision_only and needsTextConfirmation=true.
- Do not convert vision-only observation into sourceProof.
- If RAG misses a visual relation, preserve it as vision_only.
- Output valid JSON only.
"""

    def validate_input(self, payload: JsonDict) -> ValidationResult:
        errors: List[str] = []
        warnings: List[str] = []

        if len(_concepts(payload)) < 3:
            errors.append("KnowledgeGraphAgent requires conceptExtraction.concepts with at least 3 concepts.")

        buckets = _source_buckets(payload)
        if not buckets["primaryRefs"] and not buckets["samePageRefs"]:
            errors.append("KnowledgeGraphAgent requires primary/same-page source truth from selectedNode/sourceTruth/local richSourcePack.")

        if not _visual_packet(payload):
            warnings.append("No visualTeacherPacket found; KG will be source-text only.")

        if not buckets["localPageImages"]:
