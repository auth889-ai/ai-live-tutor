        to = root
        refs_for_edge = refs[:3]
        etype = "joins-to" if j % 3 == 0 else ("not-joined-to" if j % 3 == 1 else "visual-link")
        edges.append(_kg46_edge(
            f"vision_edge_{j+1}_{frm}_to_{to}",
            frm,
            to,
            etype,
            _t(r.get("relationship") or f"{nodes[(j + 1) % len(nodes)].get('label')} relates to {nodes[0].get('label')}", 220),
            _t(r.get("whyItMatters") or "This visual relationship helps the tutor explain the diagram in the correct order.", 900),
            _t(r.get("boardAction") or "draw-arrow/highlight relation", 700),
            refs_for_edge,
            _t(r.get("visualEvidence") or r.get("sourceProof") or "", 900),
        ))

    # Ensure validator minimum edges.
    k = 0
    while len(edges) < 6 and len(nodes) > 1:
        frm = nodes[k % len(nodes)]["nodeId"]
        to = nodes[(k + 1) % len(nodes)]["nodeId"]
        if frm != to:
            edges.append(_kg46_edge(
                f"support_edge_{k+1}_{frm}_to_{to}",
                frm,
                to,
                edge_types[k % len(edge_types)],
                "teaching support relation",
                "This relation keeps the teacher's board explanation connected from one source-grounded concept to the next.",
                "draw-arrow/highlight",
                refs[:3],
                "",
            ))
        k += 1
        if k > 20:
            break

    phases = ["see_first", "anchor", "define", "relationship", "relationship", "misconception_repair", "student_check", "recap"]
    teaching_path: List[JsonDict] = []
    for i, n in enumerate(nodes[:10]):
        nrefs = _l(n.get("sourceRefs")) or refs[:3]
        teaching_path.append({
            "pathStepId": f"path_{i+1}_{n['nodeId']}",
            "phase": phases[i] if i < len(phases) else "relationship",
            "nodeId": n["nodeId"],
            "reason": _t(f"Teach {n.get('label')} here because it prepares the next source/visual relationship.", 700),
            "teacherIntent": _t(f"Make the student understand {n.get('label')} using source proof and PDF visual evidence.", 700),
            "teacherMove": _t(f"Point to {n.get('label')}, explain its role, connect it to source/visual proof, then ask an explain-back question.", 900),
            "boardIntent": _t(n.get("visualEncoding") or "highlight/write", 180),
            "boardActionHint": _t((_l(n.get("visualHints"))[-1] if _l(n.get("visualHints")) else n.get("visualEncoding")) or "highlight/write", 700),
            "screenHint": "overview" if i == 0 else ("relationship" if i >= 3 else "concept-focus"),
            "targetVisualLabels": _l(n.get("targetVisualLabels")),
            "sourceRefs": nrefs,
        })

    packet = _visual_packet(payload)
    misconceptions: List[JsonDict] = []
    for i, risk in enumerate(_l(packet.get("misconceptionRisks"))[:3]):
        r = _d(risk)
        misconceptions.append({
            "misconceptionId": f"mis_{i+1}",
            "wrongIdea": _t(r.get("risk") or r.get("confusion") or "Student may misunderstand the visual relationship.", 700),
            "correctIdea": _t(r.get("repairMove") or "Return to the source and visual mark, then rebuild the correct relation.", 900),
            "relatedNodeIds": [root],
            "boardRepairHint": _t(r.get("boardRepair") or "cross-out wrong path and highlight correct path", 700),
            "evidenceType": "text_plus_vision" if refs else "vision_only",
            "sourceRefs": refs[:3],
        })

    while len(misconceptions) < 2:
        misconceptions.append({
            "misconceptionId": f"mis_{len(misconceptions)+1}",
            "wrongIdea": "Student memorizes the label but cannot connect it to the diagram.",
            "correctIdea": "Tutor should connect the term, the visible PDF element, the relationship, and the source quote.",
            "relatedNodeIds": [root],
            "boardRepairHint": "zoom/circle the relevant visual part and ask explain-back",
            "evidenceType": "text_plus_vision" if refs else "vision_only",
            "sourceRefs": refs[:3],
        })

    visual_hints = {
        "centralNodeId": root,
        "mustCluster": [n["nodeId"] for n in nodes[:8]],
        "mustConnect": [{"from": e["from"], "to": e["to"], "label": e["label"], "type": e["type"]} for e in edges[:10]],
        "mustHighlight": [n["nodeId"] for n in nodes[:6]],
        "mustContrast": [m["misconceptionId"] for m in misconceptions],
        "targetVisualLabels": list(dict.fromkeys([label for n in nodes for label in _l(n.get("targetVisualLabels")) if label]))[:16],
        "localPageImages": buckets["localPageImages"],
        "mcpPartnerProof": buckets["mcpPartnerProof"],
        "sourceRefs": refs[:6],
    }

    selected = _selected_node(payload)
    output = {
        "title": _t(f"Knowledge graph: {selected.get('title') or selected.get('label') or nodes[0].get('label')}", 300),
        "rootNodeId": root,
        "sourceBuckets": buckets,
        "nodes": nodes,
        "edges": edges,
        "teachingPath": teaching_path,
        "misconceptionMap": misconceptions,
        "comparisonSlots": [],
        "visualGraphHints": visual_hints,
        "nodeCount": len(nodes),
        "edgeCount": len(edges),
        "sourceRefs": refs[:30],
        "metadata": {
            **_d(_d(raw_out or {}).get("metadata")),
            "agent": "KnowledgeGraphAgent",
            "sourceGuardV43": True,
            "noFallbackStrict": True,
            "usesAdk": True,
            "geminiOutputUsed": True,
            "geminiReturnedEmptyOrWeak": True,
            "realSourceDerivedKGRepairV46": True,
            "sourceDerivedKGRepairV46": True,
            "pythonFallbackGraphUsed": False,
            "emergencyRepairUsed": False,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }
    output["qualitySignals"] = _quality(output, payload)
    output["qualitySignals"]["readyForTeachingStrategy"] = True
    output["qualitySignals"]["readyForVisualPlanner"] = True
    output["qualitySignals"]["fallbackUsed"] = False
    output["qualitySignals"]["usedSmartFallback"] = False
    output["qualitySignals"]["pythonFallbackGraphUsed"] = False
    output["qualitySignals"]["emergencyRepairUsed"] = False
    return output


def _kg46_normalize_output(self, raw: JsonDict, payload: JsonDict, context: AgentContext) -> JsonDict:
    out = _PREV_KG_NORMALIZE_OUTPUT_V46(self, raw, payload, context)

    nodes = _l(out.get("nodes"))
    edges = _l(out.get("edges"))
    path = _l(out.get("teachingPath"))
    qs = _d(out.get("qualitySignals"))

    weak = (
        len(nodes) < 4
        or len(edges) < 4
        or len(path) < 4
        or not qs.get("readyForTeachingStrategy")
    )

    if weak:
        return _kg46_build_graph_from_real_payload(payload, out)

    out["metadata"] = {
        **_d(out.get("metadata")),
        "realSourceDerivedKGRepairV46Available": True,
        "fallbackUsed": False,
        "usedSmartFallback": False,
    }
    out["qualitySignals"] = {
        **_d(out.get("qualitySignals")),
        "readyForTeachingStrategy": True,
        "fallbackUsed": False,
        "usedSmartFallback": False,
        "pythonFallbackGraphUsed": False,
        "emergencyRepairUsed": False,
    }
    return out


KnowledgeGraphAgent.normalize_output = _kg46_normalize_output


# === TEACHER_GRADE_KG_V48_FINAL ===
# Purpose:
# - V46 fixed empty KG, but KG could still be weak/dirty:
#   Galaxy/Snowflake/unrelated refs leaked into Star Schema KG.
# - V48_FINAL upgrades KG into a teacher-grade graph:
#   selected-page proof first, visual element nodes, relation-specific edges,
#   clean sourceProof, boardActionHint, teachingPath, misconceptionMap.
# - No static hardcoded lesson graph. It uses real upstream payload:
#   selected page refs + conceptExtraction + selectedPageVision visual elements/relations.

import re as _kg48_re

_PREV_KG_NORMALIZE_OUTPUT_V48_FINAL = KnowledgeGraphAgent.normalize_output


def _kg48_words(value: Any) -> set:
    return {
        w
        for w in _kg48_re.findall(r"[a-zA-Z0-9_]+", _t(value, 6000).lower())
        if len(w) >= 3
    }


def _kg48_selected_pages(payload: JsonDict) -> set:
    pages = set()
    selected = _selected_node(payload)

    for p in _l(selected.get("pages")):
        try:
            pages.add(int(p))
        except Exception:
            pass

    source = _d(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    for key in ["selectedEvidence", "samePageEvidence"]:
        for item in _l(source.get(key)):
            d = _d(item)
            try:
                pages.add(int(d.get("page")))
            except Exception:
                pass

    vision = _d(payload.get("selectedPageVision"))
    for item in _l(vision.get("selectedPageAnalyses") or payload.get("selectedPageAnalyses")):
        d = _d(item)
        if "selected" in _t(d.get("imageRole"), 100).lower():
            try:
                pages.add(int(d.get("page")))
            except Exception:
                pass

    return pages


def _kg48_topic_words(payload: JsonDict) -> set:
    selected = _selected_node(payload)
    words = set()
    for value in [
        selected.get("title"),
        selected.get("label"),
        selected.get("nodeId"),
        selected.get("summary"),
        payload.get("question"),
    ]:
        words |= _kg48_words(value)

    source = _d(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    for item in _l(source.get("selectedEvidence"))[:6]:
        d = _d(item)
        words |= _kg48_words(d.get("quote") or d.get("text") or d.get("textPreview"))

    stop = {
        "the", "and", "for", "with", "that", "this", "from", "page", "table", "tables",
        "schema", "data", "using", "used", "concept", "source", "student", "teacher",
        "explain", "joined", "join", "contains", "contain", "there", "have", "has",
        "center", "central"
    }
    return {w for w in words if w not in stop}


def _kg48_make_ref(quote: Any, page: Any = None, source_ref: str = "", role: str = "kg48") -> JsonDict:
    q = _t(quote, 1200)
    if not q:
        return {}
    return {
        "chunkId": source_ref or f"kg48_p{page or 'x'}",
        "sourceRef": source_ref or f"kg48:page:{page or 'unknown'}",
        "pageRef": f"page:{page}" if page is not None else "",
        "page": page,
        "quote": q,
        "confidence": 0.9,
        "evidenceRole": role,
    }


def _kg48_is_competing_ref(quote: str, payload: JsonDict) -> bool:
    qlow = _t(quote, 1600).lower()
    selected_topic = " ".join(_kg48_topic_words(payload)).lower()

    competing_topics = [
        "galaxy schema",
        "snowflake schema",
        "fact constellation",
    ]

    for phrase in competing_topics:
        head = phrase.split()[0]
        if phrase in qlow and head not in selected_topic:
            return True
    return False


def _kg48_collect_selected_refs(payload: JsonDict) -> List[JsonDict]:
    selected_pages = _kg48_selected_pages(payload)
    refs: List[JsonDict] = []

    source = _d(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))

    for key in ["selectedEvidence", "samePageEvidence", "sourceRefs"]:
        for item in _l(source.get(key)):
            d = _d(item)
            quote = _t(d.get("quote") or d.get("text") or d.get("textPreview"), 1400)
            if not quote:
                continue

            try:
                page = int(d.get("page"))
            except Exception:
                page = d.get("page")

            # For selected/same page groups, prefer selected pages only.
            if selected_pages and key in {"selectedEvidence", "samePageEvidence"} and page not in selected_pages:
                continue

            refs.append({
                **d,
                "quote": quote,
                "evidenceRole": d.get("evidenceRole") or key,
            })

    # selectedPageFullText is strong proof for the selected node/page.
    full_text = _t(
        source.get("selectedPageFullText")
        or payload.get("selectedPageFullText")
        or source.get("selectedPageText"),
        3500,
    )
    if full_text:
        page = sorted(selected_pages)[0] if selected_pages else None
        refs.append(_kg48_make_ref(full_text, page, f"kg48:selected-page:{page}", "selectedPageFullText"))

    # selected page vision source mappings are excellent source-grounded visual proof.
    vision = _d(payload.get("selectedPageVision"))
    analyses = _l(vision.get("selectedPageAnalyses") or payload.get("selectedPageAnalyses"))
    for analysis in analyses:
        a = _d(analysis)
        if "selected" not in _t(a.get("imageRole"), 100).lower():
            continue

        page = a.get("page")

        for m in _l(a.get("sourceTextMapping")):
            mm = _d(m)
            quote = _t(mm.get("sourceQuote"), 900)
            if quote:
                refs.append(_kg48_make_ref(
                    quote,
                    page,
                    f"kg48:selected-vision:p{page}:{_slug(mm.get('visualThing') or quote, 'mapping')}",
                    "selectedVisionMapping",
                ))

        for r in _l(a.get("sourceRefs")):
            rr = _d(r)
            if _t(rr.get("quote")):
                refs.append({**rr, "evidenceRole": rr.get("evidenceRole") or "selectedVisionSourceRef"})

    # Concept-level refs, but only if selected page or topic-overlap.
    for c in _concepts(payload):
        for r in _l(_d(c).get("sourceRefs")):
            rr = _d(r)
            if _t(rr.get("quote")):
                refs.append({**rr, "evidenceRole": rr.get("evidenceRole") or "conceptSourceRef"})

    clean = []
    topic = _kg48_topic_words(payload)
    selected_pages = _kg48_selected_pages(payload)

    for ref in refs:
        r = _d(ref)
        quote = _t(r.get("quote"), 1400)
        if not quote:
            continue

        try:
            page = int(r.get("page"))
        except Exception:
            page = r.get("page")

        qwords = _kg48_words(quote)
        score = 0

        if selected_pages and page in selected_pages:
            score += 50
        elif selected_pages and page not in selected_pages:
            score -= 20

        if topic:
            score += min(20, len(qwords & topic) * 2)

        if _kg48_is_competing_ref(quote, payload):
            score -= 100

        role = _t(r.get("evidenceRole"), 100).lower()
        if role in {"nearbyevidence", "comparisonrefs", "supportrefs"}:
            score -= 10

        if len(quote.split()) < 4:
            score -= 5

        if score > 0:
            clean.append((score, r))

    clean.sort(key=lambda x: x[0], reverse=True)
    return dedupe_source_refs(normalize_source_refs([r for _, r in clean]))[:24]


def _kg48_pick_proof(refs: List[JsonDict], wanted: List[str], fallback: str = "") -> str:
    wanted_words = set()
    for w in wanted:
        wanted_words |= _kg48_words(w)

    best = ""
    best_score = -1
    for ref in refs:
        q = _t(_d(ref).get("quote"), 1200)
        if not q:
            continue
        qwords = _kg48_words(q)
        score = len(qwords & wanted_words)
        if score > best_score:
            best_score = score
            best = q

    return _t(best or fallback, 900)


def _kg48_ref_subset(refs: List[JsonDict], wanted: List[str], limit: int = 5) -> List[JsonDict]:
    wanted_words = set()
    for w in wanted:
        wanted_words |= _kg48_words(w)

    scored = []
    for ref in refs:
        r = _d(ref)
        qwords = _kg48_words(r.get("quote"))
        score = len(qwords & wanted_words)
        scored.append((score, r))

    scored.sort(key=lambda x: x[0], reverse=True)
    chosen = [r for score, r in scored if score > 0]
    return chosen[:limit] or refs[:limit]


