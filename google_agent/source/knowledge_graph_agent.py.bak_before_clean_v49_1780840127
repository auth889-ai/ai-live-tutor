        "importance": 1.0 if role == "anchor" else 0.82,
        "teachingRole": role,
        "learningGoal": _t(f"Student can explain {label} using the PDF visual and selected source proof.", 800),
        "boardPlacementHint": "center" if role == "anchor" else "around-anchor",
        "visualEncoding": _t(board, 300),
        "misconceptionRisk": "medium",
        "sourceRefs": refs[:5],
        "visualHints": visual_hints or [board],
        "targetVisualLabels": [label],
        "evidenceType": "text_plus_vision" if refs else "vision_only",
        "comparisonOnly": False,
        "needsTextConfirmation": not bool(refs),
        "metadata": {
            "teacherGradeKGV48Final": True,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


def _kg48_edge(
    edge_id: str,
    frm: str,
    to: str,
    etype: str,
    label: str,
    rationale: str,
    board: str,
    refs: List[JsonDict],
    visual: str,
) -> JsonDict:
    proof = _kg48_pick_proof(refs, [label, rationale, visual])
    edge_refs = _kg48_ref_subset(refs, [label, rationale, visual], 5)

    return {
        "edgeId": _slug(edge_id, edge_id),
        "from": frm,
        "to": to,
        "type": etype if etype in VALID_EDGE_TYPES else "visual-link",
        "label": _t(label, 260),
        "teachingRationale": _t(rationale, 1000),
        "boardActionHint": _t(board, 800),
        "teacherMove": _t(f"{label}. {rationale}", 1100),
        "sourceProof": proof,
        "visualProof": _t(visual, 1000),
        "sourceRefs": edge_refs,
        "targetVisualLabels": [],
        "evidenceType": "text_plus_vision" if edge_refs and visual else ("text_only" if edge_refs else "vision_only"),
        "comparisonOnly": False,
        "needsTextConfirmation": not bool(edge_refs),
        "metadata": {
            "teacherGradeKGV48Final": True,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


def _kg48_extract_selected_visual(payload: JsonDict) -> JsonDict:
    vision = _d(payload.get("selectedPageVision"))
    analyses = _l(vision.get("selectedPageAnalyses") or payload.get("selectedPageAnalyses"))

    selected_analysis = {}
    for a in analyses:
        aa = _d(a)
        if "selected" in _t(aa.get("imageRole"), 100).lower():
            selected_analysis = aa
            break

    packet = _visual_packet(payload)
    elements = _l(selected_analysis.get("diagramElements")) or _visual_elements(payload)
    relationships = _l(selected_analysis.get("relationships")) or _visual_relations(payload)

    return {
        "analysis": selected_analysis,
        "elements": [_d(x) for x in elements],
        "relationships": [_d(x) for x in relationships],
        "coreVisualFacts": _l(selected_analysis.get("coreVisualFacts")) or _l(packet.get("sourceGroundedVisualFacts")),
        "teacherMarkingHints": _l(selected_analysis.get("teacherMarkingHints")) or _l(packet.get("teacherMarkingScript")),
        "commonConfusions": _l(selected_analysis.get("commonConfusions")) or _l(packet.get("misconceptionRisks")),
        "summary": _t(selected_analysis.get("summary") or packet.get("pageVisualNarrative"), 1600),
    }


def _kg48_build_teacher_grade_kg(payload: JsonDict, previous: JsonDict | None = None) -> JsonDict:
    refs = _kg48_collect_selected_refs(payload)
    visual = _kg48_extract_selected_visual(payload)
    elements = visual["elements"]
    relationships = visual["relationships"]

    selected = _selected_node(payload)
    title = _t(selected.get("title") or selected.get("label") or "Selected concept", 220)

    # Find central/fact element from visual data.
    central = {}
    for e in elements:
        text = " ".join([
            _t(e.get("label"), 200),
            _t(e.get("kind"), 100),
            _t(e.get("description"), 500),
            _t(e.get("teachingMeaning"), 500),
            _t(e.get("visualRole"), 300),
        ]).lower()

        if ("fact" in text or "central" in text or "center" in text) and _t(e.get("label")):
            central = e
            break

    if not central and elements:
        central = elements[0]

    central_label = _t(central.get("label") or "central fact table", 120)
    central_id = _slug(f"{central_label}_fact_table", "central_fact_table")

    dimension_elements = []
    for e in elements:
        label = _t(e.get("label"), 120)
        if not label or label.lower() == central_label.lower():
            continue

        text = " ".join([
            label,
            _t(e.get("kind"), 100),
            _t(e.get("description"), 400),
            _t(e.get("teachingMeaning"), 400),
            _t(e.get("visualRole"), 200),
        ]).lower()

        if "dimension" in text or _t(e.get("kind")).lower() == "table":
            if "attribute" not in _t(e.get("kind"), 100).lower():
                dimension_elements.append(e)

    known_dim_labels = {_t(e.get("label"), 120).lower() for e in dimension_elements}
    for r in relationships:
        for side in ["from", "to"]:
            label = _t(r.get(side), 120)
            if label and label.lower() != central_label.lower() and label.lower() not in known_dim_labels:
                dimension_elements.append({
                    "label": label,
                    "kind": "table",
                    "description": "Dimension table from visual relationship.",
                    "teachingMeaning": _t(r.get("teachingMeaning") or r.get("whyItMatters"), 500),
                })
                known_dim_labels.add(label.lower())

    overview_ref = _kg48_ref_subset(refs, ["star", "schema", "center", "dimension", "fact"], 5)
    center_refs = _kg48_ref_subset(refs, ["center", "fact", central_label, "key", "measure"], 5)
    dim_refs = _kg48_ref_subset(refs, ["dimension", "surrounding", "attribute"], 5)
    join_refs = _kg48_ref_subset(refs, ["joined", "foreign key", "fact table"], 5)
    not_join_refs = _kg48_ref_subset(refs, ["not joined", "each other", "dimension table are not joined"], 5)

    nodes: List[JsonDict] = []

    overview_id = _slug(f"{title}_overview", "kg_overview")
    nodes.append(_kg48_node(
        overview_id,
        title,
        visual["summary"] or f"Overview of {title} from selected PDF page.",
        "overview",
        1,
        "anchor",
        "Circle the full diagram and show the star shape.",
        overview_ref,
        ["Full selected PDF page shows the concept as a visual structure."],
    ))

    nodes.append(_kg48_node(
        central_id,
        f"{central_label} as central fact table",
        _t(
            central.get("description")
            or central.get("teachingMeaning")
            or "The central fact table stores the main measurable business event and keys/measures.",
            900,
        ),
        "fact_table",
        2,
        "core",
        f"Circle/highlight the '{central_label}' table.",
        center_refs,
        [_t(central.get("teachingMeaning") or central.get("description") or f"{central_label} appears as the central table.", 700)],
    ))

    dim_group_id = "dimension_tables_group"
    dim_labels = [_t(e.get("label"), 120) for e in dimension_elements if _t(e.get("label"))]

    nodes.append(_kg48_node(
        dim_group_id,
        "Dimension tables surrounding the fact table",
        _t(f"Dimension tables such as {', '.join(dim_labels[:8])} surround the central fact table and provide descriptive context.", 900),
        "dimension_group",
        3,
        "core",
        "Highlight all surrounding dimension tables as one group.",
        dim_refs,
        [f"Visible dimension tables around {central_label}: {', '.join(dim_labels[:8])}"],
    ))

    order = 4
    used_dim_node_ids = set()
    for e in dimension_elements[:8]:
        label = _t(e.get("label"), 120)
        if not label:
            continue

        node_id = _slug(f"dimension_{label}", f"dimension_{order}")
        if node_id in used_dim_node_ids:
            continue
        used_dim_node_ids.add(node_id)

        nodes.append(_kg48_node(
            node_id,
            f"{label} dimension table",
            _t(e.get("description") or e.get("teachingMeaning") or f"{label} is a dimension table that gives context to the fact.", 700),
            "dimension_table",
            order,
            "supporting",
            f"Highlight {label} and point its connection to {central_label}.",
            dim_refs,
            [_t(e.get("teachingMeaning") or e.get("description"), 700)],
        ))
        order += 1

    join_rule_id = "dimension_to_fact_join_rule"
    no_join_rule_id = "dimension_tables_not_joined_rule"
    measure_rule_id = "fact_table_key_measure_rule"

    nodes.append(_kg48_node(
