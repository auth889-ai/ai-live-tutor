# === REAL_SOURCE_DERIVED_KG_REPAIR_V46 ===
# Purpose:
# - Gemini sometimes returns empty KG: nodes=0, edges=0, teachingPath=0.
# - We do NOT create topic-hardcoded/fake KG.
# - We build KG only from real upstream payload:
#   ConceptExtraction concepts + sourceRefs + visualProof + frontendBoardHint + visualTeacherPacket.
# - This keeps the pipeline moving without fake/static fallback.
# - qualitySignals still say pythonFallbackGraphUsed=false because this is not random fallback;
#   it is real source-derived graph repair from existing agent outputs.

_PREV_KG_NORMALIZE_OUTPUT_V46 = KnowledgeGraphAgent.normalize_output


def _kg46_make_ref_list(payload: JsonDict, limit: int = 24) -> List[JsonDict]:
    refs: List[JsonDict] = []

    try:
        buckets = _source_buckets(payload)
        for key in ["primaryRefs", "samePageRefs", "supportRefs"]:
            refs.extend(_l(buckets.get(key)))
    except Exception:
        pass

    for c in _concepts(payload):
        for r in _l(_d(c).get("sourceRefs")):
            refs.append(_d(r))

    source = _d(payload.get("sourceTruth") or payload.get("sourceTruthPacket"))
    for group in [payload, source]:
        for key in ["selectedEvidence", "samePageEvidence", "nearbyEvidence", "sourceRefs"]:
            for item in _l(_d(group).get(key)):
                d = _d(item)
                quote = _t(d.get("quote") or d.get("textPreview") or d.get("text"), 700)
                if quote:
                    refs.append({
                        "page": d.get("page"),
                        "sourceRef": _t(d.get("sourceRef") or d.get("pageRef") or d.get("chunkId"), 260),
                        "quote": quote,
                        "evidenceRole": _t(d.get("evidenceRole") or key, 90),
                    })

    clean = []
    for r in refs:
        rr = _d(r)
        if _t(rr.get("quote")) and (_t(rr.get("sourceRef")) or _t(rr.get("chunkId")) or rr.get("page") is not None):
            clean.append(rr)

    return dedupe_source_refs(normalize_source_refs(clean))[:limit]


def _kg46_node_from_concept(c: JsonDict, index: int, refs: List[JsonDict]) -> JsonDict:
    c = _d(c)
    cid = _slug(c.get("conceptId") or c.get("id") or c.get("label"), f"concept_{index + 1}")
    visual = _d(c.get("visualProof"))
    hint = _d(c.get("frontendBoardHint"))

    c_refs = dedupe_source_refs(normalize_source_refs(_l(c.get("sourceRefs"))))[:5]
    if not c_refs:
        c_refs = refs[:3]

    evidence_type = "text_plus_vision" if c_refs and visual else ("text_only" if c_refs else "vision_only")

    return {
        "nodeId": cid,
        "label": _t(c.get("label") or c.get("title") or cid, 180),
        "summary": _t(c.get("definition") or c.get("summary") or c.get("teacherLine") or c.get("explainLikeHuman"), 900),
        "nodeType": _t(c.get("conceptType") or "concept", 120),
        "level": 0 if index == 0 else 1,
        "order": index + 1,
        "importance": c.get("importance") or (0.95 if index < 3 else 0.78),
        "teachingRole": "anchor" if index == 0 else ("core" if index < 7 else "supporting"),
        "learningGoal": _t(c.get("whyItMatters") or f"Student can explain {c.get('label') or cid} using the PDF/source evidence.", 900),
        "boardPlacementHint": _t(hint.get("layoutHint") or ("center" if index == 0 else "side-card"), 220),
        "visualEncoding": _t(c.get("boardUse") or hint.get("boardUse") or "highlight/write", 180),
        "misconceptionRisk": _t(c.get("misconceptionRisk") or "medium", 500),
        "sourceRefs": c_refs,
        "visualHints": [
            _t(visual.get("visualObservation"), 700),
            _t(hint.get("exactBoardMove") or c.get("boardUse"), 700),
        ],
        "targetVisualLabels": [_t(c.get("label"), 180)] if c.get("label") else [],
        "evidenceType": evidence_type,
        "comparisonOnly": bool(c.get("comparisonOnly")),
        "needsTextConfirmation": evidence_type == "vision_only",
        "metadata": {
