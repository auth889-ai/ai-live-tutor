AGENT_ORDER: List[str] = list(AGENT_CLASSES.keys())


def agent_count() -> int:
    return len(AGENT_CLASSES)


def get_agent(agent_name: str) -> BaseLiveTutorAgent:
    if agent_name not in AGENT_CLASSES:
        raise KeyError(f"Unknown live tutor agent: {agent_name}. Available: {', '.join(AGENT_ORDER)}")
    return AGENT_CLASSES[agent_name]()


def list_agents() -> List[JsonDict]:
    items: List[JsonDict] = []
    for index, name in enumerate(AGENT_ORDER, start=1):
        agent = get_agent(name)
        health = agent.health().to_dict()
        items.append(
            {
                "index": index,
                "name": name,
                "group": getattr(agent, "agent_group", "unknown"),
                "usesAdk": getattr(agent, "uses_adk", False),
                "separateFile": True,
                "healthOk": bool(health.get("ok")),
                "fallbackUsed": False,
            }
        )
    return items


def now_ms() -> int:
    return int(time.time() * 1000)


def env_true(name: str, fallback: bool = False) -> bool:
    raw = os.getenv(name)
    if raw is None or raw == "":
        return fallback
    return raw.strip().lower() in {"1", "true", "yes", "y", "on"}


def env_int(name: str, fallback: int) -> int:
    raw = os.getenv(name)
    try:
        value = int(raw or "")
        return value if value > 0 else fallback
    except Exception:
        return fallback


def per_agent_timeout_ms(payload: JsonDict, agent_name: str) -> int:
    overrides = safe_dict(payload.get("agentTimeoutsMs") or payload.get("agentTimeouts"))
    raw = overrides.get(agent_name)
    if raw:
        try:
            return max(5000, int(raw))
        except Exception:
            pass

    if payload.get("stage2AgentTimeoutMs"):
        try:
            return max(5000, int(payload.get("stage2AgentTimeoutMs")))
        except Exception:
            pass

    return env_int("STAGE2_AGENT_TIMEOUT_MS", 60000)


async def run_agent(agent_name: str, payload: JsonDict) -> JsonDict:
    agent = get_agent(agent_name)
    result_or_coro = agent.run(payload)
    result = await result_or_coro if inspect.isawaitable(result_or_coro) else result_or_coro

    if hasattr(result, "to_dict"):
        return result.to_dict()

    if isinstance(result, dict):
        return {
            "ok": bool(result.get("ok", True)),
            "agentName": agent_name,
            "mode": clean_text(payload.get("mode") or "run", 80),
            "result": result,
            "validation": {
                "ok": True,
                "errors": [],
                "warnings": [],
                "fallbackUsed": False,
            },
            "errors": [],
            "warnings": [],
            "metadata": {
                **safe_dict(result.get("metadata")),
                "fallbackUsed": False,
                "usedSmartFallback": False,
            },
        }

    raise RuntimeError(f"{agent_name} returned unsupported result type: {type(result).__name__}")


async def run_agent_with_timeout(agent_name: str, payload: JsonDict) -> JsonDict:
    timeout_ms = per_agent_timeout_ms(payload, agent_name)
    try:
        return await asyncio.wait_for(run_agent(agent_name, payload), timeout=timeout_ms / 1000)
    except asyncio.TimeoutError as exc:
        raise TimeoutError(f"{agent_name} timed out after {timeout_ms}ms") from exc


def run_agent_sync(agent_name: str, payload: JsonDict) -> JsonDict:
    return asyncio.run(run_agent(agent_name, payload))


async def health_all() -> JsonDict:
    results: List[JsonDict] = []
    ok = True

    for name in AGENT_ORDER:
        agent = get_agent(name)
        result = agent.health().to_dict()
        results.append(result)
        ok = ok and bool(result.get("ok"))

    return {
        "ok": ok,
        "agentCount": agent_count(),
        "agents": list_agents(),
        "health": results,
        "metadata": {
            "realSeparateAgents": True,
            "selectedPageVisionAgentRegistered": "SelectedPageVisionAgent" in AGENT_CLASSES,
            "fallbackUsed": False,
            "brokenAgents": [r.get("agentName") for r in results if not r.get("ok")],
        },
    }


