async def run_optional_agent(
    agent_name: str,
    payload: JsonDict,
    trace: List[JsonDict],
    mission_trace: List[JsonDict],
    summary: str,
    phase: str,
) -> JsonDict:
    started = now_ms()
    try:
        result = await run_agent_with_timeout(agent_name, payload)
        result.setdefault("metadata", {})
        result["metadata"]["runtimeMs"] = now_ms() - started
        trace.append(trace_item(agent_name, result, summary, phase))
        mission_trace.append(mission_item(agent_name, "done" if result.get("ok") else "failed", summary))
        return result
    except Exception as exc:
        result = {
            "ok": False,
            "agentName": agent_name,
            "mode": payload.get("mode") or "run",
            "result": {},
            "errors": [str(exc)],
            "warnings": [],
            "metadata": {
                "fallbackUsed": False,
                "usedSmartFallback": False,
                "optionalAgentFailed": True,
                "runtimeMs": now_ms() - started,
            },
        }
        trace.append(trace_item(agent_name, result, f"{summary} failed: {exc}", phase))
        mission_trace.append(mission_item(agent_name, "failed", f"{summary}: {exc}"))
        return result


async def run_required_agent(
    agent_name: str,
    payload: JsonDict,
    trace: List[JsonDict],
    mission_trace: List[JsonDict],
    summary: str,
    phase: str,
) -> JsonDict:
    started = now_ms()
    try:
        result = await run_agent_with_timeout(agent_name, payload)
        result.setdefault("metadata", {})
        result["metadata"]["runtimeMs"] = now_ms() - started
        trace.append(trace_item(agent_name, result, summary, phase))
        mission_trace.append(mission_item(agent_name, "done" if result.get("ok") else "failed", summary))
        require_ok(agent_name, result)
        return result
    except Exception as exc:
        already_traced = bool(trace and safe_dict(trace[-1]).get("agent") == agent_name)
        if not already_traced:
            failed_result = {
                "ok": False,
                "agentName": agent_name,
                "mode": payload.get("mode") or "run",
                "result": {},
                "errors": [str(exc)],
                "warnings": [],
                "metadata": {
                    "fallbackUsed": False,
                    "usedSmartFallback": False,
                    "requiredAgentFailed": True,
                    "runtimeMs": now_ms() - started,
                },
            }
            trace.append(trace_item(agent_name, failed_result, f"{summary} failed: {exc}", phase))
            mission_trace.append(mission_item(agent_name, "failed", f"{summary}: {exc}"))
        raise


async def run_mcp_mission_step(
    mode: str,
    payload: JsonDict,
    trace: List[JsonDict],
    mission_trace: List[JsonDict],
    mcp_trace: List[JsonDict],
    tool_trace: List[JsonDict],
    summary: str,
    require_mcp: bool = False,
) -> JsonDict:
    result = await run_optional_agent(
        "MongoDbMcpToolAgent",
        {**payload, "mode": mode, "missionPayload": payload},
        trace,
        mission_trace,
        summary,
        "partner-mcp",
    )

    res = output_result(result)
    metadata = safe_dict(res.get("metadata") or result.get("metadata"))
    tool_calls = safe_list(res.get("toolCalls"))
    mcp_used = bool(res.get("mcpUsed") or metadata.get("realMcpUsed"))

    mcp_item = {
        "mode": mode,
        "ok": bool(result.get("ok")),
        "mcpUsed": mcp_used,
        "partner": "MongoDB",
        "summary": summary,
        "toolCalls": tool_calls,
        "errors": result.get("errors") or [],
        "metadata": metadata,
    }

    mcp_trace.append(mcp_item)
    tool_trace.extend(tool_calls)

    if require_mcp and not mcp_used:
        raise RuntimeError(
            f"MongoDB MCP is required but not used in mode={mode}. "
            f"Errors={result.get('errors') or mcp_item}"
        )

    return res


