def first_list(*values: Any) -> List[Any]:
    for value in values:
        if isinstance(value, list) and value:
            return value
    return []


def collect_source_refs(*values: Any) -> List[JsonDict]:
    refs: List[JsonDict] = []

    def walk(value: Any) -> None:
        if isinstance(value, list):
            for item in value:
                walk(item)
            return

        if isinstance(value, dict):
            local = value.get("sourceRefs")
            if isinstance(local, list):
                refs.extend([safe_dict(x) for x in local if safe_dict(x)])
            for item in value.values():
                if isinstance(item, (dict, list)):
                    walk(item)

    for value in values:
        walk(value)

    return dedupe_source_refs(refs)


def source_refs_from_chunks(chunks: List[JsonDict]) -> List[JsonDict]:
    refs: List[JsonDict] = []

    for raw in safe_list(chunks):
        chunk = safe_dict(raw)
        chunk_id = clean_text(chunk.get("chunkId") or chunk.get("id") or "", 220)
        page = chunk.get("page") or chunk.get("pageNumber") or 1
        resource_id = clean_text(chunk.get("resourceId") or chunk.get("resource_id") or "", 180)

        if not chunk_id and not resource_id:
            continue

        refs.append(
            {
                "chunkId": chunk_id or f"{resource_id}_p{page}_c0",
                "sourceRef": clean_text(chunk.get("sourceRef") or chunk.get("ref") or chunk_id, 300),
                "pageRef": clean_text(chunk.get("pageRef") or chunk.get("sourceRef") or chunk_id, 300),
                "page": page,
                "quote": clean_text(chunk.get("textPreview") or chunk.get("text") or chunk.get("ocrText") or "", 900),
                "confidence": chunk.get("confidence") or 0.75,
                "resourceId": resource_id,
            }
        )

    return dedupe_source_refs(refs)


def stable_refs(payload: JsonDict, chunks: List[JsonDict]) -> List[JsonDict]:
    return dedupe_source_refs(
        safe_list(payload.get("sourceRefs"))
        or safe_list(payload.get("selectedSourceRefs"))
        or collect_source_refs(payload.get("selectedNode"), payload.get("node"), chunks)
        or source_refs_from_chunks(chunks)
    )


def has_image_refs(value: Any) -> bool:
    found = False

    def walk(item: Any) -> None:
        nonlocal found
        if found:
            return

        if isinstance(item, list):
            for child in item:
                walk(child)
            return

        if isinstance(item, dict):
            if any(
                clean_text(item.get(key))
                for key in ["pageImageUrl", "pageImagePath", "imageUrl", "imagePath", "url", "src", "path"]
            ):
                found = True
                return
            for child in item.values():
                if isinstance(child, (dict, list)):
                    walk(child)

    walk(value)
    return found


def merge_visual_context(*contexts: Any) -> JsonDict:
    merged: JsonDict = {
        "pageImages": [],
        "pageContexts": [],
        "pageImageAnalyses": [],
        "detectedDiagrams": [],
        "visualTeachingHints": [],
        "tables": [],
        "figures": [],
        "layoutBlocks": [],
        "metadata": {},
    }

    seen: Dict[str, set] = {key: set() for key in merged if key != "metadata"}

    def add_unique(key: str, item: Any, marker: str = "") -> None:
        marker = marker or clean_text(item, 500) or str(len(merged[key]))
        if marker in seen[key]:
            return
        seen[key].add(marker)
        merged[key].append(item)

    for raw in contexts:
        context = safe_dict(raw)
        if not context:
            continue

        for item_raw in safe_list(context.get("pageImages")):
            item = safe_dict(item_raw)
            marker = (
                f"{item.get('page')}|"
                f"{item.get('url') or item.get('src') or item.get('pageImageUrl')}|"
                f"{item.get('path') or item.get('pageImagePath')}"
            )
            add_unique("pageImages", item, marker)

        for item_raw in safe_list(context.get("pageContexts")):
            item = safe_dict(item_raw)
            marker = f"{item.get('page')}|{item.get('relation')}"
            add_unique("pageContexts", item, marker)

        for item_raw in safe_list(context.get("pageImageAnalyses")):
            item = safe_dict(item_raw)
            marker = f"{item.get('page')}|{item.get('visualType')}|{clean_text(item.get('summary'), 120)}"
            add_unique("pageImageAnalyses", item, marker)

        for item_raw in safe_list(context.get("detectedDiagrams")):
            item = safe_dict(item_raw)
            marker = f"{item.get('page')}|{item.get('diagramType')}|{item.get('title')}"
            add_unique("detectedDiagrams", item, marker)

        for hint in safe_list(context.get("visualTeachingHints")):
            marker = clean_text(hint, 260)
            if marker:
                add_unique("visualTeachingHints", marker, marker)

        for key in ["tables", "figures", "layoutBlocks"]:
            for item in safe_list(context.get(key)):
                add_unique(key, item, clean_text(item, 260))

        merged["metadata"].update(safe_dict(context.get("metadata")))

    merged["metadata"].update(
        {
            "mergedVisualContext": True,
            "pageImageCount": len(merged["pageImages"]),
            "pageImageAnalysisCount": len(merged["pageImageAnalyses"]),
            "detectedDiagramCount": len(merged["detectedDiagrams"]),
            "geminiVisionPageImagesAvailable": len(merged["pageImages"]) > 0,
            "selectedPageVisionUsed": len(merged["pageImageAnalyses"]) > 0,
            "modelVisionUsed": bool(merged["metadata"].get("modelVisionUsed"))
            or len(merged["pageImageAnalyses"]) > 0,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        }
    )

    return merged


def _clip_text_for_visual_planner(value: Any, limit: int = 1200) -> str:
    return clean_text(value or "", limit)


def _dedupe_strings_for_visual_planner(items: Any, limit: int = 20, text_limit: int = 500) -> List[str]:
    out: List[str] = []
    seen = set()

    for raw in safe_list(items):
        text = clean_text(raw, text_limit)
        if not text:
            continue
        key = text.lower()
        if key in seen:
            continue
        seen.add(key)
        out.append(text)
        if len(out) >= limit:
            break

    return out


def _dedupe_dicts_for_visual_planner(items: Any, key_fields: Optional[List[str]] = None, limit: int = 20) -> List[JsonDict]:
    out: List[JsonDict] = []
    seen = set()
    fields = key_fields or ["label", "from", "to", "relationship", "title", "page", "target"]

    for raw in safe_list(items):
        item = safe_dict(raw)
        if not item:
            continue

        key_parts = []
        for field in fields:
            value = item.get(field)
            if value not in (None, "", [], {}):
                key_parts.append(clean_text(value, 140))

        if not key_parts:
            key_parts.append(clean_text(item, 240))

        key = "|".join(key_parts).lower()
        if key in seen:
            continue

        seen.add(key)
        out.append(item)

        if len(out) >= limit:
            break

    return out


def _compact_source_ref_for_visual_planner(ref: Any) -> JsonDict:
    item = safe_dict(ref)
    return {
        "chunkId": clean_text(item.get("chunkId") or item.get("id") or "", 180),
        "sourceRef": clean_text(item.get("sourceRef") or item.get("ref") or item.get("pageRef") or "", 260),
        "pageRef": clean_text(item.get("pageRef") or item.get("sourceRef") or "", 260),
        "page": item.get("page") or item.get("pageNumber"),
        "quote": clean_text(item.get("quote") or item.get("text") or item.get("textPreview") or "", 900),
        "confidence": item.get("confidence"),
        "resourceId": clean_text(item.get("resourceId") or "", 180),
    }


def _compact_evidence_for_visual_planner(items: Any, fallback_refs: List[JsonDict], limit: int = 8) -> List[JsonDict]:
    out: List[JsonDict] = []
    seen = set()

    for raw in safe_list(items):
        item = safe_dict(raw)
        if not item:
            continue

        quote = clean_text(
            item.get("quote")
            or item.get("text")
            or item.get("textPreview")
            or item.get("ocrText")
            or item.get("content")
            or "",
            1200,
        )
        page = item.get("page") or item.get("pageNumber") or item.get("pageNo")
        refs = dedupe_source_refs([safe_dict(x) for x in safe_list(item.get("sourceRefs"))]) or ([item] if item else [])
        refs = [_compact_source_ref_for_visual_planner(x) for x in refs if safe_dict(x)]

        key = f"{page}|{quote[:140]}".lower()
        if key in seen:
            continue
        seen.add(key)

        if quote or refs:
            out.append({
                "page": page,
                "role": clean_text(item.get("evidenceRole") or item.get("role") or "evidence", 80),
                "quote": quote,
                "sourceRefs": refs[:4],
                "figures": safe_list(item.get("figures"))[:2],
                "tables": safe_list(item.get("tables"))[:2],
            })

        if len(out) >= limit:
            break

    if not out:
        for ref in fallback_refs[:limit]:
            out.append({
                "page": ref.get("page"),
                "role": "sourceRef",
                "quote": clean_text(ref.get("quote") or "", 900),
                "sourceRefs": [ref],
            })

    return out[:limit]


