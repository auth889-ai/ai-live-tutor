class BrokenLiveTutorAgent(BaseLiveTutorAgent):
    agent_name = "BrokenLiveTutorAgent"
    agent_group = "broken-import"
    default_mode = "broken"
    uses_adk = False

    def __init__(self, missing_agent_name: str, import_path: str, error: Exception) -> None:
        super().__init__()
        self.missing_agent_name = missing_agent_name
        self.import_path = import_path
        self.error = error
        self.agent_name = missing_agent_name

    @property
    def instruction(self) -> str:
        return "This agent failed to import. No fake fallback."

    def validate_input(self, payload: JsonDict) -> ValidationResult:
        return ValidationResult(
            ok=False,
            errors=[
                f"{self.missing_agent_name} is not importable: "
                f"{type(self.error).__name__}: {self.error}"
            ],
            warnings=[],
            validator=f"{self.missing_agent_name}.validate_input",
            fallbackUsed=False,
        )

    def build_prompt(self, payload: JsonDict, context: Any) -> str:
        return ""

    def normalize_output(self, raw: JsonDict, payload: JsonDict, context: Any) -> JsonDict:
        return {}

    def validate_output(self, output: JsonDict, payload: JsonDict, context: Any) -> ValidationResult:
        return ValidationResult(
            ok=False,
            errors=[f"{self.missing_agent_name} is broken and cannot output data."],
            warnings=[],
            validator=f"{self.missing_agent_name}.validate_output",
            fallbackUsed=False,
        )

    def run_without_adk(self, payload: JsonDict, context: Any) -> JsonDict:
        raise RuntimeError(
            f"{self.missing_agent_name} failed to import from {self.import_path}: {self.error}"
        )


class BrokenLiveTutorAgentFactory:
    def __init__(self, missing_agent_name: str, import_path: str, error: Exception) -> None:
        self.missing_agent_name = missing_agent_name
        self.import_path = import_path
        self.error = error

    def __call__(self) -> BrokenLiveTutorAgent:
        return BrokenLiveTutorAgent(self.missing_agent_name, self.import_path, self.error)


def _load_agent(class_name: str, module_path: str):
    try:
        module = importlib.import_module(module_path)
        return getattr(module, class_name)
    except Exception as exc:
        return BrokenLiveTutorAgentFactory(class_name, module_path, exc)


