def build_visual_planner_packet(
    working: JsonDict,
    grounded_refs: List[JsonDict],
    explanation_result: JsonDict,
    analogy_result: JsonDict,
    strategy_result: JsonDict,
) -> JsonDict:
    visual_lesson = safe_dict(working.get("visualLessonInput"))
    selected_node_obj = selected_node(working)

    refs = dedupe_source_refs(
        [_compact_source_ref_for_visual_planner(x) for x in grounded_refs]
        + [_compact_source_ref_for_visual_planner(x) for x in safe_list(visual_lesson.get("sourceRefs"))]
        + [_compact_source_ref_for_visual_planner(x) for x in stable_refs(working, safe_list(working.get("selectedEvidence") or working.get("chunks")))]
    )
    refs = refs[:30]

    selected_analyses = safe_list(visual_lesson.get("selectedPageAnalyses"))
    nearby_analyses = safe_list(visual_lesson.get("nearbyPageAnalyses"))
    page_analyses = safe_list(visual_lesson.get("pageImageAnalyses"))

    selected_page_analysis = _analysis_summary_for_visual_planner(selected_analyses[0] if selected_analyses else (page_analyses[0] if page_analyses else {}))
    nearby_page_summaries = [_analysis_summary_for_visual_planner(x) for x in nearby_analyses[:3]]

    selected_text = clean_text(
        visual_lesson.get("selectedPageFullText")
        or working.get("selectedPageFullText")
        or "",
        6500,
    )

    full_outline = safe_dict(visual_lesson.get("fullPdfOutline") or working.get("fullPdfOutline"))
    outline_items = safe_list(full_outline.get("outline"))[:30]
    relevant_outline = []
    selected_pages = set()
    for ref in refs:
        page = safe_dict(ref).get("page")
        if page:
            selected_pages.add(page)

    for item in outline_items:
        obj = safe_dict(item)
        page = obj.get("page")
        if page in selected_pages or (isinstance(page, int) and any(abs(page - p) <= 2 for p in selected_pages if isinstance(p, int))):
