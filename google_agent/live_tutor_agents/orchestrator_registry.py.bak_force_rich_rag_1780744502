async def run_selected_page_vision_direct(
    payload: JsonDict,
    trace: List[JsonDict],
    mission_trace: List[JsonDict],
) -> JsonDict:
    started = now_ms()

    try:
        module = importlib.import_module("google_agent.source.selected_page_vision_agent")
        collect_images = getattr(module, "collect_images_from_context")
        call_vision = getattr(module, "call_gemini_vision_for_image")
        merge_results = getattr(module, "merge_vision_results")
    except Exception as exc:
        raise RuntimeError(f"SelectedPageVisionAgent helpers are not importable: {exc}") from exc

    max_images = int(
        payload.get("maxSelectedPageVisionImages")
        or payload.get("maxVisionImages")
        or os.getenv("SELECTED_PAGE_VISION_MAX_IMAGES")
        or 3
    )
    max_images = max(1, min(max_images, 5))
    images = collect_images(payload, max_images=max_images)

    if not images:
        result = {
            "selectedPageVisionUsed": False,
            "pageImageAnalyses": [],
            "detectedDiagrams": [],
            "tables": [],
            "layoutBlocks": [],
            "diagramSummary": "",
            "visualTeachingHints": [],
            "metadata": {
                "selectedPageVisionAgentConnected": True,
                "selectedPageVisionUsed": False,
                "imageBytesLoaded": False,
                "geminiVisionCalled": False,
                "modelVisionUsed": False,
                "pageImageAnalysisCount": 0,
                "detectedDiagramCount": 0,
                "fallbackUsed": False,
                "usedSmartFallback": False,
                "skipReason": "no_page_images",
                "runtimeMs": now_ms() - started,
            },
        }
        trace.append(
            {
                "agent": "SelectedPageVisionAgent",
                "phase": "source-vision",
                "ok": True,
                "status": "skipped",
                "summary": "No page image available.",
                "fallbackUsed": False,
                "atMs": now_ms(),
            }
        )
        mission_trace.append(mission_item("SelectedPageVisionAgent", "skipped", "No page image available."))
        return result

    async def one(index: int, image: JsonDict) -> JsonDict:
        return await asyncio.to_thread(call_vision, payload, image, index)

    timeout_ms = per_agent_timeout_ms(payload, "SelectedPageVisionAgent")
    try:
        tasks = [one(index, image) for index, image in enumerate(images)]
        results = await asyncio.wait_for(asyncio.gather(*tasks), timeout=timeout_ms / 1000)
    except asyncio.TimeoutError as exc:
        raise TimeoutError(f"SelectedPageVisionAgent timed out after {timeout_ms}ms") from exc

    merged = merge_results(results, payload)
    meta = _vision_meta(merged)
    merged["metadata"] = {
        **safe_dict(merged.get("metadata")),
        **meta,
        "runtimeMs": now_ms() - started,
    }
    merged["selectedPageVisionUsed"] = bool(meta["selectedPageVisionUsed"])

    trace.append(
        {
            "agent": "SelectedPageVisionAgent",
            "phase": "source-vision",
            "ok": True,
            "status": "done",
            "summary": "Gemini Vision analyzed selected PDF page image bytes.",
            **meta,
            "atMs": now_ms(),
        }
    )
    mission_trace.append(
        mission_item(
            "SelectedPageVisionAgent",
            "done",
            "Gemini Vision analyzed selected PDF page image bytes.",
            meta,
        )
    )
    return merged


