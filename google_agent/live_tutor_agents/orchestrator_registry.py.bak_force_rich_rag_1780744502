    require_vision_when_image_exists = env_true("LIVE_TUTOR_REQUIRE_SELECTED_PAGE_VISION", True) or bool(
        payload.get("requireSelectedPageVision")
    )

    working = dict(payload)
    chunks = safe_list(
        working.get("selectedEvidence")
        or working.get("exactChunks")
        or working.get("selectedNodeExactChunks")
        or working.get("chunks")
        or working.get("retrievedChunks")
    )

    input_refs = stable_refs(working, chunks)

    if not chunks:
        raise RuntimeError("Teach-node mission requires exact selected PDF chunks. No chunks = no lesson.")
    if not input_refs:
        raise RuntimeError("Teach-node mission requires sourceRefs. No sourceRefs = no board.")

    mission_trace.append(
        mission_item("MissionPlannerAgent", "done", f"Plan selected-node lesson for {get_title(working)}")
    )

    if not bool(working.get("skipMcpRead")):
        mcp_read = await run_mcp_mission_step(
            "mission_read_context",
            {
                **working,
                "chunks": chunks,
                "sourceRefs": input_refs,
                "selectedNode": selected_node(working),
            },
            trace,
            mission_trace,
            mcp_trace,
            tool_trace,
            "Read resource/tree/chunk/session context using MongoDB MCP.",
            require_mcp=require_mcp,
        )
    else:
        mcp_read = {}

    if safe_list(mcp_read.get("chunks")):
        chunks = safe_list(mcp_read.get("chunks"))
    if safe_list(mcp_read.get("sourceRefs")):
        input_refs = dedupe_source_refs(safe_list(mcp_read.get("sourceRefs")))

    working.update(
        {
            "chunks": chunks,
            "sourceRefs": input_refs,
            "groundedRefs": input_refs,
            "verifiedSourceRefs": input_refs,
            "mcpContext": mcp_read,
            "mcpTrace": mcp_trace,
            "toolTrace": tool_trace,
            "partnerPower": build_partner_power(mcp_trace),
        }
    )

    if should_skip_rag(working):
        rag_result = {
            "chunks": chunks,
            "selectedEvidence": safe_list(working.get("selectedEvidence")) or chunks,
            "samePageEvidence": safe_list(working.get("samePageEvidence")),
            "nearbyEvidence": safe_list(working.get("nearbyEvidence")),
            "relatedEvidence": safe_list(working.get("relatedEvidence")),
            "comparisonEvidence": safe_list(working.get("comparisonEvidence")),
            "externalEvidence": safe_list(working.get("externalEvidence")),
            "pageContexts": safe_list(working.get("pageContexts")),
            "pageImages": safe_list(working.get("pageImages")),
            "visualContext": safe_dict(working.get("visualContext")),
            "sourceRefs": input_refs,
            "metadata": {
                "ragSkippedBecauseNodeContextAlreadyBuilt": True,
                "fallbackUsed": False,
                "usedSmartFallback": False,
            },
        }
        trace.append(
            {
                "agent": "RagRetrievalAgent",
                "phase": "source",
                "ok": True,
                "status": "skipped",
                "summary": "Skipped expensive RAG because Node/sourceContextBuilder already supplied selected context.",
                "fallbackUsed": False,
                "atMs": now_ms(),
            }
        )
        mission_trace.append(
            mission_item(
                "RagRetrievalAgent",
                "skipped",
                "Skipped expensive RAG because selected context already exists.",
            )
        )
    else:
        rag = await run_required_agent(
            "RagRetrievalAgent",
            {
                **working,
                "mode": working.get("ragMode") or "retrieve_local",
                "query": working.get("query") or working.get("question") or get_title(working),
                "chunks": chunks,
                "sourceRefs": input_refs,
            },
            trace,
            mission_trace,
            "Retrieved selected-node PDF context.",
            "source",
        )
        rag_result = output_result(rag)

    retrieved_chunks = safe_list(rag_result.get("chunks")) or chunks
    rag_refs = dedupe_source_refs(stable_refs(rag_result, retrieved_chunks) or input_refs)

    rag_visual_context = merge_visual_context(
        working.get("visualContext"),
        rag_result.get("visualContext"),
        {"pageImages": safe_list(working.get("pageImages"))},
        {"pageContexts": safe_list(working.get("pageContexts"))},
    )

    rag_page_images = (
        safe_list(working.get("pageImages"))
        + safe_list(rag_result.get("pageImages"))
        + safe_list(rag_visual_context.get("pageImages"))
    )

    working.update(
        {
            "chunks": retrieved_chunks,
            "retrievedChunks": retrieved_chunks,
            "selectedEvidence": safe_list(rag_result.get("selectedEvidence"))
            or safe_list(working.get("selectedEvidence"))
            or retrieved_chunks,
            "samePageEvidence": safe_list(rag_result.get("samePageEvidence"))
            or safe_list(working.get("samePageEvidence")),
            "nearbyEvidence": safe_list(rag_result.get("nearbyEvidence"))
            or safe_list(working.get("nearbyEvidence")),
            "relatedEvidence": safe_list(rag_result.get("relatedEvidence"))
            or safe_list(working.get("relatedEvidence")),
            "comparisonEvidence": safe_list(rag_result.get("comparisonEvidence"))
            or safe_list(working.get("comparisonEvidence")),
            "externalEvidence": safe_list(rag_result.get("externalEvidence"))
            or safe_list(working.get("externalEvidence")),
            "pageContexts": safe_list(rag_result.get("pageContexts"))
            or safe_list(working.get("pageContexts")),
            "pageImages": rag_page_images,
            "visualContext": rag_visual_context,
            "sourceRefs": rag_refs,
            "groundedRefs": rag_refs,
            "verifiedSourceRefs": rag_refs,

            # Preserve full source handoff for downstream agents and checkpoint debug.
            "ragRetrieval": rag_result,
            "sourceTruthPacket": {
                "selectedEvidence": safe_list(rag_result.get("selectedEvidence"))
                    or safe_list(working.get("selectedEvidence"))
                    or retrieved_chunks,
                "samePageEvidence": safe_list(rag_result.get("samePageEvidence"))
                    or safe_list(working.get("samePageEvidence")),
                "nearbyEvidence": safe_list(rag_result.get("nearbyEvidence"))
                    or safe_list(working.get("nearbyEvidence")),
                "relatedEvidence": safe_list(rag_result.get("relatedEvidence"))
                    or safe_list(working.get("relatedEvidence")),
                "comparisonEvidence": safe_list(rag_result.get("comparisonEvidence"))
                    or safe_list(working.get("comparisonEvidence")),
                "externalEvidence": safe_list(rag_result.get("externalEvidence"))
                    or safe_list(working.get("externalEvidence")),
                "pageContexts": safe_list(rag_result.get("pageContexts"))
                    or safe_list(working.get("pageContexts")),
                "sourceRefs": rag_refs,
                "selectedPageFullText": clean_text(
                    working.get("selectedPageFullText")
                    or working.get("selectedPageFullTextExcerpt")
                    or "",
                    30000,
                ),
                "fullPdfSummary": clean_text(
                    working.get("fullPdfSummary")
                    or working.get("pdfSummary")
                    or "",
                    30000,
                ),
                "fullPdfOutline": working.get("fullPdfOutline"),
                "fullPdfOutlineText": clean_text(
                    working.get("fullPdfOutlineText")
                    or "",
                    30000,
                ),
                "diagramHints": safe_list(rag_result.get("diagramHints")),
                "contentFlags": safe_dict(rag_result.get("contentFlags")),
                "metadata": {
                    **safe_dict(rag_result.get("metadata")),
                    "sourceTruthPacketV1": True,
                    "preserveHugePayloadForDownstreamAgents": True,
                    "fallbackUsed": False,
                    "usedSmartFallback": False,
                },
            },
        }
    )

    image_exists = has_image_refs(
        {
            "pageImages": working.get("pageImages"),
            "visualContext": working.get("visualContext"),
            "pageContexts": working.get("pageContexts"),
            "selectedEvidence": working.get("selectedEvidence"),
            "samePageEvidence": working.get("samePageEvidence"),
            "chunks": working.get("chunks"),
        }
    )

    if image_exists:
        selected_page_vision_result = await run_selected_page_vision_direct(working, trace, mission_trace)
        vision_meta = _vision_meta(selected_page_vision_result)

        if require_vision_when_image_exists and not vision_meta["geminiVisionCalled"]:
            raise RuntimeError("Page images exist but SelectedPageVisionAgent did not call Gemini Vision.")

        merged_visual_context = merge_visual_context(
            working.get("visualContext"),
            {
                "pageImageAnalyses": selected_page_vision_result.get("pageImageAnalyses"),
                "detectedDiagrams": selected_page_vision_result.get("detectedDiagrams"),
                "visualTeachingHints": selected_page_vision_result.get("visualTeachingHints"),
                "metadata": safe_dict(selected_page_vision_result.get("metadata")),
            },
        )

        working.update(
            {
                "selectedPageVision": selected_page_vision_result,
                "selectedPageVisionUsed": True,
                "pageImageAnalyses": safe_list(selected_page_vision_result.get("pageImageAnalyses")),
                "detectedVisualDiagrams": safe_list(selected_page_vision_result.get("detectedDiagrams")),
                "selectedPageVisionDiagramSummary": clean_text(
                    selected_page_vision_result.get("diagramSummary"),
                    12000,
                ),
                "visualTeachingHints": safe_list(selected_page_vision_result.get("visualTeachingHints")),
                "visualContext": merged_visual_context,
            }
        )
    else:
        selected_page_vision_result = {
            "selectedPageVisionUsed": False,
            "pageImageAnalyses": [],
            "detectedDiagrams": [],
            "diagramSummary": "",
            "visualTeachingHints": [],
            "metadata": {
                "selectedPageVisionAgentConnected": True,
                "selectedPageVisionUsed": False,
                "imageBytesLoaded": False,
                "geminiVisionCalled": False,
                "modelVisionUsed": False,
                "fallbackUsed": False,
                "usedSmartFallback": False,
                "skipReason": "no_page_images",
            },
        }

        trace.append(
            {
                "agent": "SelectedPageVisionAgent",
                "phase": "source-vision",
                "ok": True,
                "status": "skipped",
                "summary": "No page image available.",
                "fallbackUsed": False,
                "atMs": now_ms(),
            }
        )
        mission_trace.append(
            mission_item("SelectedPageVisionAgent", "skipped", "No selected page image reference found.")
        )
        working.update(
            {
                "selectedPageVision": selected_page_vision_result,
                "selectedPageVisionUsed": False,
            }
        )

    if bool(working.get("stopAfterSelectedPageVision")) or bool(working.get("visionProbeOnly")):
        # Save source-truth/vision checkpoint through MongoDB MCP before early return.
        # This makes MCP do a useful tutor action even during source-layer debug.
        if not bool(working.get("skipMcpSave")):
            source_checkpoint_candidate = {
                "sessionId": working.get("sessionId"),
                "ownerKey": working.get("ownerKey"),
                "offlineUserId": working.get("offlineUserId"),
                "resourceId": working.get("resourceId"),
                "treeId": working.get("treeId"),
                "boardId": working.get("boardId"),
                "selectedNode": selected_node(working),
                "title": get_title(working),
                "sourceRefs": safe_list(working.get("sourceRefs")),
                "sourceTruthPacket": safe_dict(working.get("sourceTruthPacket")),
                "ragRetrieval": safe_dict(working.get("ragRetrieval")),
                "selectedPageVision": selected_page_vision_result,
                "pageImageAnalyses": safe_list(selected_page_vision_result.get("pageImageAnalyses")),
                "detectedVisualDiagrams": safe_list(selected_page_vision_result.get("detectedDiagrams")),
                "selectedPageVisionDiagramSummary": clean_text(
                    selected_page_vision_result.get("diagramSummary"),
                    12000,
                ),
                "agentTrace": trace,
                "missionTrace": mission_trace,
                "mcpTrace": mcp_trace,
                "metadata": {
                    "checkpointStage": "selected_page_vision",
                    "sourceTruthCheckpoint": True,
                    "selectedPageVisionCheckpoint": True,
                    "fallbackUsed": False,
                    "usedSmartFallback": False,
                },
            }

            mcp_checkpoint_save = await run_mcp_mission_step(
                "mission_save_session",
                {
                    **working,
                    "mcpSaveKind": "selected_page_vision_source_truth_checkpoint",
                    "sourceTruthPacket": safe_dict(working.get("sourceTruthPacket")),
                    "selectedPageVision": selected_page_vision_result,
                    "pageImageAnalyses": safe_list(selected_page_vision_result.get("pageImageAnalyses")),
                    "detectedVisualDiagrams": safe_list(selected_page_vision_result.get("detectedDiagrams")),
                    "stage2Session": source_checkpoint_candidate,
                    "sessionId": working.get("sessionId"),
                    "resourceId": working.get("resourceId"),
                    "treeId": working.get("treeId"),
                    "boardId": working.get("boardId"),
                },
                trace,
                mission_trace,
                mcp_trace,
                tool_trace,
                "Save selected-page sourceTruth/vision checkpoint using MongoDB MCP.",
                require_mcp=require_mcp,
            )

            working["mcpSave"] = mcp_checkpoint_save
            working["mcpTrace"] = mcp_trace
            working["toolTrace"] = tool_trace
            working["partnerPower"] = build_partner_power(mcp_trace)

        return checkpoint_response(
            "selected_page_vision",
            working,
            trace,
            mission_trace,
            selected_page_vision_result,
            extra_metadata={
                "stoppedAfterSelectedPageVision": True,
                "mcpCheckpointSaveAttempted": not bool(working.get("skipMcpSave")),
            },
        )

    grounded_refs = dedupe_source_refs(rag_refs + collect_source_refs(selected_page_vision_result)) or rag_refs
    working.update(
        {
            "sourceRefs": grounded_refs,
            "groundedRefs": grounded_refs,
            "verifiedSourceRefs": grounded_refs,
        }
    )

    concept_payload = {
        **build_teaching_brain_packet(
            working,
            grounded_refs,
            selected_page_vision_result,
            mode="concept_extraction",
        ),
        "chunks": retrieved_chunks,
        "sourceRefs": grounded_refs,
        "selectedEvidence": working.get("selectedEvidence"),
        "samePageEvidence": working.get("samePageEvidence"),
        "nearbyEvidence": working.get("nearbyEvidence"),
        "comparisonEvidence": working.get("comparisonEvidence"),
        "selectedPageFullText": working.get("selectedPageFullText"),
        "fullPdfSummary": working.get("fullPdfSummary"),
        "fullPdfOutline": working.get("fullPdfOutline"),
    }

    concept = await run_required_agent(
        "ConceptExtractionAgent",
        concept_payload,
        trace,
        mission_trace,
        "Extracted source-grounded concepts from selected evidence and vision.",
        "source",
    )
    concept_result = output_result(concept)
    working["conceptExtraction"] = concept_result
    working["concepts"] = safe_list(concept_result.get("concepts") or concept_result.get("keyConcepts"))

    knowledge_payload = {
        **build_teaching_brain_packet(
            working,
            grounded_refs,
            selected_page_vision_result,
            concept_result=concept_result,
            mode="knowledge_graph",
        ),
        "chunks": retrieved_chunks,
        "sourceRefs": grounded_refs,
        "conceptExtraction": concept_result,
        "concepts": safe_list(concept_result.get("concepts") or concept_result.get("keyConcepts")),
        "selectedEvidence": working.get("selectedEvidence"),
        "selectedPageFullText": working.get("selectedPageFullText"),
    }

    knowledge = await run_required_agent(
        "KnowledgeGraphAgent",
        knowledge_payload,
        trace,
        mission_trace,
        "Built concept relationship graph from extracted concepts and vision relationships.",
        "source",
    )
    knowledge_result = output_result(knowledge)
    working["knowledgeGraph"] = knowledge_result

    strategy_payload = {
        **build_teaching_brain_packet(
            working,
            grounded_refs,
            selected_page_vision_result,
            concept_result=concept_result,
            knowledge_result=knowledge_result,
            mode="teaching_strategy",
        ),
        "sourceRefs": grounded_refs,
        "conceptExtraction": concept_result,
        "knowledgeGraph": knowledge_result,
        "selectedPageVision": selected_page_vision_result,
        "selectedEvidence": working.get("selectedEvidence"),
        "selectedPageFullText": working.get("selectedPageFullText"),
    }

    strategy = await run_required_agent(
        "TeachingStrategyAgent",
        strategy_payload,
        trace,
        mission_trace,
        "Planned human-tutor teaching strategy from concept graph and vision hints.",
        "planning",
    )
    strategy_result = output_result(strategy)
    working["teachingStrategy"] = strategy_result

    if bool(working.get("stopAfterTeachingStrategy")):
        return checkpoint_response(
            "teaching_strategy",
            working,
            trace,
            mission_trace,
            selected_page_vision_result,
            extra_result={
                "conceptExtraction": concept_result,
                "knowledgeGraph": knowledge_result,
                "teachingStrategy": strategy_result,
            },
            extra_metadata={
                "stoppedAfterTeachingStrategy": True,
                "phase1PreDetailedBrainWired": True,
                "conceptCount": len(safe_list(concept_result.get("concepts") or concept_result.get("keyConcepts"))),
                "knowledgeNodeCount": len(safe_list(knowledge_result.get("nodes"))),
                "knowledgeEdgeCount": len(safe_list(knowledge_result.get("edges"))),
                "teachingStepCount": len(safe_list(strategy_result.get("teachingSteps"))),
                "strategySourceRefCount": len(safe_list(strategy_result.get("sourceRefs"))),
            },
        )

    explanation_payload = {
        **build_teaching_brain_packet(
            working,
            grounded_refs,
            selected_page_vision_result,
            concept_result=concept_result,
            knowledge_result=knowledge_result,
            strategy_result=strategy_result,
            mode="detailed_explanation",
        ),
        "sourceRefs": grounded_refs,
        "conceptExtraction": concept_result,
        "knowledgeGraph": knowledge_result,
        "teachingStrategy": strategy_result,
        "selectedPageVision": selected_page_vision_result,
        "selectedEvidence": working.get("selectedEvidence"),
        "samePageEvidence": working.get("samePageEvidence"),
        "nearbyEvidence": working.get("nearbyEvidence"),
        "comparisonEvidence": working.get("comparisonEvidence"),
        "selectedPageFullText": working.get("selectedPageFullText"),
        "fullPdfSummary": working.get("fullPdfSummary"),
        "fullPdfOutline": working.get("fullPdfOutline"),
    }

    explanation_task = run_required_agent(
        "DetailedExplanationAgent",
        explanation_payload,
        trace,
        mission_trace,
        "Generated detailed source-grounded human tutor explanation.",
        "teaching",
    )
    analogy_task = run_optional_agent(
        "AnalogyExampleAgent",
        {
            **explanation_payload,
            "mode": "analogy_examples",
        },
        trace,
        mission_trace,
        "Generated examples/analogies from the same teaching brain packet.",
        "teaching",
    )

    explanation, analogy = await asyncio.gather(explanation_task, analogy_task)
    explanation_result = output_result(explanation)
    analogy_result = output_result(analogy)
    working["detailedExplanation"] = explanation_result
    working["analogyExample"] = analogy_result

    if bool(working.get("stopAfterTeachingBrain")):
        return checkpoint_response(
            "teaching_brain",
            working,
            trace,
            mission_trace,
            selected_page_vision_result,
            extra_result={
                "conceptExtraction": concept_result,
                "knowledgeGraph": knowledge_result,
                "teachingStrategy": strategy_result,
                "detailedExplanation": explanation_result,
                "analogyExample": analogy_result,
            },
            extra_metadata={
                "stoppedAfterTeachingBrain": True,
                "phase1TeachingBrainWired": True,
                "conceptCount": len(safe_list(concept_result.get("concepts") or concept_result.get("keyConcepts"))),
                "knowledgeNodeCount": len(safe_list(knowledge_result.get("nodes"))),
                "knowledgeEdgeCount": len(safe_list(knowledge_result.get("edges"))),
            },
        )

    visual_planner_packet = build_visual_planner_packet(
        working,
        grounded_refs,
        explanation_result,
        analogy_result,
        strategy_result,
    )
    working["visualPlannerPacket"] = visual_planner_packet

    visual_plan = await run_required_agent(
        "VisualPlannerAgent",
        {
            "mode": "plan_visuals",
            "selectedNode": visual_planner_packet.get("selectedNode"),
            "visualPlannerPacket": visual_planner_packet,
            "sourceRefs": grounded_refs,
            "requirePremiumScreens": True,
            "requireMultiScreen": True,
            "requireAutoGrow": True,
            "requireSourceEvidenceBlocks": True,
            "requireDiagramBlocks": True,
            "requireMistakeQuizBlocks": True,
            "studentLevel": working.get("studentLevel"),
            "language": working.get("language"),
            "question": working.get("question") or working.get("query"),
            "stage2AgentTimeoutMs": working.get("stage2AgentTimeoutMs"),
            "agentTimeoutsMs": working.get("agentTimeoutsMs"),
        },
        trace,
        mission_trace,
        "Planned rich visual board from compact source/vision/teaching packet.",
        "visual",
    )
    visual_result = output_result(visual_plan)

    if bool(working.get("stopAfterVisualPlanner")):
        return checkpoint_response(
            "visual_planner",
            working,
            trace,
            mission_trace,
            selected_page_vision_result,
            extra_result={"visualPlan": visual_result},
            extra_metadata={
                "stoppedAfterVisualPlanner": True,
                "premiumScreenCount": len(collect_screens(visual_result)),
            },
        )

    diagram_task = run_required_agent(
        "DiagramCompilerAgent",
        build_diagram_compiler_packet(
            working,
            grounded_refs,
            visual_result,
            explanation_result,
            selected_page_vision_result,
        ),
        trace,
        mission_trace,
        "Compiled diagrams.",
        "visual",
    )
    quiz_task = run_optional_agent(
        "AssessmentQuizAgent",
        {
            **working,
            "sourceRefs": grounded_refs,
            "explanation": explanation_result,
            "visualPlan": visual_result,
        },
        trace,
        mission_trace,
        "Generated quiz.",
        "assessment",
    )

    diagrams, quiz = await asyncio.gather(diagram_task, quiz_task)
    diagram_result = output_result(diagrams)
    quiz_result = output_result(quiz)

    board_scene = await run_required_agent(
        "BoardSceneAgent",
        build_board_scene_packet(
            working,
            grounded_refs,
            visual_result,
            diagram_result,
            explanation_result,
            quiz_result,
            selected_page_vision_result,
        ),
        trace,
        mission_trace,
        "Created premium board scenes.",
        "visual",
    )
    board_scene_result = output_result(board_scene)

    if bool(working.get("stopAfterBoardScene")):
        return checkpoint_response(
            "board_scene",
            working,
            trace,
            mission_trace,
            selected_page_vision_result,
            extra_result={
                "visualPlan": visual_result,
                "compiledDiagrams": collect_diagrams(diagram_result),
                "boardScene": board_scene_result,
                "premiumBoardScreens": collect_screens(board_scene_result, visual_result),
                "boardSections": collect_sections(board_scene_result, visual_result, explanation_result),
                "quiz": quiz_result,
            },
            extra_metadata={
                "stoppedAfterBoardScene": True,
                "premiumScreenCount": len(collect_screens(board_scene_result, visual_result)),
            },
        )

    board_commands = await run_required_agent(
        "BoardCommandAgent",
        build_board_command_packet(
            working,
            grounded_refs,
            board_scene_result,
            visual_result,
            diagram_result,
            selected_page_vision_result,
        ),
        trace,
        mission_trace,
        "Created board animation commands.",
        "visual",
    )
    command_result = output_result(board_commands)

    layout_task = run_required_agent(
        "LayoutAgent",
        build_layout_packet(
            working,
            grounded_refs,
            board_scene_result,
            command_result,
        ),
        trace,
        mission_trace,
        "Validated board layout.",
        "visual",
    )
    handwriting_task = run_optional_agent(
        "HandwritingDrawingAgent",
        build_handwriting_packet(
            working,
            grounded_refs,
            command_result,
            selected_page_vision_result,
        ),
        trace,
        mission_trace,
        "Added handwriting drawing hints.",
        "visual",
    )

    layout, handwriting = await asyncio.gather(layout_task, handwriting_task)
    layout_result = output_result(layout)
    handwriting_result = output_result(handwriting)

    voice = await run_required_agent(
        "VoiceScriptAgent",
        build_voice_script_packet(
            working,
            grounded_refs,
            explanation_result,
            board_scene_result,
            command_result,
            selected_page_vision_result,
        ),
        trace,
        mission_trace,
        "Generated voice script.",
        "live",
    )
    voice_result = output_result(voice)

    subtitles = await run_required_agent(
        "SubtitleSyncAgent",
        build_subtitle_packet(
            working,
            voice_result,
            command_result,
        ),
        trace,
        mission_trace,
        "Synced subtitles.",
        "live",
    )
    subtitle_result = output_result(subtitles)

    board_commands_list = collect_board_commands(command_result, board_scene_result, visual_result)
    voice_script = collect_voice_script(voice_result)
    subtitle_list = collect_subtitles(subtitle_result)
    board_sections = collect_sections(board_scene_result, visual_result, explanation_result)
    premium_screens = collect_screens(board_scene_result, visual_result)
    compiled_diagrams = collect_diagrams(diagram_result)

    if not board_commands_list:
        raise RuntimeError("Final Stage2 validation failed: boardCommands is empty.")
    if not voice_script:
        raise RuntimeError("Final Stage2 validation failed: voiceScript is empty.")
    if not subtitle_list:
        raise RuntimeError("Final Stage2 validation failed: subtitles is empty.")

    lesson_transcript = lesson_transcript_from(voice_script, explanation_result, board_sections)
    partner_power = build_partner_power(mcp_trace)
    vision_meta = _vision_meta(selected_page_vision_result)

    candidate = {
        "title": get_title(working),
        "selectedNode": selected_node(working),
        "missionTrace": mission_trace,
        "agentTrace": trace,
        "toolTrace": tool_trace,
        "mcpTrace": mcp_trace,
        "partnerPower": partner_power,
        "mcpContext": mcp_read,
        "ragRetrieval": rag_result,
        "selectedPageVision": selected_page_vision_result,
        "selectedPageVisionUsed": vision_meta["selectedPageVisionUsed"],
        "pageImageAnalyses": safe_list(selected_page_vision_result.get("pageImageAnalyses")),
        "detectedVisualDiagrams": safe_list(selected_page_vision_result.get("detectedDiagrams")),
        "selectedPageVisionDiagramSummary": vision_meta["diagramSummary"],
        "visualContext": working.get("visualContext"),
        "conceptExtraction": concept_result,
        "knowledgeGraph": knowledge_result,
        "teachingStrategy": strategy_result,
        "detailedExplanation": explanation_result,
        "analogyExamples": analogy_result,
        "visualPlan": visual_result,
        "boardScene": board_scene_result,
        "boardSections": board_sections,
        "premiumBoardScreens": premium_screens,
        "boardScreens": premium_screens,
        "compiledDiagrams": compiled_diagrams,
        "diagramArtifacts": safe_dict(diagram_result.get("diagramArtifacts"))
        or {"compiledDiagrams": compiled_diagrams},
        "layout": layout_result,
        "handwriting": handwriting_result,
        "boardCommands": board_commands_list,
        "commands": board_commands_list,
        "voiceScript": voice_script,
        "subtitles": subtitle_list,
        "quiz": quiz_result,
        "lessonTranscript": lesson_transcript,
        "sourceRefs": grounded_refs,
        "sourceCards": safe_list(board_scene_result.get("sourceCards"))
        or safe_list(visual_result.get("sourceCards")),
        "htmlPreviews": safe_list(diagram_result.get("htmlPreviews"))
        or safe_list(visual_result.get("htmlPreviews")),
        "imagePreviews": safe_list(working.get("pageImages"))[:12],
        "metadata": {
            "realSeparateAgents": True,
            "realMultiAgentMission": True,
            "sourceGrounded": True,
            "agentCountUsed": len(trace),
            "missionStepCount": len(mission_trace),
            "mcpTraceCount": len(mcp_trace),
            "mcpUsed": partner_power.get("mcpUsed"),
            "mcpToolCallCount": partner_power.get("toolCallCount"),
            "partner": "MongoDB",
            "diagramCompilerUsed": True,
            "compiledDiagramCount": len(compiled_diagrams),
            "premiumScreenCount": len(premium_screens),
            "boardCommandCount": len(board_commands_list),
            "voiceLineCount": len(voice_script),
            "subtitleCount": len(subtitle_list),
            **vision_meta,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }

    if not bool(working.get("skipMcpSave")):
        mcp_save = await run_mcp_mission_step(
            "mission_save_session",
            {
                **working,
                "stage2Session": candidate,
                "sessionId": working.get("sessionId"),
                "resourceId": working.get("resourceId"),
                "treeId": working.get("treeId"),
                "boardId": working.get("boardId"),
            },
            trace,
            mission_trace,
            mcp_trace,
            tool_trace,
            "Save/prove Stage2 session using MongoDB MCP.",
            require_mcp=require_mcp,
        )
    else:
        mcp_save = {}

    candidate["mcpSave"] = mcp_save
    candidate["mcpTrace"] = mcp_trace
    candidate["toolTrace"] = tool_trace
    candidate["partnerPower"] = build_partner_power(mcp_trace)
    candidate["metadata"]["mcpUsed"] = candidate["partnerPower"].get("mcpUsed")
    candidate["metadata"]["mcpToolCallCount"] = candidate["partnerPower"].get("toolCallCount")

    candidate["flowAudit"] = build_flow_audit(
        trace,
        mission_trace,
        mcp_trace,
        candidate,
    )

    candidate["metadata"]["flowAuditOk"] = bool(candidate["flowAudit"].get("ok"))
    candidate["metadata"]["missingExpectedSpine"] = candidate["flowAudit"].get("missingExpectedSpine")
    candidate["metadata"]["commandTypes"] = candidate["flowAudit"].get("commandTypes")
    candidate["metadata"]["mcpUsed"] = candidate["partnerPower"].get("mcpUsed") or candidate["flowAudit"].get("mcpUsed")

    assert_final_flow_quality(candidate, require_mcp=require_mcp)

    if not bool(working.get("skipFinalValidator")):
        final_validation = await run_required_agent(
            "ValidatorSafetyAgent",
            {"candidate": candidate, "strict": True},
            trace,
            mission_trace,
            "Validated final lesson.",
            "validation",
        )
        final_validation_result = output_result(final_validation).get("validation") or output_result(final_validation)
    else:
        final_validation_result = {
            "ok": True,
            "skipped": True,
            "reason": "skipFinalValidator=true",
            "fallbackUsed": False,
            "usedSmartFallback": False,
        }

    return {
        "ok": True,
        "mode": "teach_node_pipeline",
        "result": {
            **candidate,
            "validation": final_validation_result,
        },
        "trace": trace,
        "agentTrace": trace,
        "missionTrace": mission_trace,
        "toolTrace": tool_trace,
        "mcpTrace": mcp_trace,
        "partnerPower": candidate["partnerPower"],
        "selectedPageVision": selected_page_vision_result,
        "metadata": {
            "realSeparateAgents": True,
            "realMultiAgentMission": True,
            "agentCountUsed": len(trace),
            "missionStepCount": len(mission_trace),
            "mcpTraceCount": len(mcp_trace),
            "mcpUsed": candidate["partnerPower"].get("mcpUsed"),
            "mcpToolCallCount": candidate["partnerPower"].get("toolCallCount"),
            "partner": "MongoDB",
            "sourceGrounded": True,
            "diagramCompilerUsed": True,
            "compiledDiagramCount": len(compiled_diagrams),
            "premiumScreenCount": len(premium_screens),
            **vision_meta,
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


async def run_interrupt_repair_pipeline(payload: JsonDict) -> JsonDict:
    trace: List[JsonDict] = []
    mission_trace: List[JsonDict] = []
    mcp_trace: List[JsonDict] = []
    tool_trace: List[JsonDict] = []

    repair = await run_required_agent(
        "RepairConfusionAgent",
        {
            **safe_dict(payload),
            "mode": "interrupt_repair",
            "question": payload.get("question")
            or payload.get("interruptText")
            or payload.get("message")
            or "Student interrupted the lesson.",
            "boardCommands": safe_list(payload.get("boardCommands")),
            "voiceScript": safe_list(payload.get("voiceScript")),
            "subtitles": safe_list(payload.get("subtitles")),
            "selectedPageVision": payload.get("selectedPageVision"),
        },
        trace,
        mission_trace,
        "Repaired lesson after student interrupt.",
        "repair",
    )

    result = output_result(repair)
    board_commands = collect_board_commands(result)
    voice_script = collect_voice_script(result)
    subtitles = collect_subtitles(result)

    if not board_commands:
        board_commands = safe_list(result.get("repairCommands"))
    if not voice_script:
        voice_script = safe_list(result.get("repairVoiceScript"))
    if not subtitles:
        subtitles = safe_list(result.get("repairSubtitles"))

    if not board_commands or not voice_script:
        raise RuntimeError("Interrupt repair returned weak output: commands/voiceScript missing.")

    return {
        "ok": True,
        "mode": "interrupt_repair_pipeline",
        "result": {
            **result,
            "boardCommands": board_commands,
            "voiceScript": voice_script,
            "subtitles": subtitles,
            "trace": trace,
            "missionTrace": mission_trace,
            "metadata": {
                "fallbackUsed": False,
                "usedSmartFallback": False,
            },
        },
        "trace": trace,
        "missionTrace": mission_trace,
        "mcpTrace": mcp_trace,
        "toolTrace": tool_trace,
        "metadata": {
            "fallbackUsed": False,
            "usedSmartFallback": False,
        },
    }


