def _json(value: Any, limit: int = 170000) -> str:
    try:
        return clean_text(json.dumps(value, ensure_ascii=False, indent=2), limit)
    except Exception:
        return clean_text(value, limit)


def _words(value: Any) -> List[str]:
    text = clean_text(value, 5000).lower()
    return [w for w in re.findall(r"[a-zA-Z0-9_]+", text) if len(w) >= 3]


def _selected_pages(payload: JsonDict) -> List[Any]:
    pages: List[Any] = []
    node = safe_dict(payload.get("selectedNode") or payload.get("node"))
    pages.extend(safe_list(node.get("pages")))
    pages.extend(safe_list(node.get("pageNumbers")))

    for key in ["selectedEvidence", "samePageEvidence"]:
        for item in safe_list(payload.get(key)):
            page = safe_dict(item).get("page") or safe_dict(item).get("pageNumber")
            if page not in (None, ""):
                pages.append(page)

    source_truth = safe_dict(payload.get("sourceTruth"))
    for key in ["selectedEvidence", "samePageEvidence"]:
        for item in safe_list(source_truth.get(key)):
            page = safe_dict(item).get("page") or safe_dict(item).get("pageNumber")
            if page not in (None, ""):
                pages.append(page)

    out: List[Any] = []
    seen = set()
    for page in pages:
        k = str(page)
        if k not in seen:
            seen.add(k)
            out.append(page)
    return out


def _selected_title(payload: JsonDict) -> str:
    node = safe_dict(payload.get("selectedNode") or payload.get("node"))
    return clean_text(
        node.get("title")
        or node.get("label")
        or node.get("name")
        or node.get("nodeId")
        or payload.get("question")
        or "selected concept",
        260,
    )


def _selected_keywords(payload: JsonDict) -> List[str]:
    terms: List[str] = []
    node = safe_dict(payload.get("selectedNode") or payload.get("node"))

    for part in [
        node.get("title"),
        node.get("label"),
        node.get("definition"),
        node.get("summary"),
        payload.get("question"),
    ]:
        terms.extend(_words(part))

    for key in ["selectedEvidence", "samePageEvidence"]:
        for item in safe_list(payload.get(key)):
            terms.extend(_words(safe_dict(item).get("text") or safe_dict(item).get("quote") or ""))

    source_truth = safe_dict(payload.get("sourceTruth"))
    for key in ["selectedEvidence", "samePageEvidence"]:
        for item in safe_list(source_truth.get(key)):
            terms.extend(_words(safe_dict(item).get("text") or safe_dict(item).get("quote") or ""))

    stop = {
        "the", "and", "for", "with", "that", "this", "from", "table",
        "data", "database", "schema", "concept", "page", "source",
        "student", "teacher", "lesson",
    }

    out: List[str] = []
    seen = set()
    for term in terms:
        if term in stop:
            continue
        if term not in seen:
            seen.add(term)
            out.append(term)
        if len(out) >= 70:
            break
    return out


def _ref_from_item(item: JsonDict, role: str = "") -> JsonDict:
    return {
        "chunkId": clean_text(item.get("chunkId") or item.get("id") or "", 220),
        "sourceRef": clean_text(
            item.get("sourceRef") or item.get("pageRef") or item.get("chunkId") or item.get("id") or "",
            380,
        ),
        "pageRef": clean_text(item.get("pageRef") or item.get("sourceRef") or "", 380),
        "page": item.get("page") or item.get("pageNumber"),
        "quote": clean_text(item.get("quote") or item.get("textPreview") or item.get("text") or "", 1500),
        "confidence": item.get("confidence") or 0.82,
        "resourceId": clean_text(item.get("resourceId") or "", 220),
        "evidenceRole": clean_text(role or item.get("evidenceRole") or "", 120),
    }


def _looks_empty_ref(ref: JsonDict) -> bool:
    r = safe_dict(ref)
    return not clean_text(r.get("quote")) and not clean_text(r.get("sourceRef")) and not clean_text(r.get("chunkId"))


def _ref_score(ref: JsonDict, selected_pages: List[Any], keywords: List[str], role: str) -> float:
    r = safe_dict(ref)
    quote = clean_text(r.get("quote"), 1600)
    page = r.get("page")
    page_s = str(page) if page not in (None, "") else ""
    selected_page_set = {str(x) for x in selected_pages}

    if _looks_empty_ref(r):
        return -100.0

    score = 0.0
    if quote:
        score += 4.0
    if r.get("sourceRef") or r.get("chunkId"):
        score += 2.0
    if page_s and page_s in selected_page_set:
        score += 8.0
    if role == "selectedEvidence":
        score += 7.0
    if role == "samePageEvidence":
        score += 5.0
    if role == "nearbyEvidence":
        score += 2.0
    if role == "comparisonEvidence":
        score += 1.0

    q_words = set(_words(quote))
    if keywords and q_words:
        overlap = len(q_words.intersection(set(keywords)))
        score += min(9.0, overlap * 1.4)

    lower_quote = quote.lower()
    if page_s not in selected_page_set:
        if len(quote.split()) < 5:
            score -= 6.0
        if "software design and architecture" in lower_quote and len(quote.split()) < 14:
            score -= 7.0
        if "lets solve" in lower_quote or "top management want" in lower_quote:
            score -= 5.0
        if "galaxy schema" in lower_quote and "galaxy" not in keywords:
            score -= 4.0

    return score


def _collect_ranked_refs(payload: JsonDict) -> Dict[str, List[JsonDict]]:
    selected_pages = _selected_pages(payload)
    keywords = _selected_keywords(payload)

    buckets: Dict[str, List[Tuple[float, JsonDict]]] = {
        "selected": [],
        "samePage": [],
        "nearby": [],
        "comparison": [],
        "related": [],
        "general": [],
    }

    def push(role: str, score: float, ref: JsonDict) -> None:
        if role == "selectedEvidence":
            buckets["selected"].append((score, ref))
        elif role == "samePageEvidence":
            buckets["samePage"].append((score, ref))
        elif role == "nearbyEvidence":
            buckets["nearby"].append((score, ref))
        elif role == "comparisonEvidence":
            buckets["comparison"].append((score, ref))
        elif role == "relatedEvidence":
            buckets["related"].append((score, ref))
        else:
            buckets["general"].append((score, ref))

    def add(role: str, item: Any) -> None:
        raw = safe_dict(item)
        if not raw:
            return

        refs = safe_list(raw.get("sourceRefs"))
        if refs:
            for rr in refs:
                ref = _ref_from_item({**raw, **safe_dict(rr)}, role)
                score = _ref_score(ref, selected_pages, keywords, role)
                if score > 0:
                    push(role, score, ref)
        else:
            ref = _ref_from_item(raw, role)
            score = _ref_score(ref, selected_pages, keywords, role)
            if score > 0:
                push(role, score, ref)

    source_truth = safe_dict(payload.get("sourceTruth"))

    for key in ["selectedEvidence", "samePageEvidence", "nearbyEvidence", "comparisonEvidence", "relatedEvidence"]:
        for item in safe_list(payload.get(key)):
            add(key, item)
        for item in safe_list(source_truth.get(key)):
            add(key, item)

    for item in safe_list(payload.get("sourceRefs")):
        add("general", item)

    for item in safe_list(safe_dict(payload.get("selectedNode") or payload.get("node")).get("sourceRefs")):
        add("selectedEvidence", item)

    for item in safe_list(payload.get("chunks")):
        add("general", item)

    result: Dict[str, List[JsonDict]] = {}
    for bucket, scored in buckets.items():
        scored.sort(key=lambda x: x[0], reverse=True)
        result[bucket] = dedupe_source_refs(normalize_source_refs([ref for _, ref in scored]))[:30]

    result["primary"] = dedupe_source_refs(
        result["selected"][:8]
        + result["samePage"][:6]
        + result["nearby"][:3]
        + result["general"][:3]
    )[:16]

    result["allClean"] = dedupe_source_refs(
        result["selected"]
        + result["samePage"]
        + result["nearby"]
        + result["comparison"]
        + result["related"]
        + result["general"]
    )[:70]

    return result


def _step_refs_for_role(step: JsonDict, clean_refs: Dict[str, List[JsonDict]]) -> List[JsonDict]:
    raw_refs = dedupe_source_refs([safe_dict(x) for x in safe_list(step.get("sourceRefs"))])
    keywords = _words(step.get("name")) + _words(step.get("teacherMove")) + _words(step.get("boardMove"))

    filtered: List[JsonDict] = []
    for ref in raw_refs:
        if _ref_score(ref, [], keywords, "step") > 0 and clean_text(ref.get("quote")):
            filtered.append(ref)

    if filtered:
        return dedupe_source_refs(filtered)[:5]

    visual_type = clean_text(step.get("visualType"), 80).lower()
    name = (
        clean_text(step.get("name"), 200).lower()
        + " "
        + clean_text(step.get("teacherMove"), 800).lower()
        + " "
        + clean_text(step.get("boardMove"), 800).lower()
    )

    if "compare" in visual_type or "comparison" in name or "versus" in name or " vs " in name:
        refs = clean_refs["comparison"][:4] + clean_refs["primary"][:2]
    else:
        refs = clean_refs["primary"][:5]

    return dedupe_source_refs(refs)[:5]


def _bridge_refs(bridge: JsonDict, primary_refs: List[JsonDict]) -> List[JsonDict]:
    refs = dedupe_source_refs([safe_dict(x) for x in safe_list(bridge.get("sourceRefs"))])
    cleaned: List[JsonDict] = []
    for ref in refs:
        if clean_text(ref.get("quote")) and (ref.get("sourceRef") or ref.get("chunkId")):
            cleaned.append(ref)
    if not cleaned:
        cleaned = primary_refs[:4]
    return dedupe_source_refs(normalize_source_refs(cleaned))[:6]


class TeachingStrategyAgent(BaseLiveTutorAgent):
    agent_name = "TeachingStrategyAgent"
    agent_group = "planning"
    default_mode = "plan_teaching_strategy"
    uses_adk = True

    @property
    def instruction(self) -> str:
        return """
You are TeachingStrategyAgent for a world-class human-like Live Tutor.

Your job:
- Decide how to teach the selected node.
- Use source truth as factual truth.
- Use selected page vision for diagram/layout/teacher marking.
- Use conceptExtraction and knowledgeGraph to plan teaching order.
- Produce a rich strategy that DetailedExplanationAgent can turn into a
  worldTeacherLesson and VisualPlanner can turn into board screens.

Hard rules:
- Output ONLY JSON.
- No fixed domain.
- No fake fallback.
- No unsupported facts.
- No paragraph-only strategy.
- Do not create final boardCommands.
- Every teaching step must include clean sourceRefs.
- Do not attach unrelated pages or empty quote refs to every step.
"""

    def validate_input(self, payload: JsonDict) -> ValidationResult:
        errors: List[str] = []
        warnings: List[str] = []

        selected_node = safe_dict(payload.get("selectedNode") or payload.get("node"))
        chunks = safe_list(payload.get("chunks"))
        clean_refs = _collect_ranked_refs(payload)

        if not selected_node:
            errors.append("TeachingStrategyAgent requires selectedNode/node.")
        if not chunks and not clean_refs.get("primary"):
            errors.append("TeachingStrategyAgent requires chunks or clean sourceRefs.")
        if not clean_refs.get("primary"):
            errors.append("TeachingStrategyAgent could not build clean primary sourceRefs.")
        if not safe_dict(payload.get("conceptExtraction")):
            warnings.append("conceptExtraction missing; strategy may be less structured.")
        if not safe_dict(payload.get("knowledgeGraph")):
            warnings.append("knowledgeGraph missing; strategy may be less connected.")

        return ValidationResult(
            ok=not errors,
            errors=errors,
            warnings=warnings,
            validator="TeachingStrategyAgent.validate_input",
            fallbackUsed=False,
        )

