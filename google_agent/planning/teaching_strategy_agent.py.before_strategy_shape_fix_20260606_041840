    def run_without_adk(self, payload: JsonDict, context: AgentContext) -> JsonDict:
        raise RuntimeError("TeachingStrategyAgent requires Gemini/ADK. No rule-based/static fallback is allowed.")

    def normalize_output(self, raw: JsonDict, payload: JsonDict, context: AgentContext) -> JsonDict:
        raw = safe_dict(raw)
        if isinstance(raw.get("result"), dict):
            raw = safe_dict(raw.get("result"))

        clean_refs = _collect_ranked_refs(payload)
        primary_refs = clean_refs.get("primary", [])
        all_clean_refs = clean_refs.get("allClean", []) or primary_refs

        if not primary_refs:
            raise RuntimeError("TeachingStrategyAgent cannot normalize without clean primary sourceRefs.")

        steps: List[JsonDict] = []
        for index, item in enumerate(safe_list(raw.get("teachingSteps") or raw.get("steps"))):
            step = safe_dict(item)
            step_refs = _step_refs_for_role(step, clean_refs)
            steps.append(
                {
                    "stepId": normalize_id(step.get("stepId") or f"step_{index + 1}", f"step_{index + 1}"),
                    "name": clean_text(step.get("name") or f"Step {index + 1}", 180),
                    "teacherMove": clean_text(step.get("teacherMove") or "", 2400),
                    "boardMove": clean_text(step.get("boardMove") or "", 2200),
                    "visualType": clean_text(step.get("visualType") or "definition", 100),
                    "reason": clean_text(step.get("reason") or "", 1300),
                    "learningOutcome": clean_text(step.get("learningOutcome") or "", 900),
                    "sourceRefs": step_refs,
                    "metadata": {
                        **safe_dict(step.get("metadata")),
                        "sourceRefsCleanedV2": True,
                        "sourceRefsRepairedFromPayload": False,
                    },
                }
            )

        repair_routes: List[JsonDict] = []
        for index, item in enumerate(safe_list(raw.get("repairRoutes"))):
            route = safe_dict(item)
            route_refs = _step_refs_for_role(route, clean_refs)
            repair_routes.append(
                {
                    "routeId": normalize_id(route.get("routeId") or f"repair_{index + 1}", f"repair_{index + 1}"),
                    "trigger": clean_text(route.get("trigger") or "", 800),
                    "repairMove": clean_text(route.get("repairMove") or "", 2200),
                    "boardMove": clean_text(route.get("boardMove") or "", 1800),
                    "sourceRefs": route_refs,
                    "metadata": {
                        **safe_dict(route.get("metadata")),
                        "sourceRefsCleanedV2": True,
                    },
                }
            )

        board_action_plan: List[JsonDict] = []
        for index, item in enumerate(safe_list(raw.get("boardActionPlan"))):
            action = safe_dict(item)
            refs = _step_refs_for_role(action, clean_refs)
            board_action_plan.append(
                {
                    "actionPlanId": normalize_id(
                        action.get("actionPlanId") or f"board_plan_{index + 1}",
                        f"board_plan_{index + 1}",
                    ),
                    "stepId": clean_text(action.get("stepId") or "", 160),
                    "intent": clean_text(action.get("intent") or "write", 80),
                    "target": clean_text(action.get("target") or action.get("text") or "", 900),
                    "sourceRefs": refs,
                    "metadata": {**safe_dict(action.get("metadata")), "sourceRefsCleanedV2": True},
                }
            )

        student_model = safe_dict(raw.get("studentModel"))
        pacing_plan = safe_dict(raw.get("pacingPlan"))
        voice_style = safe_dict(raw.get("voiceStyle"))
        visual_bridge_raw = safe_dict(raw.get("visualBoardBridge"))

        all_refs: List[JsonDict] = []
        all_refs.extend(primary_refs)
        for step in steps:
            all_refs.extend(safe_list(step.get("sourceRefs")))
        for route in repair_routes:
            all_refs.extend(safe_list(route.get("sourceRefs")))
        for action in board_action_plan:
            all_refs.extend(safe_list(action.get("sourceRefs")))

        return {
            "strategyId": normalize_id(raw.get("strategyId") or "strategy_1", "strategy_1"),
            "title": clean_text(raw.get("title") or "Teaching Strategy", 220),
            "teachingGoal": clean_text(raw.get("teachingGoal") or raw.get("goal") or "", 1600),
            "studentModel": {
                "level": clean_text(student_model.get("level") or context.studentLevel, 80),
                "likelyPriorKnowledge": [clean_text(x, 350) for x in safe_list(student_model.get("likelyPriorKnowledge"))],
                "likelyConfusions": [clean_text(x, 500) for x in safe_list(student_model.get("likelyConfusions"))],
                "preferredLanguage": clean_text(student_model.get("preferredLanguage") or context.language, 80),
            },
            "teachingSteps": steps,
            "boardActionPlan": board_action_plan,
            "visualBoardBridge": {
                "mustDraw": [clean_text(x, 500) for x in safe_list(visual_bridge_raw.get("mustDraw"))],
                "mustHighlight": [clean_text(x, 500) for x in safe_list(visual_bridge_raw.get("mustHighlight"))],
                "mustConnect": [clean_text(x, 500) for x in safe_list(visual_bridge_raw.get("mustConnect"))],
                "mustAvoid": [clean_text(x, 500) for x in safe_list(visual_bridge_raw.get("mustAvoid"))],
                "screenRoleHints": [clean_text(x, 300) for x in safe_list(visual_bridge_raw.get("screenRoleHints"))],
                "sourceRefs": _bridge_refs(visual_bridge_raw, primary_refs),
                "metadata": {
                    "worldTeachingStrategyV2": True,
                    "readyForVisualPlanner": True,
                },
            },
            "pacingPlan": {
                "pace": clean_text(pacing_plan.get("pace") or "normal", 60),
                "pausePoints": [clean_text(x, 350) for x in safe_list(pacing_plan.get("pausePoints"))],
                "interruptChecks": [clean_text(x, 350) for x in safe_list(pacing_plan.get("interruptChecks"))],
            },
            "repairRoutes": repair_routes,
            "voiceStyle": {
                "tone": clean_text(voice_style.get("tone") or "warm private tutor", 120),
                "pace": clean_text(voice_style.get("pace") or "normal", 60),
                "emphasisWords": [clean_text(x, 120) for x in safe_list(voice_style.get("emphasisWords"))],
            },
            "qualitySignals": {
                **safe_dict(raw.get("qualitySignals")),
                "worldTeachingStrategyV2": True,
                "cleanSourceRefs": True,
                "readyForDetailedExplanation": True,
                "readyForVisualPlanner": True,
                "teachingStepCount": len(steps),
                "boardActionPlanCount": len(board_action_plan),
                "repairRouteCount": len(repair_routes),
                "fallbackUsed": False,
            },
            "sourceRefs": dedupe_source_refs(normalize_source_refs(all_refs or all_clean_refs)),
            "metadata": {
                **safe_dict(raw.get("metadata")),
                "agent": self.agent_name,
                "realSeparateAgent": True,
                "fallbackUsed": False,
                "usedSmartFallback": False,
                "humanTutorStyle": True,
                "interruptRepairReady": True,
                "worldTeachingStrategyV2": True,
                "sourceRefsCleanedV2": True,
                "sourceRefsRepairedFromPayload": False,
            },
        }

    def validate_output(self, output: JsonDict, payload: JsonDict, context: AgentContext) -> ValidationResult:
        errors: List[str] = []
        warnings: List[str] = []

        if not clean_text(output.get("teachingGoal")):
            errors.append("teachingGoal is required.")

        steps = safe_list(output.get("teachingSteps"))
        if len(steps) < 7:
            errors.append("teachingSteps must contain at least 7 world-teacher steps.")

        ref_validation = require_source_refs(
            safe_list(output.get("sourceRefs")),
            "TeachingStrategyAgent.output.sourceRefs",
        )
        errors.extend(ref_validation.errors)

        for index, step in enumerate(steps):
            item = safe_dict(step)
            if len(clean_text(item.get("teacherMove")).split()) < 20:
                errors.append(f"teachingSteps[{index}].teacherMove is too short.")
            if not clean_text(item.get("boardMove")):
                errors.append(f"teachingSteps[{index}].boardMove is required.")
            if not clean_text(item.get("learningOutcome")):
                warnings.append(f"teachingSteps[{index}].learningOutcome should be present.")
            if not safe_list(item.get("sourceRefs")):
                errors.append(f"teachingSteps[{index}].sourceRefs are required.")

            for ref in safe_list(item.get("sourceRefs")):
                r = safe_dict(ref)
                if not clean_text(r.get("quote")):
                    warnings.append(f"teachingSteps[{index}] contains sourceRef with empty quote; should be avoided.")

        if len(safe_list(output.get("repairRoutes"))) < 2:
            errors.append("repairRoutes must contain at least 2 misconception repair paths.")

        if not safe_dict(output.get("visualBoardBridge")):
            errors.append("visualBoardBridge is required for VisualPlanner handoff.")

        if len(safe_list(output.get("boardActionPlan"))) < 5:
            warnings.append("boardActionPlan should have at least 5 board intents.")

        if safe_dict(output.get("metadata")).get("sourceRefsRepairedFromPayload"):
            errors.append("sourceRefsRepairedFromPayload should be false after V2 clean source strategy.")

        return ValidationResult(
            ok=not errors,
            errors=errors,
            warnings=warnings,
            validator="TeachingStrategyAgent.validate_output",
            fallbackUsed=False,
        )


